CREATE OR REPLACE TABLE core_bld.default.DataRetentionAnalysis_system_test AS

WITH mqs AS (
    SELECT
        headers['MQSQuoteId'] AS mqsQuoteId,
        headers['externalID'] AS externalID,
        headers['quoteDate'] AS quoteDate,
        get_json_object(payload, '$.control.transactionType') AS transactionType,
        get_json_object(payload, '$.control.todayDate') || ' ' ||
        get_json_object(payload, '$.control.currentTime') AS quoteRequestDate,
        enqueuedTime,
        ethuQueuedDateStamp,
        payload,
        headers,

        CASE
            WHEN array_contains(
                transform(
                    from_json(
                        get_json_object(payload, '$.mteEnrichments'),
                        'array<struct<provider:string>>'
                    ),
                    x -> x.provider
                ),
                'mylicence'
            ) THEN 'present'
            ELSE 'not_present'
        END AS provider_status,

        CASE
            WHEN year(headers['quoteDate']) < year(ethuQueuedDateStamp) THEN 'invaliddateissue'
            ELSE 'validate'
        END AS quoteDate_status

    FROM core_bld.mqs_ethu_utr_dvla_test.ethubstream
    WHERE CAST(ethuQueuedDateStamp AS DATE) = '2026-02-09'
      AND headers['messageType'] = 'mqs-quote-request'
      -- AND headers['MQSQuoteId'] = 'MQS-f4295fe3-34a6-4211-9c2e-8b782818803a'
),

athn1 AS (
    SELECT
        mqsQuoteId,
        interactionId,
        status,
        eventType,
        process,
        agreementNumber,
        timeStamp,
        rateDate,
        quoteDate,
        originalQuoteDate,
        inceptionDate,
        writeTimestamp,
        ethuQueuedDateStamp,
        TimeEnqueued,
        process_code,
        updatedOn
    FROM core_bld.default.athena_base_table_update
    -- WHERE mqsQuoteId = 'MQS-f4295fe3-34a6-4211-9c2e-8b782818803a'
),

athn_dedup AS (
    SELECT
        mqsQuoteId,
        interactionId,
        status,
        eventType,
        process,
        agreementNumber,
        timeStamp,
        rateDate,
        quoteDate,
        originalQuoteDate,
        inceptionDate,
        writeTimestamp,
        ethuQueuedDateStamp,
        TimeEnqueued,
        process_code,
        updatedOn
    FROM (
        SELECT
            a.*,
            ROW_NUMBER() OVER (
                PARTITION BY a.mqsQuoteId, a.interactionId, a.process_code
                ORDER BY a.TimeEnqueued ASC
            ) AS rn
        FROM athn1 a
    ) x
    WHERE rn = 1
),

athn_status AS (
    SELECT
        mqsQuoteId,
        MAX(CASE WHEN status = 'AGREEMENT' THEN 1 ELSE 0 END) AS has_agreement
    FROM core_bld.default.athena_base_table_update
    GROUP BY mqsQuoteId
)

SELECT
    mqs.*,
    s.mqsQuoteId AS soldAthenaMqsQuoteId,
    s.has_agreement,
    a.mqsQuoteId AS quoteAthenaMqsQuoteId,
    a.process_code AS athenaProcessCode,
    a.interactionId AS athenaInteractionId,

    CASE
        WHEN s.has_agreement = 1 THEN 'converted_quote'

        WHEN s.has_agreement = 0
             AND a.mqsQuoteId IS NOT NULL THEN
            CASE
                WHEN mqs.quoteDate_status = 'validate' THEN
                    CASE
                        WHEN datediff(current_date(), mqs.quoteDate) > 30
                            THEN 'unconverted_quote_delete_dvla'
                        ELSE 'unconverted_quote_in_retention_period'
                    END

                WHEN mqs.quoteDate_status = 'invaliddateissue' THEN
                    CASE
                        WHEN datediff(current_date(), a.updatedOn) > 30
                            THEN 'unconverted_quote_delete_dvla_athenabased'
                        ELSE 'unconverted_quote_in_retention_period_athenabased'
                    END

                ELSE 'undecided'
            END

        WHEN s.has_agreement IS NULL THEN
            CASE
                WHEN mqs.quoteDate_status = 'validate' THEN
                    CASE
                        WHEN datediff(current_date(), mqs.quoteDate) > 30
                            THEN 'unconverted_quote_delete_dvla_no_athena_match'
                        ELSE 'unconverted_quote_in_retention_period_no_athena_match'
                    END
                ELSE 'undecided'
            END

        ELSE 'undecided'
    END AS retention_status

FROM mqs
LEFT JOIN athn_status s
    ON mqs.mqsQuoteId = s.mqsQuoteId
LEFT JOIN athn_dedup a
    ON mqs.externalID = a.interactionId
   AND mqs.transactionType = a.process_code
   AND mqs.mqsQuoteId = a.mqsQuoteId
;
