WITH csv_daily AS (
  SELECT
    a.requestDate AS reportDate,

    COUNT(*) AS total_csv_records,
    COUNT_IF(a.mqsQuoteId IS NULL) AS csv_quote_null,

    COUNT_IF(
      b.existsInCSV = true AND b.existsInMQS = true AND b.existsInAthena = true AND b.allMatching = true
    ) AS matched_in_window,

    COUNT_IF(
      b.existsInCSV = true AND b.existsInMQS = true AND b.existsInAthena = true AND b.allMatching = false
    ) AS matched_backdated,

    (
      COUNT_IF(b.existsInCSV = true AND b.existsInMQS = true AND b.existsInAthena = true AND b.allMatching = true)
      +
      COUNT_IF(b.existsInCSV = true AND b.existsInMQS = true AND b.existsInAthena = true AND b.allMatching = false)
    ) AS matched_over_all,

    COUNT_IF(b.existsInCSV = true AND b.existsInMQS = true  AND b.existsInAthena = false) AS mqs_only,
    COUNT_IF(b.existsInCSV = true AND b.existsInMQS = false AND b.existsInAthena = true ) AS athena_only,
    COUNT_IF(b.existsInCSV = true AND b.existsInMQS = false AND b.existsInAthena = false) AS missing,

    COUNT_IF(a.mqsQuoteId IS NULL AND b.existsInAthena = true ) AS csv_quote_null_athena_hit,
    COUNT_IF(a.mqsQuoteId IS NULL AND b.existsInAthena = false) AS csv_quote_null_athena_miss,

    /* keep your reverse_recon_* placeholders here (filled by join) */
    CAST(0 AS BIGINT) AS reverse_recon_mqs,
    CAST(0 AS BIGINT) AS reverse_recon_athena

  FROM core_bld.radar_live.reconciliation_csv_source a
  LEFT JOIN core_bld.radar_live.reconciliation_history b
    ON  a.interactionId     = b.interactionId
    AND a.mqsQuoteId        = b.MQSQuoteId
    AND a.requestTimestamp  = b.requestTimestamp
  GROUP BY a.requestDate
),

reverse_daily AS (
  SELECT
    COALESCE(DATE(MQSTimestamp), DATE(athenaTimestamp)) AS reportDate,

    COUNT_IF(existsInCSV = false AND existsInMQS = true)    AS reverse_recon_mqs,
    COUNT_IF(existsInCSV = false AND existsInAthena = true) AS reverse_recon_athena

  FROM core_bld.radar_live.reconciliation_history
  WHERE existsInCSV = false
  GROUP BY COALESCE(DATE(MQSTimestamp), DATE(athenaTimestamp))
)

SELECT
  COALESCE(c.reportDate, r.reportDate) AS reportDate,

  /* CSV metrics (null-safe if a day only exists in reverse) */
  COALESCE(c.total_csv_records, 0) AS total_csv_records,
  COALESCE(c.csv_quote_null, 0) AS csv_quote_null,
  COALESCE(c.matched_in_window, 0) AS matched_in_window,
  COALESCE(c.matched_backdated, 0) AS matched_backdated,
  COALESCE(c.matched_over_all, 0) AS matched_over_all,
  COALESCE(c.mqs_only, 0) AS mqs_only,
  COALESCE(c.athena_only, 0) AS athena_only,
  COALESCE(c.missing, 0) AS missing,
  COALESCE(c.csv_quote_null_athena_hit, 0) AS csv_quote_null_athena_hit,
  COALESCE(c.csv_quote_null_athena_miss, 0) AS csv_quote_null_athena_miss,

  /* Reverse metrics grouped by timestamps */
  COALESCE(r.reverse_recon_mqs, 0) AS reverse_recon_mqs,
  COALESCE(r.reverse_recon_athena, 0) AS reverse_recon_athena

FROM csv_daily c
FULL OUTER JOIN reverse_daily r
  ON c.reportDate = r.reportDate
ORDER BY reportDate;
