import json
import requests

WEBHOOK_URL = "YOUR_TEAMS_WEBHOOK_URL"
DASHBOARD_URL = "https://YOUR-DATABRICKS-WORKSPACE/sql/dashboards/YOUR_DASHBOARD_ID"

query = """
WITH bounds AS (
    SELECT date_trunc('day', current_timestamp()) AS day_start
),
latest_mqs_interval AS (
    SELECT MAX(interval_end) AS max_interval
    FROM core_bld.default.monitoring_ehub_30min_metrics
    WHERE interval_end >= (SELECT day_start FROM bounds)
      AND message_type <> 'ALL'
),
interaction_intervals AS (
    SELECT DISTINCT interval_start
    FROM core_bld.default.monitoring_mqs_interaction_status
    WHERE interval_start >= (SELECT day_start FROM bounds)
),
latest_minus_1_interaction AS (
    SELECT interval_start AS interaction_interval
    FROM (
        SELECT
            interval_start,
            ROW_NUMBER() OVER (ORDER BY interval_start DESC) AS rn
        FROM interaction_intervals
    ) x
    WHERE rn = 2
),
ehub_latest AS (
    SELECT
        run_date,
        interval_end,
        message_type AS message_type_link,
        message_count AS ehub_count,
        is_sla_breach AS ehub_sla
    FROM core_bld.default.monitoring_ehub_30min_metrics
    WHERE message_type <> 'ALL'
      AND interval_end = (SELECT max_interval FROM latest_mqs_interval)
),
bronze_latest AS (
    SELECT
        CASE
            WHEN message_type = 'dlt_quote_request' THEN 'mqs-quote-request'
            WHEN message_type = 'dlt_precomp_response' THEN 'precomp-response'
            WHEN message_type = 'dlt_rating_request' THEN 'rating-request'
            WHEN message_type = 'dlt_rating_response' THEN 'rating-response'
            WHEN message_type = 'dlt_cache_id' THEN 'quote-cache-id'
            WHEN message_type = 'dlt_stop_quote' THEN 'stop-quote'
            WHEN message_type = 'dlt_rating_request_dvla_removed' THEN 'dlt_rating_request_dvla_removed'
            WHEN message_type = 'dlt_raw_enrichments' THEN 'dlt_raw_enrichments'
            ELSE 'others'
        END AS message_type_link,
        interval_end,
        message_count,
        is_sla_flag
    FROM core_bld.default.monitoring_mqs_bronze_30min
    WHERE message_type <> 'ALL'
      AND interval_end = (SELECT max_interval FROM latest_mqs_interval)
),
interaction_latest_minus_1 AS (
    SELECT
        interval_start,
        SUM(total_count) AS total_interaction_count
    FROM core_bld.default.monitoring_mqs_interaction_status
    WHERE interval_start = (SELECT interaction_interval FROM latest_minus_1_interaction)
    GROUP BY interval_start
)
SELECT
    e.run_date,
    e.interval_end,
    e.message_type_link,
    e.ehub_count,
    e.ehub_sla,
    COALESCE(b.message_count, 0) AS bronze_count,
    COALESCE(b.is_sla_flag, 0) AS bronze_sla,
    e.ehub_count - COALESCE(b.message_count, 0) AS count_difference,
    CASE
        WHEN e.ehub_sla = 1 AND COALESCE(b.is_sla_flag, 0) = 1 THEN 'EHUB & BRONZE'
        WHEN e.ehub_sla = 1 THEN 'EHUB'
        WHEN COALESCE(b.is_sla_flag, 0) = 1 THEN 'BRONZE'
        WHEN COALESCE(i.total_interaction_count, 0) = 0 THEN 'INTERACTION'
    END AS breach_source
FROM ehub_latest e
LEFT JOIN bronze_latest b
    ON e.message_type_link = b.message_type_link
   AND e.interval_end = b.interval_end
LEFT JOIN interaction_latest_minus_1 i
    ON 1 = 1
WHERE
       e.ehub_sla = 1
    OR COALESCE(b.is_sla_flag, 0) = 1
    OR COALESCE(i.total_interaction_count, 0) = 0
"""

df = spark.sql(query)
rows = [r.asDict() for r in df.collect()]

def build_metric_factset(row):
    return {
        "type": "FactSet",
        "facts": [
            {"title": "Interval", "value": str(row["interval_end"])},
            {"title": "EHUB Count", "value": str(row["ehub_count"])},
            {"title": "Bronze Count", "value": str(row["bronze_count"])},
            {"title": "Difference", "value": str(row["count_difference"])},
            {"title": "Source", "value": str(row["breach_source"])}
        ]
    }

def build_breach_container(row):
    return {
        "type": "Container",
        "style": "attention",
        "bleed": True,
        "separator": True,
        "items": [
            {
                "type": "TextBlock",
                "text": f"⚠ {row['message_type_link']}",
                "weight": "Bolder",
                "size": "Medium",
                "wrap": True
            },
            build_metric_factset(row)
        ]
    }

def build_healthy_container(run_ts):
    return {
        "type": "Container",
        "style": "good",
        "bleed": True,
        "items": [
            {
                "type": "TextBlock",
                "text": "✅ System Healthy",
                "weight": "Bolder",
                "size": "Large",
                "wrap": True
            },
            {
                "type": "TextBlock",
                "text": "All monitored streams are within SLA for the latest run.",
                "wrap": True,
                "spacing": "Small"
            },
            {
                "type": "FactSet",
                "facts": [
                    {"title": "Checked At", "value": str(run_ts)},
                    {"title": "Status", "value": "Operational"}
                ]
            }
        ]
    }

def build_header(title_icon, title_text, subtitle, color):
    return [
        {
            "type": "Container",
            "items": [
                {
                    "type": "TextBlock",
                    "text": f"{title_icon} RADAR LIVE Monitoring",
                    "weight": "Bolder",
                    "size": "Large",
                    "wrap": True
                },
                {
                    "type": "TextBlock",
                    "text": title_text,
                    "weight": "Bolder",
                    "size": "ExtraLarge",
                    "color": color,
                    "wrap": True,
                    "spacing": "Small"
                },
                {
                    "type": "TextBlock",
                    "text": subtitle,
                    "wrap": True,
                    "spacing": "Small",
                    "isSubtle": True
                }
            ]
        }
    ]

def build_card(rows):
    run_ts = spark.sql("select current_timestamp() as ts").collect()[0]["ts"]

    if rows:
        total_breaches = len(rows)
        latest_interval = rows[0]["interval_end"]

        body = []
        body.extend(build_header(
            "⚠",
            "SLA Breach Detected",
            "Immediate attention required. Please review the impacted streams below.",
            "Attention"
        ))

        body.append(
            {
                "type": "Container",
                "style": "emphasis",
                "items": [
                    {
                        "type": "FactSet",
                        "facts": [
                            {"title": "Environment", "value": "RADAR LIVE"},
                            {"title": "Status", "value": "Breach"},
                            {"title": "Latest Interval", "value": str(latest_interval)},
                            {"title": "Impacted Types", "value": str(total_breaches)}
                        ]
                    }
                ]
            }
        )

        for row in rows[:5]:
            body.append(build_breach_container(row))

        if total_breaches > 5:
            body.append(
                {
                    "type": "TextBlock",
                    "text": f"⚙ Additional impacted message types not shown: {total_breaches - 5}",
                    "wrap": True,
                    "spacing": "Medium"
                }
            )

        body.append(
            {
                "type": "TextBlock",
                "text": "🛠 Recommended action: Review dashboard, validate pipeline health, and investigate upstream/downstream flow delays.",
                "wrap": True,
                "spacing": "Medium"
            }
        )

    else:
        body = []
        body.extend(build_header(
            "✅",
            "All Systems Operational",
            "No SLA breaches detected for the latest monitoring cycle.",
            "Good"
        ))
        body.append(build_healthy_container(run_ts))

    return {
        "type": "message",
        "attachments": [
            {
                "contentType": "application/vnd.microsoft.card.adaptive",
                "content": {
                    "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
                    "type": "AdaptiveCard",
                    "version": "1.4",
                    "body": body,
                    "actions": [
                        {
                            "type": "Action.OpenURL",
                            "title": "Open Monitoring Dashboard",
                            "url": DASHBOARD_URL
                        }
                    ]
                }
            }
        ]
    }

payload = build_card(rows)

response = requests.post(
    WEBHOOK_URL,
    headers={"Content-Type": "application/json"},
    data=json.dumps(payload),
    timeout=30
)

print("HTTP status:", response.status_code)
print("Response text:", response.text)
response.raise_for_status()
