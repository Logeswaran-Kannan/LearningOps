%sql
WITH hist_base AS (
    SELECT
        interactionId,
        MQSQuoteId,
        requestTimestamp,
        athenaTimestamp,
        MQSTimestamp,
        DATE(requestTimestamp) AS requestDate,
        DATE(athenaTimestamp) AS athenaDate,
        DATE(MQSTimestamp) AS mqsDate,
        LPAD(CAST(requestProcess AS STRING), 2, '0') AS requestProcess,
        LPAD(CAST(athenaProcess AS STRING), 2, '0') AS athenaProcess,
        LPAD(CAST(MQSProcess AS STRING), 2, '0') AS MQSProcess,
        existsInCSV,
        existsInAthena,
        existsInMQS,
        allMatching,
        loadDate,
        updatedDate
    FROM core_bld.radar_live.reconciliation_history
    WHERE interactionId = 'PUT_SAMPLE_INTERACTION_ID_HERE'
)
SELECT *,
    CASE
        WHEN existsInCSV = true
         AND existsInMQS = true
         AND existsInAthena = true
         AND requestProcess = MQSProcess
         AND requestProcess = athenaProcess
         AND athenaDate = requestDate
        THEN 'matched_in_window'

        WHEN existsInCSV = true
         AND existsInMQS = true
         AND existsInAthena = true
         AND requestProcess = MQSProcess
         AND requestProcess = athenaProcess
         AND athenaDate > requestDate
        THEN 'matched_backdated'

        WHEN existsInCSV = true
         AND existsInMQS = true
         AND existsInAthena = true
         AND (
                requestProcess <> MQSProcess
             OR requestProcess <> athenaProcess
             OR MQSProcess <> athenaProcess
         )
        THEN 'different_process'

        ELSE 'other'
    END AS recon_status
FROM hist_base
ORDER BY requestTimestamp, athenaTimestamp, MQSTimestamp;
