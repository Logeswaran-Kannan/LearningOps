import json
import requests

WEBHOOK_URL = "YOUR_TEAMS_WEBHOOK_URL"

query = """
WITH bounds AS (
    SELECT date_trunc('day', current_timestamp()) AS day_start
),
latest_mqs_interval AS (
    SELECT MAX(interval_end) AS max_interval
    FROM core_bld.default.monitoring_ehub_30min_metrics
    WHERE interval_end >= (SELECT day_start FROM bounds)
      AND message_type <> 'ALL'
),
interaction_intervals AS (
    SELECT DISTINCT interval_start
    FROM core_bld.default.monitoring_mqs_interaction_status
    WHERE interval_start >= (SELECT day_start FROM bounds)
),
latest_minus_1_interaction AS (
    SELECT interval_start AS interaction_interval
    FROM (
        SELECT
            interval_start,
            ROW_NUMBER() OVER (ORDER BY interval_start DESC) AS rn
        FROM interaction_intervals
    ) x
    WHERE rn = 2
),
ehub_latest AS (
    SELECT
        run_date,
        interval_end,
        message_type AS message_type_link,
        message_count AS ehub_count,
        is_sla_breach AS ehub_sla
    FROM core_bld.default.monitoring_ehub_30min_metrics
    WHERE message_type <> 'ALL'
      AND interval_end = (SELECT max_interval FROM latest_mqs_interval)
),
bronze_latest AS (
    SELECT
        CASE
            WHEN message_type = 'dlt_quote_request' THEN 'mqs-quote-request'
            WHEN message_type = 'dlt_precomp_response' THEN 'precomp-response'
            WHEN message_type = 'dlt_rating_request' THEN 'rating-request'
            WHEN message_type = 'dlt_rating_response' THEN 'rating-response'
            WHEN message_type = 'dlt_cache_id' THEN 'quote-cache-id'
            WHEN message_type = 'dlt_stop_quote' THEN 'stop-quote'
            WHEN message_type = 'dlt_rating_request_dvla_removed' THEN 'dlt_rating_request_dvla_removed'
            WHEN message_type = 'dlt_raw_enrichments' THEN 'dlt_raw_enrichments'
            ELSE 'others'
        END AS message_type_link,
        interval_end,
        message_count,
        is_sla_flag
    FROM core_bld.default.monitoring_mqs_bronze_30min
    WHERE message_type <> 'ALL'
      AND interval_end = (SELECT max_interval FROM latest_mqs_interval)
),
interaction_latest_minus_1 AS (
    SELECT
        interval_start,
        SUM(total_count) AS total_interaction_count
    FROM core_bld.default.monitoring_mqs_interaction_status
    WHERE interval_start = (SELECT interaction_interval FROM latest_minus_1_interaction)
    GROUP BY interval_start
)
SELECT
    e.run_date,
    e.interval_end,
    e.message_type_link,
    e.ehub_count,
    e.ehub_sla,
    COALESCE(b.message_count, 0) AS bronze_count,
    COALESCE(b.is_sla_flag, 0) AS bronze_sla,
    e.ehub_count - COALESCE(b.message_count, 0) AS count_difference,
    CASE
        WHEN e.ehub_sla = 1 AND COALESCE(b.is_sla_flag, 0) = 1 THEN 'EHUB & BRONZE'
        WHEN e.ehub_sla = 1 THEN 'EHUB'
        WHEN COALESCE(b.is_sla_flag, 0) = 1 THEN 'BRONZE'
        WHEN COALESCE(i.total_interaction_count, 0) = 0 THEN 'INTERACTION'
    END AS breach_source
FROM ehub_latest e
LEFT JOIN bronze_latest b
    ON e.message_type_link = b.message_type_link
   AND e.interval_end = b.interval_end
LEFT JOIN interaction_latest_minus_1 i
    ON 1 = 1
WHERE
       e.ehub_sla = 1
    OR COALESCE(b.is_sla_flag, 0) = 1
    OR COALESCE(i.total_interaction_count, 0) = 0
"""

df = spark.sql(query)
rows = [r.asDict() for r in df.collect()]

workspace_url = "https://<your-databricks-workspace-url>"
dashboard_url = "https://<your-dashboard-url>"

def metric_fact(title, value):
    return {"title": title, "value": str(value)}

def build_breach_container(r):
    return {
        "type": "Container",
        "style": "emphasis",
        "bleed": False,
        "spacing": "Medium",
        "items": [
            {
                "type": "TextBlock",
                "text": f"{r['message_type_link']}",
                "weight": "Bolder",
                "size": "Medium",
                "wrap": True
            },
            {
                "type": "TextBlock",
                "text": f"Breach Source: {r['breach_source']}",
                "color": "Attention",
                "weight": "Bolder",
                "wrap": True,
                "spacing": "Small"
            },
            {
                "type": "FactSet",
                "facts": [
                    metric_fact("Interval", r["interval_end"]),
                    metric_fact("EHUB Count", r["ehub_count"]),
                    metric_fact("EHUB SLA", r["ehub_sla"]),
                    metric_fact("Bronze Count", r["bronze_count"]),
                    metric_fact("Bronze SLA", r["bronze_sla"]),
                    metric_fact("Difference", r["count_difference"])
                ]
            }
        ]
    }

def build_card(rows):
    breach_count = len(rows)
    latest_interval = str(rows[0]["interval_end"]) if rows else "Latest run"
    has_breach = breach_count > 0

    status_text = "SLA BREACH DETECTED" if has_breach else "SYSTEM HEALTHY"
    status_color = "Attention" if has_breach else "Good"
    status_style = "attention" if has_breach else "good"
    intro_text = (
        "Immediate attention required. One or more monitored message types breached SLA in the latest run."
        if has_breach else
        "All monitored pipelines are operating within expected SLA for the latest run."
    )

    body = [
        {
            "type": "Container",
            "style": "default",
            "items": [
                {
                    "type": "TextBlock",
                    "text": "RADAR LIVE",
                    "weight": "Bolder",
                    "size": "ExtraLarge",
                    "wrap": True
                },
                {
                    "type": "TextBlock",
                    "text": "Automated SLA Monitoring Notification",
                    "spacing": "None",
                    "isSubtle": True,
                    "wrap": True
                }
            ]
        },
        {
            "type": "Container",
            "style": status_style,
            "bleed": True,
            "items": [
                {
                    "type": "TextBlock",
                    "text": status_text,
                    "weight": "Bolder",
                    "size": "Large",
                    "color": "Light",
                    "wrap": True
                },
                {
                    "type": "TextBlock",
                    "text": intro_text,
                    "color": "Light",
                    "wrap": True,
                    "spacing": "Small"
                }
            ]
        },
        {
            "type": "Container",
            "spacing": "Medium",
            "items": [
                {
                    "type": "TextBlock",
                    "text": "Run Summary",
                    "weight": "Bolder",
                    "size": "Medium"
                },
                {
                    "type": "FactSet",
                    "facts": [
                        metric_fact("Environment", "RADAR LIVE"),
                        metric_fact("Latest Interval", latest_interval),
                        metric_fact("Breaches", breach_count),
                        metric_fact("Status", status_text)
                    ]
                }
            ]
        }
    ]

    if has_breach:
        body.append({
            "type": "TextBlock",
            "text": "Impacted Message Types",
            "weight": "Bolder",
            "size": "Medium",
            "spacing": "Medium"
        })

        for r in rows[:5]:
            body.append(build_breach_container(r))

        if breach_count > 5:
            body.append({
                "type": "TextBlock",
                "text": f"...and {breach_count - 5} more impacted message type(s).",
                "isSubtle": True,
                "wrap": True,
                "spacing": "Medium"
            })

    else:
        body.append({
            "type": "Container",
            "style": "good",
            "items": [
                {
                    "type": "TextBlock",
                    "text": "No action required.",
                    "weight": "Bolder",
                    "color": "Good",
                    "wrap": True
                },
                {
                    "type": "TextBlock",
                    "text": "Monitoring completed successfully with no SLA breach identified.",
                    "wrap": True
                }
            ]
        })

    body.append({
        "type": "TextBlock",
        "text": "Generated automatically by Databricks scheduled monitoring.",
        "isSubtle": True,
        "spacing": "Medium",
        "wrap": True
    })

    return {
        "type": "message",
        "attachments": [
            {
                "contentType": "application/vnd.microsoft.card.adaptive",
                "content": {
                    "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
                    "type": "AdaptiveCard",
                    "version": "1.4",
                    "body": body,
                    "actions": [
                        {
                            "type": "Action.OpenURL",
                            "title": "Open Databricks Workspace",
                            "url": workspace_url
                        },
                        {
                            "type": "Action.OpenURL",
                            "title": "Open Monitoring Dashboard",
                            "url": dashboard_url
                        }
                    ]
                }
            }
        ]
    }

payload = build_card(rows)

response = requests.post(
    WEBHOOK_URL,
    headers={"Content-Type": "application/json"},
    data=json.dumps(payload),
    timeout=30
)

print("HTTP status:", response.status_code)
print("Response text:", response.text)
response.raise_for_status()
