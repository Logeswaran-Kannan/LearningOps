%sql

WITH csv_base AS (
    SELECT
        interactionId,
        mqsQuoteId,
        requestDate,
        requestTimestamp,
        LPAD(CAST(transactionCode AS STRING), 2, '0') AS csv_process
    FROM core_bld.radar_live.reconciliation_csv_source
),
hist_base AS (
    SELECT
        interactionId,
        MQSQuoteId,
        COALESCE(
            LPAD(CAST(requestProcess AS STRING), 2, '0'),
            LPAD(CAST(MQSProcess AS STRING), 2, '0'),
            LPAD(CAST(athenaProcess AS STRING), 2, '0')
        ) AS process_key,
        MQSTimestamp,
        athenaTimestamp,
        existsInMQS,
        existsInAthena
    FROM core_bld.radar_live.reconciliation_history
    WHERE MQSQuoteId IS NOT NULL
),
hist_consolidated AS (
    SELECT
        interactionId,
        MQSQuoteId,
        process_key,
        MAX(CASE WHEN COALESCE(existsInMQS, false) = true THEN 1 ELSE 0 END) AS mqs_exists,
        MAX(CASE WHEN COALESCE(existsInAthena, false) = true THEN 1 ELSE 0 END) AS athena_exists,
        MAX(MQSTimestamp) AS mqs_ts,
        MAX(athenaTimestamp) AS athena_ts
    FROM hist_base
    GROUP BY interactionId, MQSQuoteId, process_key
),
joined AS (
    SELECT
        c.requestDate,
        c.interactionId,
        c.mqsQuoteId,
        c.csv_process,
        c.requestTimestamp AS csv_ts,
        h.process_key,
        h.mqs_exists,
        h.athena_exists,
        h.mqs_ts,
        h.athena_ts,
        GREATEST(h.mqs_ts, h.athena_ts) AS completion_ts,
        ROUND(
            (UNIX_TIMESTAMP(GREATEST(h.mqs_ts, h.athena_ts)) - UNIX_TIMESTAMP(c.requestTimestamp)) / 3600.0,
            2
        ) AS delay_hours,
        CASE WHEN c.csv_process = h.process_key THEN 1 ELSE 0 END AS same_process_match
    FROM csv_base c
    LEFT JOIN hist_consolidated h
      ON c.interactionId = h.interactionId
     AND c.mqsQuoteId = h.MQSQuoteId
     AND c.csv_process = h.process_key
    WHERE c.mqsQuoteId IS NOT NULL
      AND c.requestDate = DATE('2026-02-09')
)
SELECT
    *,
    CASE
        WHEN COALESCE(mqs_exists, 0) = 1
         AND COALESCE(athena_exists, 0) = 1
         AND same_process_match = 1
         AND completion_ts IS NOT NULL
         AND UNIX_TIMESTAMP(completion_ts) - UNIX_TIMESTAMP(csv_ts) >= 0
         AND UNIX_TIMESTAMP(completion_ts) - UNIX_TIMESTAMP(csv_ts) <= 86400
        THEN 'matched_in_24h'

        WHEN COALESCE(mqs_exists, 0) = 1
         AND COALESCE(athena_exists, 0) = 1
         AND same_process_match = 1
         AND completion_ts IS NOT NULL
         AND UNIX_TIMESTAMP(completion_ts) - UNIX_TIMESTAMP(csv_ts) > 86400
        THEN 'matched_outside_24h'

        WHEN COALESCE(mqs_exists, 0) = 1
         AND COALESCE(athena_exists, 0) = 0
        THEN 'present_mqs_only'

        WHEN COALESCE(mqs_exists, 0) = 0
         AND COALESCE(athena_exists, 0) = 1
        THEN 'present_athena_only'

        WHEN COALESCE(mqs_exists, 0) = 0
         AND COALESCE(athena_exists, 0) = 0
        THEN 'missing_in_both'

        ELSE 'other'
    END AS debug_status
FROM joined
ORDER BY csv_ts, interactionId, mqsQuoteId;
