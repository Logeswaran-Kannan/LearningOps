%sql

WITH csv_base AS (
    SELECT
        interactionId,
        mqsQuoteId,
        requestDate,
        requestTimestamp,
        LPAD(CAST(transactionCode AS STRING), 2, '0') AS csv_process
    FROM core_bld.radar_live.reconciliation_csv_source
),

hist_base AS (
    SELECT
        interactionId,
        MQSQuoteId,
        LPAD(CAST(requestProcess AS STRING), 2, '0') AS requestProcess,
        LPAD(CAST(MQSProcess AS STRING), 2, '0') AS MQSProcess,
        LPAD(CAST(athenaProcess AS STRING), 2, '0') AS athenaProcess,
        requestTimestamp,
        MQSTimestamp,
        athenaTimestamp,
        existsInCSV,
        existsInMQS,
        existsInAthena
    FROM core_bld.radar_live.reconciliation_history
),

/* =====================================================
   1. NON-POLARIS HISTORY NORMALIZATION
   Build one process key so split MQS/Athena rows can merge
   ===================================================== */
hist_non_polaris_normalized AS (
    SELECT
        interactionId,
        MQSQuoteId,
        COALESCE(requestProcess, MQSProcess, athenaProcess) AS process_key,
        requestTimestamp,
        MQSTimestamp,
        athenaTimestamp,
        existsInCSV,
        existsInMQS,
        existsInAthena
    FROM hist_base
    WHERE MQSQuoteId IS NOT NULL
),

/* =====================================================
   2. NON-POLARIS HISTORY CONSOLIDATION
   Merge separate MQS row and Athena row into one event
   ===================================================== */
hist_non_polaris_consolidated AS (
    SELECT
        interactionId,
        MQSQuoteId,
        process_key,

        MAX(CASE WHEN COALESCE(existsInMQS, false) = true THEN 1 ELSE 0 END) AS mqs_exists,
        MAX(CASE WHEN COALESCE(existsInAthena, false) = true THEN 1 ELSE 0 END) AS athena_exists,
        MAX(CASE WHEN COALESCE(existsInCSV, false) = true THEN 1 ELSE 0 END) AS csv_exists_hist,

        MAX(MQSTimestamp) AS mqs_ts,
        MAX(athenaTimestamp) AS athena_ts,
        MAX(requestTimestamp) AS hist_request_ts
    FROM hist_non_polaris_normalized
    GROUP BY
        interactionId,
        MQSQuoteId,
        process_key
),

/* =====================================================
   3. NON-POLARIS CSV RECONCILIATION
   ===================================================== */
csv_non_polaris_joined AS (
    SELECT
        c.requestDate AS reportDate,
        c.interactionId,
        c.mqsQuoteId,
        c.csv_process,
        c.requestTimestamp AS csv_ts,

        h.process_key,
        h.mqs_exists,
        h.athena_exists,
        h.csv_exists_hist,
        h.mqs_ts,
        h.athena_ts,
        h.hist_request_ts,

        GREATEST(h.mqs_ts, h.athena_ts) AS completion_ts,

        CASE
            WHEN h.process_key = c.csv_process THEN 1
            ELSE 0
        END AS same_process_match
    FROM csv_base c
    LEFT JOIN hist_non_polaris_consolidated h
      ON c.interactionId = h.interactionId
     AND c.mqsQuoteId = h.MQSQuoteId
     AND c.csv_process = h.process_key
    WHERE c.mqsQuoteId IS NOT NULL
),

non_polaris_daily AS (
    SELECT
        reportDate,
        COUNT(*) AS total_non_polaris,

        COUNT_IF(
            COALESCE(mqs_exists, 0) = 1
            AND COALESCE(athena_exists, 0) = 1
            AND same_process_match = 1
            AND completion_ts IS NOT NULL
            AND UNIX_TIMESTAMP(completion_ts) - UNIX_TIMESTAMP(csv_ts) >= 0
            AND UNIX_TIMESTAMP(completion_ts) - UNIX_TIMESTAMP(csv_ts) <= 86400
        ) AS matched_in_24h,

        COUNT_IF(
            COALESCE(mqs_exists, 0) = 1
            AND COALESCE(athena_exists, 0) = 1
            AND same_process_match = 1
            AND completion_ts IS NOT NULL
            AND UNIX_TIMESTAMP(completion_ts) - UNIX_TIMESTAMP(csv_ts) > 86400
        ) AS matched_outside_24h,

        COUNT_IF(
            COALESCE(mqs_exists, 0) = 0
            AND COALESCE(athena_exists, 0) = 0
        ) AS missing_in_both,

        COUNT_IF(
            COALESCE(mqs_exists, 0) = 1
            AND COALESCE(athena_exists, 0) = 0
        ) AS present_mqs_only,

        COUNT_IF(
            COALESCE(mqs_exists, 0) = 0
            AND COALESCE(athena_exists, 0) = 1
        ) AS present_athena_only,

        COUNT_IF(
            COALESCE(mqs_exists, 0) = 1
            AND COALESCE(athena_exists, 0) = 1
            AND same_process_match = 0
        ) AS different_process

    FROM csv_non_polaris_joined
    GROUP BY reportDate
),

/* =====================================================
   4. POLARIS HISTORY NORMALIZATION
   Polaris = CSV quote null, expected only in Athena
   Match by interactionId + process
   ===================================================== */
hist_polaris_normalized AS (
    SELECT
        interactionId,
        COALESCE(athenaProcess, requestProcess) AS process_key,
        athenaTimestamp,
        existsInAthena
    FROM hist_base
    WHERE MQSQuoteId IS NULL
),

hist_polaris_consolidated AS (
    SELECT
        interactionId,
        process_key,
        MAX(CASE WHEN COALESCE(existsInAthena, false) = true THEN 1 ELSE 0 END) AS athena_exists,
        MAX(athenaTimestamp) AS athena_ts
    FROM hist_polaris_normalized
    GROUP BY interactionId, process_key
),

csv_polaris_joined AS (
    SELECT
        c.requestDate,
        c.interactionId,
        c.csv_process,
        h.athena_exists,
        h.athena_ts
    FROM csv_base c
    LEFT JOIN hist_polaris_consolidated h
      ON c.interactionId = h.interactionId
     AND c.csv_process = h.process_key
    WHERE c.mqsQuoteId IS NULL
),

polaris_daily AS (
    SELECT
        CASE
            WHEN COALESCE(athena_exists, 0) = 1 THEN DATE(athena_ts)
            ELSE requestDate
        END AS reportDate,

        COUNT_IF(COALESCE(athena_exists, 0) = 1) AS polaris_matched,
        COUNT_IF(COALESCE(athena_exists, 0) = 0) AS polaris_missing
    FROM csv_polaris_joined
    GROUP BY
        CASE
            WHEN COALESCE(athena_exists, 0) = 1 THEN DATE(athena_ts)
            ELSE requestDate
        END
),

/* =====================================================
   5. REVERSE RECONCILIATION
   Non-polaris only
   Present in MQS and/or Athena but missing in CSV
   Report date from system where present
   ===================================================== */
reverse_daily AS (
    SELECT
        CASE
            WHEN COALESCE(mqs_exists, 0) = 1 THEN DATE(mqs_ts)
            WHEN COALESCE(athena_exists, 0) = 1 THEN DATE(athena_ts)
        END AS reportDate,

        COUNT_IF(
            COALESCE(csv_exists_hist, 0) = 0
            AND COALESCE(mqs_exists, 0) = 1
            AND COALESCE(athena_exists, 0) = 1
        ) AS reverse_both_missing_csv,

        COUNT_IF(
            COALESCE(csv_exists_hist, 0) = 0
            AND COALESCE(mqs_exists, 0) = 1
            AND COALESCE(athena_exists, 0) = 0
        ) AS reverse_mqs_only,

        COUNT_IF(
            COALESCE(csv_exists_hist, 0) = 0
            AND COALESCE(mqs_exists, 0) = 0
            AND COALESCE(athena_exists, 0) = 1
        ) AS reverse_athena_only

    FROM hist_non_polaris_consolidated
    WHERE COALESCE(csv_exists_hist, 0) = 0
      AND (
            COALESCE(mqs_exists, 0) = 1
         OR COALESCE(athena_exists, 0) = 1
      )
    GROUP BY
        CASE
            WHEN COALESCE(mqs_exists, 0) = 1 THEN DATE(mqs_ts)
            WHEN COALESCE(athena_exists, 0) = 1 THEN DATE(athena_ts)
        END
),

/* =====================================================
   6. ALL REPORT DATES
   ===================================================== */
all_dates AS (
    SELECT reportDate FROM non_polaris_daily
    UNION
    SELECT reportDate FROM polaris_daily
    UNION
    SELECT reportDate FROM reverse_daily
)

/* =====================================================
   7. FINAL DASHBOARD OUTPUT
   ===================================================== */
SELECT
    d.reportDate,

    COALESCE(n.total_non_polaris, 0) AS total_non_polaris,
    COALESCE(n.matched_in_24h, 0) AS matched_in_24h,
    COALESCE(n.matched_outside_24h, 0) AS matched_outside_24h,
    COALESCE(n.missing_in_both, 0) AS missing_in_both,
    COALESCE(n.present_mqs_only, 0) AS present_mqs_only,
    COALESCE(n.present_athena_only, 0) AS present_athena_only,
    COALESCE(n.different_process, 0) AS different_process,

    COALESCE(p.polaris_matched, 0) AS polaris_matched,
    COALESCE(p.polaris_missing, 0) AS polaris_missing,

    COALESCE(r.reverse_both_missing_csv, 0) AS reverse_both_missing_csv,
    COALESCE(r.reverse_mqs_only, 0) AS reverse_mqs_only,
    COALESCE(r.reverse_athena_only, 0) AS reverse_athena_only

FROM all_dates d
LEFT JOIN non_polaris_daily n
    ON d.reportDate = n.reportDate
LEFT JOIN polaris_daily p
    ON d.reportDate = p.reportDate
LEFT JOIN reverse_daily r
    ON d.reportDate = r.reportDate
ORDER BY d.reportDate;
