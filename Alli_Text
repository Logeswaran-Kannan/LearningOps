import json
import requests

WEBHOOK_URL = "YOUR_TEAMS_WEBHOOK_URL"
DASHBOARD_URL = "YOUR_DATABRICKS_DASHBOARD_URL"

query = """
WITH bounds AS (
    SELECT date_trunc('day', current_timestamp()) AS day_start
),
latest_mqs_interval AS (
    SELECT MAX(interval_end) AS max_interval
    FROM core_bld.default.monitoring_ehub_30min_metrics
    WHERE interval_end >= (SELECT day_start FROM bounds)
      AND message_type <> 'ALL'
),
interaction_intervals AS (
    SELECT DISTINCT interval_start
    FROM core_bld.default.monitoring_mqs_interaction_status
    WHERE interval_start >= (SELECT day_start FROM bounds)
),
latest_minus_1_interaction AS (
    SELECT interval_start AS interaction_interval
    FROM (
        SELECT
            interval_start,
            ROW_NUMBER() OVER (ORDER BY interval_start DESC) AS rn
        FROM interaction_intervals
    ) x
    WHERE rn = 2
),
ehub_latest AS (
    SELECT
        run_date,
        interval_end,
        message_type AS message_type_link,
        message_count AS ehub_count,
        is_sla_breach AS ehub_sla
    FROM core_bld.default.monitoring_ehub_30min_metrics
    WHERE message_type <> 'ALL'
      AND interval_end = (SELECT max_interval FROM latest_mqs_interval)
),
bronze_latest AS (
    SELECT
        CASE
            WHEN message_type = 'dlt_quote_request' THEN 'mqs-quote-request'
            WHEN message_type = 'dlt_precomp_response' THEN 'precomp-response'
            WHEN message_type = 'dlt_rating_request' THEN 'rating-request'
            WHEN message_type = 'dlt_rating_response' THEN 'rating-response'
            WHEN message_type = 'dlt_cache_id' THEN 'quote-cache-id'
            WHEN message_type = 'dlt_stop_quote' THEN 'stop-quote'
            WHEN message_type = 'dlt_rating_request_dvla_removed' THEN 'dlt_rating_request_dvla_removed'
            WHEN message_type = 'dlt_raw_enrichments' THEN 'dlt_raw_enrichments'
            ELSE 'others'
        END AS message_type_link,
        interval_end,
        message_count,
        is_sla_flag
    FROM core_bld.default.monitoring_mqs_bronze_30min
    WHERE message_type <> 'ALL'
      AND interval_end = (SELECT max_interval FROM latest_mqs_interval)
),
interaction_latest_minus_1 AS (
    SELECT
        interval_start,
        SUM(total_count) AS total_interaction_count
    FROM core_bld.default.monitoring_mqs_interaction_status
    WHERE interval_start = (SELECT interaction_interval FROM latest_minus_1_interaction)
    GROUP BY interval_start
)
SELECT
    e.run_date,
    e.interval_end,
    e.message_type_link,
    e.ehub_count,
    e.ehub_sla,
    COALESCE(b.message_count, 0) AS bronze_count,
    COALESCE(b.is_sla_flag, 0) AS bronze_sla,
    e.ehub_count - COALESCE(b.message_count, 0) AS count_difference,
    CASE
        WHEN e.ehub_sla = 1 AND COALESCE(b.is_sla_flag, 0) = 1 THEN 'EHUB & BRONZE'
        WHEN e.ehub_sla = 1 THEN 'EHUB'
        WHEN COALESCE(b.is_sla_flag, 0) = 1 THEN 'BRONZE'
        WHEN COALESCE(i.total_interaction_count, 0) = 0 THEN 'INTERACTION'
    END AS breach_source
FROM ehub_latest e
LEFT JOIN bronze_latest b
    ON e.message_type_link = b.message_type_link
   AND e.interval_end = b.interval_end
LEFT JOIN interaction_latest_minus_1 i
    ON 1 = 1
WHERE
       e.ehub_sla = 1
    OR COALESCE(b.is_sla_flag, 0) = 1
    OR COALESCE(i.total_interaction_count, 0) = 0
ORDER BY e.message_type_link
"""

df = spark.sql(query)
rows = [r.asDict() for r in df.collect()]

def truncate_text(value, max_len=28):
    s = "" if value is None else str(value)
    return s if len(s) <= max_len else s[:max_len - 3] + "..."

def status_block(has_breach: bool):
    if has_breach:
        return [
            {
                "type": "Container",
                "style": "attention",
                "bleed": True,
                "items": [
                    {
                        "type": "TextBlock",
                        "text": "⚠️  SLA BREACH DETECTED",
                        "weight": "Bolder",
                        "size": "Large",
                        "wrap": True
                    },
                    {
                        "type": "TextBlock",
                        "text": "Immediate review required for EHUB / Bronze / Interaction pipeline health.",
                        "wrap": True,
                        "spacing": "Small"
                    }
                ]
            }
        ]
    return [
        {
            "type": "Container",
            "style": "good",
            "bleed": True,
            "items": [
                {
                    "type": "TextBlock",
                    "text": "✅  SYSTEM HEALTHY",
                    "weight": "Bolder",
                    "size": "Large",
                    "wrap": True
                },
                {
                    "type": "TextBlock",
                    "text": "No SLA breach detected in the latest monitoring cycle.",
                    "wrap": True,
                    "spacing": "Small"
                }
            ]
        }
    ]

def summary_block(rows):
    impacted = len(rows)
    latest_interval = str(rows[0]["interval_end"]) if rows else str(
        spark.sql("select current_timestamp() as ts").collect()[0]["ts"]
    )

    if rows:
        source_counts = {}
        for r in rows:
            src = str(r.get("breach_source", "UNKNOWN"))
            source_counts[src] = source_counts.get(src, 0) + 1
        source_text = ", ".join([f"{k}: {v}" for k, v in source_counts.items()])
    else:
        source_text = "No impacted flows"

    return {
        "type": "Container",
        "spacing": "Medium",
        "items": [
            {
                "type": "TextBlock",
                "text": "RADAR LIVE | Production Monitoring",
                "weight": "Bolder",
                "size": "Medium"
            },
            {
                "type": "FactSet",
                "facts": [
                    {"title": "Environment", "value": "Production"},
                    {"title": "Interval", "value": latest_interval},
                    {"title": "Impacted Flows", "value": str(impacted)},
                    {"title": "Affected Source", "value": source_text}
                ]
            }
        ]
    }

def table_header():
    return {
        "type": "ColumnSet",
        "separator": True,
        "spacing": "Medium",
        "columns": [
            {"type": "Column", "width": 3, "items": [{"type": "TextBlock", "text": "Message Type", "weight": "Bolder", "wrap": True}]},
            {"type": "Column", "width": 1, "items": [{"type": "TextBlock", "text": "EHUB", "weight": "Bolder", "horizontalAlignment": "Center"}]},
            {"type": "Column", "width": 1, "items": [{"type": "TextBlock", "text": "Bronze", "weight": "Bolder", "horizontalAlignment": "Center"}]},
            {"type": "Column", "width": 1, "items": [{"type": "TextBlock", "text": "Diff", "weight": "Bolder", "horizontalAlignment": "Center"}]},
            {"type": "Column", "width": 2, "items": [{"type": "TextBlock", "text": "Breach Source", "weight": "Bolder", "wrap": True}]}
        ]
    }

def table_rows(rows, max_rows=8):
    items = []
    for r in rows[:max_rows]:
        breach_source = str(r.get("breach_source", "UNKNOWN"))
        source_icon = "⚠️" if breach_source != "INTERACTION" else "🛠️"

        items.append({
            "type": "ColumnSet",
            "separator": True,
            "spacing": "Small",
            "columns": [
                {
                    "type": "Column",
                    "width": 3,
                    "items": [{
                        "type": "TextBlock",
                        "text": truncate_text(r.get("message_type_link")),
                        "wrap": True
                    }]
                },
                {
                    "type": "Column",
                    "width": 1,
                    "items": [{
                        "type": "TextBlock",
                        "text": str(r.get("ehub_count", 0)),
                        "horizontalAlignment": "Center"
                    }]
                },
                {
                    "type": "Column",
                    "width": 1,
                    "items": [{
                        "type": "TextBlock",
                        "text": str(r.get("bronze_count", 0)),
                        "horizontalAlignment": "Center"
                    }]
                },
                {
                    "type": "Column",
                    "width": 1,
                    "items": [{
                        "type": "TextBlock",
                        "text": str(r.get("count_difference", 0)),
                        "horizontalAlignment": "Center"
                    }]
                },
                {
                    "type": "Column",
                    "width": 2,
                    "items": [{
                        "type": "TextBlock",
                        "text": f"{source_icon} {breach_source}",
                        "wrap": True
                    }]
                }
            ]
        })

    if len(rows) > max_rows:
        items.append({
            "type": "TextBlock",
            "text": f"... and {len(rows) - max_rows} more impacted message types",
            "isSubtle": True,
            "spacing": "Small",
            "wrap": True
        })

    return items

def build_card(rows):
    has_breach = len(rows) > 0

    body = []
    body.extend(status_block(has_breach))
    body.append(summary_block(rows))

    if has_breach:
        body.append({
            "type": "TextBlock",
            "text": "Impact Summary",
            "weight": "Bolder",
            "spacing": "Medium"
        })
        body.append(table_header())
        body.extend(table_rows(rows, max_rows=8))
    else:
        body.append({
            "type": "TextBlock",
            "text": "All monitored message types are within SLA for the current cycle.",
            "wrap": True,
            "spacing": "Medium"
        })

    return {
        "type": "message",
        "attachments": [
            {
                "contentType": "application/vnd.microsoft.card.adaptive",
                "content": {
                    "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
                    "type": "AdaptiveCard",
                    "version": "1.4",
                    "body": body,
                    "actions": [
                        {
                            "type": "Action.OpenURL",
                            "title": "Open Monitoring Dashboard",
                            "url": DASHBOARD_URL
                        }
                    ]
                }
            }
        ]
    }

payload = build_card(rows)

response = requests.post(
    WEBHOOK_URL,
    headers={"Content-Type": "application/json"},
    data=json.dumps(payload),
    timeout=30
)

print("HTTP status:", response.status_code)
print("Response text:", response.text)
response.raise_for_status()
