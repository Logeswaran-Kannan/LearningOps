WITH latest_daily_run AS (
    SELECT
        run_date,
        MAX(timestamp) AS latest_timestamp
    FROM core_bld.default.dw_audit_table_count_check
    WHERE is_latest = 'Y'
    GROUP BY run_date
),
latest_daily_data AS (
    SELECT t.*
    FROM core_bld.default.dw_audit_table_count_check t
    INNER JOIN latest_daily_run r
        ON t.run_date = r.run_date
       AND t.timestamp = r.latest_timestamp
    WHERE t.is_latest = 'Y'
),
base AS (
    SELECT
        run_date,
        run_id,
        table_name,
        CASE
            WHEN lower(table_name) LIKE 'p%' THEN 'PC'
            WHEN lower(table_name) LIKE 'b%' THEN 'BC'
            WHEN lower(table_name) LIKE 'c%' THEN 'CC'
            ELSE 'OTHER'
        END AS domain,
        ods_stg_copy_count,
        ods_count,
        ods_views_count,
        ods_stg_copy_table_exists,
        ods_table_exists,
        ods_views_table_exists,
        ods_stg_copy_date_filter_applied,
        ods_date_filter_applied,
        ods_views_date_filter_applied,
        status,
        comment,
        timestamp
    FROM latest_daily_data
)

SELECT
    run_date,
    domain,
    COUNT(*) AS total_tables,
    SUM(CASE WHEN status = 'ALL_MATCHED' THEN 1 ELSE 0 END) AS all_matched_cnt,
    SUM(CASE WHEN status = 'COUNT_MISMATCH' THEN 1 ELSE 0 END) AS count_mismatch_cnt,
    SUM(CASE WHEN status = 'DATA_NOT_LOADED' THEN 1 ELSE 0 END) AS data_not_loaded_cnt,
    SUM(CASE WHEN status = 'TABLE_NOT_CREATED' THEN 1 ELSE 0 END) AS table_not_created_cnt,
    SUM(CASE WHEN status = 'STAGE_COPY_LOAD_ISSUE' THEN 1 ELSE 0 END) AS stage_copy_load_issue_cnt,
    SUM(CASE WHEN status = 'ODS_LOAD_ISSUE' THEN 1 ELSE 0 END) AS ods_load_issue_cnt,
    SUM(CASE WHEN status = 'ODS_VIEWS_LOAD_ISSUE' THEN 1 ELSE 0 END) AS ods_views_load_issue_cnt,
    SUM(CASE WHEN status = 'CHECK_REQUIRED' THEN 1 ELSE 0 END) AS check_required_cnt,
    ROUND(100.0 * SUM(CASE WHEN status = 'ALL_MATCHED' THEN 1 ELSE 0 END) / COUNT(*), 2) AS kpi_match_pct,
    ROUND(100.0 * SUM(CASE WHEN status IN ('ALL_MATCHED','COUNT_MISMATCH') THEN 1 ELSE 0 END) / COUNT(*), 2) AS kpi_loaded_presence_pct,
    MAX(timestamp) AS batch_timestamp
FROM base
GROUP BY run_date, domain
ORDER BY run_date DESC, domain;
