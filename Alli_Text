%sql

WITH hist_base AS (
    SELECT
        interactionId,
        MQSQuoteId,

        requestTimestamp,
        athenaTimestamp,
        MQSTimestamp,

        DATE(requestTimestamp) AS requestDate,
        DATE(athenaTimestamp) AS athenaDate,
        DATE(MQSTimestamp) AS mqsDate,

        LPAD(CAST(requestProcess AS STRING),2,'0') AS requestProcess,
        LPAD(CAST(athenaProcess AS STRING),2,'0') AS athenaProcess,
        LPAD(CAST(MQSProcess AS STRING),2,'0') AS MQSProcess,

        existsInCSV,
        existsInAthena,
        existsInMQS,
        allMatching

    FROM core_bld.radar_live.reconciliation_history
),

hist_filtered AS (
    SELECT *
    FROM hist_base
    WHERE requestDate = DATE('2026-02-09')
),

classified AS (

SELECT

    interactionId,
    MQSQuoteId,

    requestTimestamp,
    MQSTimestamp,
    athenaTimestamp,

    requestProcess,
    MQSProcess,
    athenaProcess,

    existsInCSV,
    existsInMQS,
    existsInAthena,

    requestDate,
    mqsDate,
    athenaDate,

    CASE

        WHEN existsInCSV = true
         AND existsInMQS = true
         AND existsInAthena = true
         AND requestProcess = MQSProcess
         AND requestProcess = athenaProcess
         AND athenaDate = requestDate
        THEN 'matched_in_window'

        WHEN existsInCSV = true
         AND existsInMQS = true
         AND existsInAthena = true
         AND requestProcess = MQSProcess
         AND requestProcess = athenaProcess
         AND athenaDate > requestDate
        THEN 'matched_backdated'

        WHEN existsInCSV = true
         AND existsInMQS = true
         AND existsInAthena = true
         AND (
                requestProcess <> MQSProcess
             OR requestProcess <> athenaProcess
             OR MQSProcess <> athenaProcess
            )
        THEN 'different_process'

        WHEN existsInCSV = true
         AND existsInMQS = true
         AND (existsInAthena = false OR existsInAthena IS NULL)
        THEN 'mqs_only'

        WHEN existsInCSV = true
         AND (existsInMQS = false OR existsInMQS IS NULL)
         AND existsInAthena = true
        THEN 'athena_only'

        WHEN existsInCSV = true
         AND (existsInMQS = false OR existsInMQS IS NULL)
         AND (existsInAthena = false OR existsInAthena IS NULL)
        THEN 'missing'

        WHEN existsInCSV = false
         AND existsInMQS = true
        THEN 'reverse_recon_mqs'

        WHEN existsInCSV = false
         AND existsInAthena = true
        THEN 'reverse_recon_athena'

        ELSE 'unclassified'

    END AS recon_status

FROM hist_filtered
)

SELECT *
FROM classified
ORDER BY
requestTimestamp,
interactionId,
requestProcess;
