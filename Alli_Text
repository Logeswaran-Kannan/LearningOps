WITH mqs_9feb AS (
    SELECT
        headers['MQSQuoteId']                                       AS mqs_quote_id,
        headers['externalID']                                       AS external_id,
        coalesce(
            headers['transactionType'],
            get_json_object(payload, '$.control.transactionType'),
            get_json_object(payload, '$.transactionType'),
            'UNKNOWN'
        )                                                           AS transaction_type,
        min(cast(enqueuedTime as timestamp))                        AS first_mqs_enqueued_ts,
        max(CASE
            WHEN lower(payload) LIKE '%"provider":"mylicence"%'
              OR lower(payload) LIKE '%"provider":"mylicense"%'
              OR lower(payload) LIKE '%"provider":"dvla"%'
            THEN 1 ELSE 0 END)                                      AS has_mylicense_dvla
    FROM core.mqs_athn_mtr.ehubstream
    WHERE headers['messageType'] = 'afp-quote-request'
      AND headers['MQSQuoteId'] IS NOT NULL
      AND date(cast(enqueuedTime as timestamp)) = '2026-02-09'
    GROUP BY
        headers['MQSQuoteId'],
        headers['externalID'],
        coalesce(
            headers['transactionType'],
            get_json_object(payload, '$.control.transactionType'),
            get_json_object(payload, '$.transactionType'),
            'UNKNOWN'
        )
),
athena_match AS (
    SELECT
        get_json_object(payload, '$.interaction.mqsQuoteId')        AS mqs_quote_id,
        min(cast(coalesce(TimeEnqueued, wrtTimestamp, get_json_object(payload, '$.timestamp')) as timestamp))
                                                                    AS first_athena_ts,
        min(CASE
            WHEN upper(get_json_object(payload, '$.interaction.status')) = 'AGREEMENT'
            THEN cast(coalesce(TimeEnqueued, wrtTimestamp, get_json_object(payload, '$.timestamp')) as timestamp)
        END)                                                        AS first_agreement_ts,
        max(CASE
            WHEN upper(get_json_object(payload, '$.interaction.status')) = 'AGREEMENT'
            THEN 1 ELSE 0
        END)                                                        AS is_converted_in_athena
    FROM core.flow.ehubstream
    WHERE get_json_object(payload, '$.interaction.mqsQuoteId') IS NOT NULL
    GROUP BY get_json_object(payload, '$.interaction.mqsQuoteId')
)
SELECT
    m.mqs_quote_id,
    m.external_id,
    upper(m.transaction_type)                                       AS transaction_type,
    m.first_mqs_enqueued_ts,
    a.first_athena_ts,
    a.first_agreement_ts,
    coalesce(a.is_converted_in_athena, 0)                           AS is_converted_in_athena,
    datediff(current_date(), date(m.first_mqs_enqueued_ts))         AS age_days,
    m.has_mylicense_dvla,
    CASE
        WHEN coalesce(a.is_converted_in_athena, 0) = 0
         AND datediff(current_date(), date(m.first_mqs_enqueued_ts)) > 60
         AND m.has_mylicense_dvla = 1
        THEN 'DELETE_MYLICENSE_PART'
        WHEN coalesce(a.is_converted_in_athena, 0) = 1
        THEN 'KEEP_CONVERTED'
        ELSE 'KEEP_NOT_YET_60'
    END                                                             AS retention_action
FROM mqs_9feb m
LEFT JOIN athena_match a
    ON m.mqs_quote_id = a.mqs_quote_id
ORDER BY m.first_mqs_enqueued_ts;
