WITH params AS (
    SELECT
        current_date() AS run_dt,
        timestamp('2026-04-14 13:00:00') AS fix_cutoff_ts
),

base AS (
    SELECT
        MQS_QUOTE_ID,
        RATING_QUOTE_KEY,
        QUOTE_REF,
        POLICY_REF,
        BRAND_NAME,
        RATING_REQUEST_CHANNEL_NAME,
        TRNSCTN_DESC,
        LATEST_QUOTE_JOURNEY_DESC,

        to_date(TRNSCTN_DT) AS trnsctn_dt,
        to_date(EFCTV_DTS) AS efctv_dt,
        to_date(DWH_DATA_DTS) AS dwh_data_dt,

        DWH_CREATE_DTS,
        DWH_UPDATE_DTS,

        CASE
            WHEN lower(RATING_REQUEST_CHANNEL_NAME) LIKE '%confused%' THEN 'Aggs - Confused'
            WHEN lower(RATING_REQUEST_CHANNEL_NAME) LIKE '%ctm%'
              OR lower(RATING_REQUEST_CHANNEL_NAME) LIKE '%compare the market%' THEN 'Aggs - CTM'
            WHEN lower(RATING_REQUEST_CHANNEL_NAME) LIKE '%go compare%' THEN 'Aggs - Go Compare'
            WHEN lower(RATING_REQUEST_CHANNEL_NAME) LIKE '%msm%'
              OR lower(RATING_REQUEST_CHANNEL_NAME) LIKE '%money supermarket%' THEN 'Aggs - MSM'
            ELSE 'Non Aggs - including partnerships'
        END AS aggregator_group,

        CASE
            WHEN LATEST_QUOTE_JOURNEY_DESC IS NULL
              OR lower(LATEST_QUOTE_JOURNEY_DESC) NOT LIKE '%sale%'
            THEN 1 ELSE 0
        END AS is_unconverted

    FROM core.curated_idw_mtr_athn_mqs.dim_audit_rating_quote_permissions
    WHERE DWH_CREATE_DTS < timestamp('2026-04-14 13:00:00')
      AND MQS_QUOTE_ID IS NOT NULL
),

retention_rule AS (
    SELECT
        *,
        CASE
            WHEN aggregator_group IN ('Aggs - CTM', 'Aggs - Go Compare') THEN 15
            WHEN aggregator_group = 'Aggs - Confused' THEN NULL
            ELSE 24
        END AS retention_months
    FROM base
),

date_candidates AS (
    SELECT
        *,
        date_sub(efctv_dt, 30) AS potential_earliest_trnsctn_dt,

        add_months(trnsctn_dt, retention_months) AS delete_due_by_trnsctn_dt,
        add_months(date_sub(efctv_dt, 30), retention_months) AS delete_due_by_efctv_minus_30,
        add_months(dwh_data_dt, retention_months) AS delete_due_by_dwh_data_dt,

        datediff(efctv_dt, trnsctn_dt) AS efctv_vs_trnsctn_days,
        datediff(efctv_dt, dwh_data_dt) AS efctv_vs_dwh_data_days,
        datediff(trnsctn_dt, dwh_data_dt) AS trnsctn_vs_dwh_data_days

    FROM retention_rule
    WHERE retention_months IS NOT NULL
      AND is_unconverted = 1
),

flags AS (
    SELECT
        *,
        CASE WHEN delete_due_by_trnsctn_dt <= current_date() THEN 1 ELSE 0 END AS delete_using_trnsctn_dt,
        CASE WHEN delete_due_by_efctv_minus_30 <= current_date() THEN 1 ELSE 0 END AS delete_using_efctv_minus_30,
        CASE WHEN delete_due_by_dwh_data_dt <= current_date() THEN 1 ELSE 0 END AS delete_using_dwh_data_dt,

        CASE
            WHEN delete_due_by_trnsctn_dt <= current_date()
             AND delete_due_by_dwh_data_dt > current_date()
            THEN 1 ELSE 0
        END AS wrongly_delete_if_using_trnsctn_dt_vs_dwh,

        CASE
            WHEN delete_due_by_efctv_minus_30 <= current_date()
             AND delete_due_by_dwh_data_dt > current_date()
            THEN 1 ELSE 0
        END AS wrongly_delete_if_using_efctv_minus_30_vs_dwh,

        CASE
            WHEN abs(datediff(efctv_dt, dwh_data_dt)) > 30
            THEN 1 ELSE 0
        END AS efctv_suspicious_vs_dwh,

        CASE
            WHEN abs(datediff(trnsctn_dt, dwh_data_dt)) > 30
            THEN 1 ELSE 0
        END AS trnsctn_suspicious_vs_dwh

    FROM date_candidates
)

SELECT
    aggregator_group,
    retention_months,
    TRNSCTN_DESC,

    COUNT(DISTINCT MQS_QUOTE_ID) AS total_unconverted_quotes_pre_fix,

    COUNT(DISTINCT CASE WHEN delete_using_trnsctn_dt = 1 THEN MQS_QUOTE_ID END)
        AS would_delete_using_trnsctn_dt,

    COUNT(DISTINCT CASE WHEN delete_using_efctv_minus_30 = 1 THEN MQS_QUOTE_ID END)
        AS would_delete_using_efctv_minus_30,

    COUNT(DISTINCT CASE WHEN delete_using_dwh_data_dt = 1 THEN MQS_QUOTE_ID END)
        AS would_delete_using_dwh_data_dt,

    COUNT(DISTINCT CASE WHEN wrongly_delete_if_using_trnsctn_dt_vs_dwh = 1 THEN MQS_QUOTE_ID END)
        AS wrongly_delete_if_using_trnsctn_dt,

    COUNT(DISTINCT CASE WHEN wrongly_delete_if_using_efctv_minus_30_vs_dwh = 1 THEN MQS_QUOTE_ID END)
        AS wrongly_delete_if_using_efctv_minus_30,

    COUNT(DISTINCT CASE WHEN efctv_suspicious_vs_dwh = 1 THEN MQS_QUOTE_ID END)
        AS quotes_where_efctv_dt_suspicious,

    COUNT(DISTINCT CASE WHEN trnsctn_suspicious_vs_dwh = 1 THEN MQS_QUOTE_ID END)
        AS quotes_where_trnsctn_dt_suspicious

FROM flags
GROUP BY
    aggregator_group,
    retention_months,
    TRNSCTN_DESC
ORDER BY
    wrongly_delete_if_using_trnsctn_dt DESC; 

