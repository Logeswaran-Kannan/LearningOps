# =========================================================
# BREACH QUERY
# =========================================================
breach_sql = f"""
WITH ehub_latest AS (
    SELECT
        run_date,
        interval_end,
        message_type AS message_type_link,
        message_count AS ehub_count,
        is_sla_breach AS ehub_sla
    FROM core_bld.default.monitoring_ehub_30min_update
    WHERE message_type <> 'ALL'
      AND interval_end = TIMESTAMP('{mqs_interval}')
),
bronze_latest AS (
    SELECT
        CASE
            WHEN message_type = 'dlt_quote_request' THEN 'mqs-quote-request'
            WHEN message_type = 'dlt_precomp_response' THEN 'precomp-response'
            WHEN message_type = 'dlt_rating_request_v2' THEN 'rating-request'
            WHEN message_type = 'dlt_rating_response_v2' THEN 'rating-response'
            WHEN message_type = 'dlt_cache_id' THEN 'quote-cache-id'
            WHEN message_type = 'dlt_stop_quote' THEN 'stop-quote'
            WHEN message_type = 'dlt_rating_request_dvla_removed_v2' THEN 'dlt_rating_request_dvla_removed_v2'
            WHEN message_type = 'dlt_raw_enrichments' THEN 'dlt_raw_enrichments'
            ELSE 'others'
        END AS message_type_link,
        interval_end,
        message_count,
        is_sla_flag
    FROM core_bld.default.monitoring_mqs_bronze_30min_update
    WHERE message_type <> 'ALL'
      AND interval_end = TIMESTAMP('{mqs_interval}')
),
interaction_expected AS (
    SELECT
        interval_start,
        SUM(total_count) AS total_interaction_count
    FROM core_bld.default.monitoring_mqs_interaction_status
    WHERE interval_start = TIMESTAMP('{interaction_interval}')
    GROUP BY interval_start
),
final_status AS (
    SELECT
        e.run_date,
        e.interval_end,
        e.message_type_link,
        e.ehub_count,
        e.ehub_sla,
        COALESCE(b.message_count, 0) AS bronze_count,
        COALESCE(b.is_sla_flag, 0) AS bronze_sla,
        e.ehub_count - COALESCE(b.message_count, 0) AS count_difference,
        ABS(e.ehub_count - COALESCE(b.message_count, 0)) AS abs_count_difference,
        CASE
            WHEN e.ehub_sla = 1 AND COALESCE(b.is_sla_flag, 0) = 1 THEN 'EHUB & BRONZE'
            WHEN e.ehub_sla = 1 THEN 'EHUB'
            WHEN COALESCE(b.is_sla_flag, 0) = 1 THEN 'BRONZE'
            WHEN COALESCE(i.total_interaction_count, 0) = 0 THEN 'INTERACTION'
        END AS breach_source
    FROM ehub_latest e
    LEFT JOIN bronze_latest b
        ON e.message_type_link = b.message_type_link
       AND e.interval_end = b.interval_end
    LEFT JOIN interaction_expected i
        ON 1 = 1
)
SELECT *
FROM final_status
WHERE
       ehub_sla = 1
    OR bronze_sla = 1
    OR breach_source = 'INTERACTION'
ORDER BY abs_count_difference DESC, message_type_link
"""

rows = [r.asDict() for r in spark.sql(breach_sql).collect()]
current_status = "BREACH" if rows else "HEALTHY"
current_interval = mqs_interval

print("DEBUG STATUS")
