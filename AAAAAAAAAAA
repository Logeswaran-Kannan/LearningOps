# STATE TABLE
# ==============================================================
def ensure_state_table():
    spark.sql(f"""
    CREATE TABLE IF NOT EXISTS {STATE_TABLE} (
        alert_name        STRING,
        brand             STRING,
        current_status    STRING,
        last_interval     TIMESTAMP,
        last_notified_at  TIMESTAMP
    )
    USING DELTA
    """)

def read_previous_status(brand: str):
    """Read previous status for a specific brand."""
    state_df  = spark.table(STATE_TABLE).filter(
        (F.col("alert_name") == ALERT_NAME) &
        (F.col("brand") == brand)
    )
    state_rows = state_df.collect()
    return state_rows[0]["current_status"] if state_rows else None

def upsert_state(brand: str, current_status: str, current_interval):
    """
    Safe MERGE upsert — atomic, no DELETE+INSERT gap.
    Prevents state loss if job fails mid-run.
    """
    spark.createDataFrame(
        [(ALERT_NAME, brand, current_status, current_interval)],
        ["alert_name", "brand", "current_status", "last_interval"]
    ).withColumn(
        "last_notified_at", F.current_timestamp()
    ).createOrReplaceTempView("state_update")

    spark.sql(f"""
        MERGE INTO {STATE_TABLE} t
        USING state_update s
        ON t.alert_name = s.alert_name
        AND t.brand = s.brand
        WHEN MATCHED THEN UPDATE SET
            t.current_status   = s.current_status,
            t.last_interval    = s.last_interval,
            t.last_notified_at = s.last_notified_at
        WHEN NOT MATCHED THEN INSERT (
            alert_name, brand, current_status,
            last_interval, last_notified_at
        ) VALUES (
            s.alert_name, s.brand, s.current_status,
            s.last_interval, s.last_notified_at
        )
    """)

# ==============================================================
# CORE BREACH QUERY — PER BRAND
# ==============================================================
def get_breach_rows(brand: str):
    """
    Returns breach rows for a specific brand from the latest interval.
    Joins EHUB + Bronze on (message_type_link, interval_end, brand).
    Interaction joined on (interval_start, brand).
    """
    query = f"""
    WITH bounds AS (
        SELECT date_trunc('day', current_timestamp()) AS day_start
    ),
    latest_mqs_interval AS (
        SELECT MAX(interval_end) AS max_interval
        FROM {EHUB_TABLE}
        WHERE interval_end >= (SELECT day_start FROM bounds)
          AND message_type <> 'ALL'
          AND brand = '{brand}'
    ),
    interaction_intervals AS (
        SELECT DISTINCT interval_start
        FROM {INTERACTION_TABLE}
        WHERE interval_start >= (SELECT day_start FROM bounds)
          AND brand = '{brand}'
    ),
    latest_minus_1_interaction AS (
        SELECT interval_start AS interaction_interval
        FROM (
            SELECT interval_start,
                   ROW_NUMBER() OVER (ORDER BY interval_start DESC) AS rn
            FROM interaction_intervals
        ) x
        WHERE rn = 1
    ),
    ehub_latest AS (
        SELECT
            run_date,
            interval_start,
            interval_end,
            message_type        AS message_type_link,
            message_count       AS ehub_count,
            is_sla_breach       AS ehub_sla,
            brand
        FROM {EHUB_TABLE}
        WHERE message_type <> 'ALL'
          AND brand = '{brand}'
          AND interval_end = (SELECT max_interval FROM latest_mqs_interval)
    ),
    bronze_latest AS (
        SELECT
            CASE
                WHEN message_type = 'dlt_quote_request'                  THEN 'mqs-quote-request'
                WHEN message_type = 'dlt_precomp_response'               THEN 'precomp-response'
                WHEN message_type = 'dlt_rating_request_v2'              THEN 'rating-request'
                WHEN message_type = 'dlt_rating_response_v2'             THEN 'rating-response'
                WHEN message_type = 'dlt_cache_id'                       THEN 'quote-cache-id'
                WHEN message_type = 'dlt_stop_quote'                     THEN 'stop-quote'
                WHEN message_type = 'dlt_rating_request_dvla_removed_v2' THEN 'dlt_rating_request_dvla_removed'
                WHEN message_type = 'dlt_raw_enrichments'                THEN 'dlt_raw_enrichments'
                ELSE 'others'
            END AS message_type_link,
            interval_end,
            interval_start,
            message_count,
            is_sla_breach       AS is_sla_flag,
            brand
        FROM {BRONZE_TABLE}
        WHERE message_type <> 'ALL'
          AND brand = '{brand}'
          AND interval_end = (SELECT max_interval FROM latest_mqs_interval)
    ),
    interaction_latest AS (
        SELECT
            interval_start,
            SUM(total_count) AS total_interaction_count
        FROM {INTERACTION_TABLE}
        WHERE brand = '{brand}'
          AND status = 'ALL'
          AND interval_start = (SELECT interaction_interval FROM latest_minus_1_interaction)
        GROUP BY interval_start
    )
    SELECT
        e.run_date,
        e.interval_end,
        e.message_type_link,
        e.ehub_count,
        e.ehub_sla,
        COALESCE(b.message_count, 0)  AS bronze_count,
        COALESCE(b.is_sla_flag, 0)    AS bronze_sla,
        e.ehub_count - COALESCE(b.message_count, 0) AS count_difference,
        CASE
            WHEN e.ehub_sla = 1 AND COALESCE(b.is_sla_flag, 0) = 1 THEN '△ EHUB & BRONZE'
            WHEN e.ehub_sla = 1                                      THEN '△ EHUB'
            WHEN COALESCE(b.is_sla_flag, 0) = 1                     THEN '△ BRONZE'
            WHEN COALESCE(i.total_interaction_count, 0) = 0          THEN '※ INTERACTION'
        END AS breach_source
    FROM ehub_latest e
    LEFT JOIN bronze_latest b
        ON  e.message_type_link = b.message_type_link
        AND e.interval_end      = b.interval_end
    LEFT JOIN interaction_latest i
        ON  e.interval_start    = i.interval_start
    WHERE
        e.ehub_sla = 1
        OR COALESCE(b.is_sla_flag, 0) = 1
        OR COALESCE(i.total_interaction_count, 0) = 0
    ORDER BY e.message_type_link
    LIMIT 6
    """
    breach_df = spark.sql(query)
    return [r.asDict() for r in breach_df.collect()]

def get_latest_interval(brand: str):
    """Get latest completed interval for a brand."""
    result = spark.sql(f"""
        WITH bounds AS (
            SELECT date_trunc('day', current_timestamp()) AS day_start
        )
        SELECT MAX(interval_end) AS latest_interval
        FROM {EHUB_TABLE}
        WHERE interval_end >= (SELECT day_start FROM bounds)
          AND message_type <> 'ALL'
          AND brand = '{brand}'
    """).collect()[0]["latest_interval"]
    return result

