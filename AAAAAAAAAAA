WITH base AS (
    SELECT
        TRNSCTN_DESC,
        TRNSCTN_DT,
        EFCTV_DTS,
        LATEST_QUOTE_JOURNEY_DESC,
        
        -- Identify period
        CASE 
            WHEN TRNSCTN_DT < '2026-04-14 05:00:00' 
            THEN 'PRE_FIX'
            ELSE 'POST_FIX'
        END AS period,

        -- Unconverted flag
        CASE 
            WHEN LATEST_QUOTE_JOURNEY_DESC NOT LIKE '%Sale%' 
                 OR LATEST_QUOTE_JOURNEY_DESC IS NULL
            THEN 1 ELSE 0 
        END AS is_unconverted,

        -- Violation flag
        CASE 
            WHEN datediff(EFCTV_DTS, TRNSCTN_DT) > 30 
            THEN 1 ELSE 0 
        END AS is_violation

    FROM core.curated_idw_mtr_athn_mqs.dim_audit_rating_quote_permissions
)

SELECT
    TRNSCTN_DESC,

    COUNT(*) AS total_records,

    SUM(is_unconverted) AS unconverted_records,

    SUM(CASE WHEN is_unconverted = 1 AND is_violation = 1 THEN 1 END) 
        AS violating_unconverted_records,

    ROUND(
        100 * SUM(CASE WHEN is_unconverted = 1 AND is_violation = 1 THEN 1 END) 
        / NULLIF(SUM(is_unconverted),0), 2
    ) AS violation_pct_within_unconverted

FROM base
WHERE period = 'PRE_FIX'
GROUP BY TRNSCTN_DESC
ORDER BY violating_unconverted_records DESC;
