-- Check last 3 intervals and their counts
SELECT
    interval_end,
    brand,
    message_type,
    message_count,
    is_sla_breach
FROM core_bld.default.monitoring_ehub_30min_update
WHERE run_date = current_date()
  AND message_type <> 'ALL'
  AND brand IN ('AZ','BRITANNIA')
ORDER BY interval_end DESC
LIMIT 30
