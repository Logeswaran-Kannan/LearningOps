def send_teams_payload(webhook_url, payload):
    payload_str = json.dumps(payload, ensure_ascii=False)

    print("Payload size:", len(payload_str))
    print(payload_str[:2000])

    response = requests.post(
        webhook_url.strip(),
        headers={"Content-Type": "application/json; charset=utf-8"},
        data=payload_str.encode("utf-8"),
        timeout=30
    )

    print("HTTP status:", response.status_code)
    print("Response text:", response.text)

    if response.status_code >= 400 or "Webhook message delivery failed" in response.text:
        raise Exception(f"Teams webhook failed: {response.text}")

    return response

