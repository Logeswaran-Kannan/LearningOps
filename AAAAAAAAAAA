        brand_summaries.append({
            "brand"        : brand,
            "status"       : current_status,
            "breaches"     : get_overnight_breach_count(brand),
            "last_interval": latest_interval
        })
    send_webhook(daily_health_card(brand_summaries))
    print("Daily health card sent.")

# ---------- Breach / recovery alert ----------
action  = should_send_alert(
    prev_status, current_status,
    notified_status, consecutive_count
)
payload = None

if action == "breach":
    print("→ Sending breach card")
    payload         = breach_card(rows, latest_interval)
    notified_status = "BREACH"

elif action == "recovery":
    print(f"→ Sending recovery card after {consecutive_count} stable intervals")
    payload         = healthy_card(latest_interval)
    notified_status = "HEALTHY"

else:
    print("→ No notification sent")

if payload:
    send_webhook(payload)

upsert_state(
    current_status, latest_interval,
    consecutive_count, notified_status
)

print("Alert job completed successfully.")
