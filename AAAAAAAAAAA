WITH base AS (
    SELECT
        POLICY_REF,
        TRNSCTN_DESC,
        to_date(EFCTV_DTS) AS EFCTV_DT,
        DWH_CREATE_DTS,

        ROW_NUMBER() OVER (
            PARTITION BY POLICY_REF, TRNSCTN_DESC
            ORDER BY EFCTV_DTS
        ) AS rn

    FROM core.curated_idw_mtr_athn_mqs.dim_audit_rating_quote_permissions
    WHERE POLICY_REF IS NOT NULL
)
