from pyspark.sql import functions as F
from pyspark.sql import Window
from delta.tables import DeltaTable

CSV_TABLE = "core_bld.radar_live.reconciliation_csv_source"
FLOW_TABLE = "core.flow.ehubstream"
TARGET_TABLE = "core_bld.radar_live.recon_interaction_detail"

LOOKBACK_DAYS = 2
SCAN_DAYS_BEFORE = 15
SCAN_DAYS_AFTER = 15
FLOW_HARD_START_DATE = "2026-01-30"

CSV_KEY_COLS = [
    "interactionId",
    "mqsQuoteId",
    "requestTimestamp",
    "transactionCode",
    "csv_segment"
]

MERGE_KEY_COLS = [
    "reconciliation_direction",
    "csv_interactionId",
    "csv_mqsQuoteId",
    "csv_requestTimestamp",
    "csv_transactionCode",
    "csv_segment",
    "interaction_interactionId",
    "interaction_mqsQuoteId",
    "interaction_TimeEnqueued",
    "interaction_process_code",
    "interaction_segment"
]


def target_has_data():
    if not spark.catalog.tableExists(TARGET_TABLE):
        return False
    return spark.table(TARGET_TABLE).limit(1).count() > 0


def dedupe_df(df, partition_cols, order_cols):
    w = Window.partitionBy(*partition_cols).orderBy(*order_cols)
    return df.withColumn("_rn", F.row_number().over(w)).filter("_rn = 1").drop("_rn")


def calculate_time_diff(df, left_ts_col, right_ts_col):
    return (
        df
        .withColumn("diff_days", F.when(
            F.col(left_ts_col).isNotNull() & F.col(right_ts_col).isNotNull(),
            F.datediff(F.to_date(F.col(right_ts_col)), F.to_date(F.col(left_ts_col)))
        ))
        .withColumn("diff_hours", F.when(
            F.col(left_ts_col).isNotNull() & F.col(right_ts_col).isNotNull(),
            F.round((F.unix_timestamp(right_ts_col) - F.unix_timestamp(left_ts_col)) / 3600.0, 2)
        ))
        .withColumn("diff_minutes", F.when(
            F.col(left_ts_col).isNotNull() & F.col(right_ts_col).isNotNull(),
            F.round((F.unix_timestamp(right_ts_col) - F.unix_timestamp(left_ts_col)) / 60.0, 2)
        ))
        .withColumn("abs_diff_hours", F.when(
            F.col(left_ts_col).isNotNull() & F.col(right_ts_col).isNotNull(),
            F.round(F.abs(F.unix_timestamp(right_ts_col) - F.unix_timestamp(left_ts_col)) / 3600.0, 2)
        ))
    )


def load_csv_base():
    df = (
        spark.table(CSV_TABLE)
        .select(
            "interactionId",
            "mqsQuoteId",
            "requestTimestamp",
            "requestDate",
            "requestTime",
            F.col("transactionType").alias("csv_transactionType"),
            "transactionCode",
            "product"
        )
        .filter(
            F.col("interactionId").isNotNull() &
            F.col("requestTimestamp").isNotNull() &
            F.col("transactionCode").isNotNull() &
            F.col("requestDate").isNotNull()
        )
        .withColumn(
            "csv_segment",
            F.when(F.col("mqsQuoteId").isNull(), "POLARIS_OR_NON_MQS")
             .otherwise("MQS_LINKED")
        )
    )

    return dedupe_df(
        df,
        CSV_KEY_COLS,
        [F.col("requestTimestamp").desc(), F.col("requestDate").desc_nulls_last()]
    )


def load_csv_source():
    base_df = load_csv_base()

    if not target_has_data():
        return base_df.withColumn("run_type", F.lit("FIRST_RUN"))

    source_max_date = (
        base_df.select(F.max("requestDate").alias("source_max_date"))
        .collect()[0]["source_max_date"]
    )

    if source_max_date is None:
        return base_df.limit(0).withColumn("run_type", F.lit("INCREMENTAL_RUN"))

    return (
        base_df
        .filter(
            F.col("requestDate").between(
                F.date_sub(F.lit(source_max_date), LOOKBACK_DAYS),
                F.lit(source_max_date)
            )
        )
        .withColumn("run_type", F.lit("INCREMENTAL_RUN"))
    )


def get_csv_time_bounds(csv_df):
    row = (
        csv_df.select(
            F.min("requestTimestamp").alias("min_ts"),
            F.max("requestTimestamp").alias("max_ts")
        )
        .collect()[0]
    )
    return row["min_ts"], row["max_ts"]


def load_interaction_source(min_ts, max_ts):
    dynamic_min_ts = F.lit(min_ts).cast("timestamp") - F.expr(f"INTERVAL {SCAN_DAYS_BEFORE} DAYS")
    dynamic_max_ts = F.lit(max_ts).cast("timestamp") + F.expr(f"INTERVAL {SCAN_DAYS_AFTER} DAYS")
    hard_start_ts = F.to_timestamp(F.lit(FLOW_HARD_START_DATE))

    df = (
        spark.table(FLOW_TABLE)
        .select(
            F.get_json_object("payload", "$.interaction.mqsQuoteId").alias("interaction_mqsQuoteId"),
            F.get_json_object("payload", "$.interaction._id").alias("interaction_interactionId"),
            F.get_json_object("payload", "$.interaction.status").alias("interaction_status"),
            F.get_json_object("payload", "$.eventType").alias("interaction_eventType"),
            F.get_json_object("payload", "$.interaction.process").alias("interaction_process"),
            F.get_json_object("interactionmessage", "$.agreementNumber").alias("interaction_agreementNumber"),
            F.get_json_object("payload", "$.timestamp").alias("interaction_eventTimestamp"),
            F.get_json_object("payload", "$.interaction.factors.rateDate").alias("interaction_rateDate"),
            F.get_json_object("payload", "$.interaction.factors.quoteDate").alias("interaction_quoteDate"),
            F.get_json_object("payload", "$.interaction.factors.originalQuoteDate").alias("interaction_originalQuoteDate"),
            F.get_json_object("payload", "$.interaction.factors.inceptionDate").alias("interaction_inceptionDate"),
            F.get_json_object("payload", "$.interaction.updatedOn").alias("interaction_updatedOn"),
            F.get_json_object("payload", "$.interaction.createdOn").alias("interaction_createdOn"),
            F.to_timestamp("writeTimestamp").alias("interaction_writeTimestamp"),
            F.to_timestamp("eHubQueuedDatestamp").alias("interaction_eHubQueuedDatestamp"),
            F.to_timestamp("TimeEnqueued").alias("interaction_TimeEnqueued")
        )
        .filter(
            F.col("interaction_interactionId").isNotNull() &
            F.col("interaction_TimeEnqueued").isNotNull() &
            F.col("interaction_eHubQueuedDatestamp").isNotNull()
        )
        .filter(F.col("interaction_eHubQueuedDatestamp") >= hard_start_ts)
        .filter(F.col("interaction_TimeEnqueued").between(dynamic_min_ts, dynamic_max_ts))
        .withColumn(
            "interaction_process_code",
            F.when(F.lower(F.col("interaction_process")).like("mta%"), "30")
             .when(F.lower(F.col("interaction_process")).like("nb%"), "02")
             .when(F.lower(F.col("interaction_process")).like("renewal%"), "08")
             .when(F.lower(F.col("interaction_process")).like("support%"), "30")
        )
        .withColumn(
            "interaction_segment",
            F.when(F.col("interaction_mqsQuoteId").isNull(), "POLARIS_OR_NON_MQS")
             .otherwise("MQS_LINKED")
        )
        .filter(F.col("interaction_process_code").isNotNull())
    )

    return dedupe_df(
        df,
        [
            "interaction_interactionId",
            "interaction_mqsQuoteId",
            "interaction_TimeEnqueued",
            "interaction_process_code",
            "interaction_segment"
        ],
        [
            F.col("interaction_eHubQueuedDatestamp").desc(),
            F.col("interaction_writeTimestamp").desc_nulls_last()
        ]
    )


def build_forward_reconciliation(csv_df, interaction_df):
    c = csv_df.alias("c")
    i = interaction_df.alias("i")

    join_condition = (
        (F.col("c.interactionId") == F.col("i.interaction_interactionId")) &
        (F.col("c.transactionCode") == F.col("i.interaction_process_code")) &
        F.col("i.interaction_TimeEnqueued").between(
            F.col("c.requestTimestamp") - F.expr(f"INTERVAL {SCAN_DAYS_BEFORE} DAYS"),
            F.col("c.requestTimestamp") + F.expr(f"INTERVAL {SCAN_DAYS_AFTER} DAYS")
        ) &
        (
            (
                (F.col("c.csv_segment") == "MQS_LINKED") &
                (F.col("i.interaction_segment") == "MQS_LINKED") &
                (F.col("c.mqsQuoteId") == F.col("i.interaction_mqsQuoteId"))
            ) |
            (
                (F.col("c.csv_segment") == "POLARIS_OR_NON_MQS") &
                (F.col("i.interaction_segment") == "POLARIS_OR_NON_MQS")
            )
        )
    )

    joined = (
        c.join(i, join_condition, "left")
        .select(
            F.col("c.interactionId").alias("csv_interactionId"),
            F.col("c.mqsQuoteId").alias("csv_mqsQuoteId"),
            F.col("c.requestDate").alias("csv_requestDate"),
            F.col("c.requestTime").alias("csv_requestTime"),
            F.col("c.requestTimestamp").alias("csv_requestTimestamp"),
            F.col("c.csv_transactionType"),
            F.col("c.transactionCode").alias("csv_transactionCode"),
            F.col("c.product").alias("csv_product"),
            F.col("c.csv_segment"),
            F.col("c.run_type"),

            F.col("i.interaction_interactionId"),
            F.col("i.interaction_mqsQuoteId"),
            F.col("i.interaction_status"),
            F.col("i.interaction_eventType"),
            F.col("i.interaction_process"),
            F.col("i.interaction_process_code"),
            F.col("i.interaction_segment"),
            F.col("i.interaction_agreementNumber"),
            F.col("i.interaction_eventTimestamp"),
            F.col("i.interaction_rateDate"),
            F.col("i.interaction_quoteDate"),
            F.col("i.interaction_originalQuoteDate"),
            F.col("i.interaction_inceptionDate"),
            F.col("i.interaction_updatedOn"),
            F.col("i.interaction_createdOn"),
            F.col("i.interaction_writeTimestamp"),
            F.col("i.interaction_eHubQueuedDatestamp"),
            F.col("i.interaction_TimeEnqueued")
        )
    )

    joined = calculate_time_diff(joined, "csv_requestTimestamp", "interaction_TimeEnqueued")

    w = Window.partitionBy(
        "csv_interactionId",
        "csv_mqsQuoteId",
        "csv_requestTimestamp",
        "csv_transactionCode",
        "csv_segment"
    ).orderBy(
        F.when(F.col("interaction_TimeEnqueued").isNull(), 1).otherwise(0),
        F.abs(F.unix_timestamp("interaction_TimeEnqueued") - F.unix_timestamp("csv_requestTimestamp")),
        F.col("interaction_eHubQueuedDatestamp").asc_nulls_last()
    )

    return (
        joined.withColumn("rn", F.row_number().over(w))
        .filter("rn = 1")
        .drop("rn")
        .withColumn("reconciliation_direction", F.lit("FORWARD"))
        .withColumn("match_flag", F.when(F.col("interaction_TimeEnqueued").isNotNull(), "Y").otherwise("N"))
        .withColumn(
            "recon_status",
            F.when(F.col("interaction_TimeEnqueued").isNotNull(), "MATCHED_IN_INTERACTION")
             .otherwise("MISSING_IN_INTERACTION")
        )
        .withColumn("recon_requestDate", F.col("csv_requestDate"))
        .withColumn("run_ts", F.current_timestamp())
    )


def build_reverse_reconciliation(csv_df, interaction_df):
    c = csv_df.alias("c")
    i = interaction_df.alias("i")

    join_condition = (
        (F.col("i.interaction_interactionId") == F.col("c.interactionId")) &
        (F.col("i.interaction_process_code") == F.col("c.transactionCode")) &
        F.col("c.requestTimestamp").between(
            F.col("i.interaction_TimeEnqueued") - F.expr(f"INTERVAL {SCAN_DAYS_BEFORE} DAYS"),
            F.col("i.interaction_TimeEnqueued") + F.expr(f"INTERVAL {SCAN_DAYS_AFTER} DAYS")
        ) &
        (
            (
                (F.col("i.interaction_segment") == "MQS_LINKED") &
                (F.col("c.csv_segment") == "MQS_LINKED") &
                (F.col("i.interaction_mqsQuoteId") == F.col("c.mqsQuoteId"))
            ) |
            (
                (F.col("i.interaction_segment") == "POLARIS_OR_NON_MQS") &
                (F.col("c.csv_segment") == "POLARIS_OR_NON_MQS")
            )
        )
    )

    joined = (
        i.join(c, join_condition, "left")
        .select(
            F.col("c.interactionId").alias("csv_interactionId"),
            F.col("c.mqsQuoteId").alias("csv_mqsQuoteId"),
            F.col("c.requestDate").alias("csv_requestDate"),
            F.col("c.requestTime").alias("csv_requestTime"),
            F.col("c.requestTimestamp").alias("csv_requestTimestamp"),
            F.col("c.csv_transactionType"),
            F.col("c.transactionCode").alias("csv_transactionCode"),
            F.col("c.product").alias("csv_product"),
            F.col("c.csv_segment"),
            F.col("c.run_type"),

            F.col("i.interaction_interactionId"),
            F.col("i.interaction_mqsQuoteId"),
            F.col("i.interaction_status"),
            F.col("i.interaction_eventType"),
            F.col("i.interaction_process"),
            F.col("i.interaction_process_code"),
            F.col("i.interaction_segment"),
            F.col("i.interaction_agreementNumber"),
            F.col("i.interaction_eventTimestamp"),
            F.col("i.interaction_rateDate"),
            F.col("i.interaction_quoteDate"),
            F.col("i.interaction_originalQuoteDate"),
            F.col("i.interaction_inceptionDate"),
            F.col("i.interaction_updatedOn"),
            F.col("i.interaction_createdOn"),
            F.col("i.interaction_writeTimestamp"),
            F.col("i.interaction_eHubQueuedDatestamp"),
            F.col("i.interaction_TimeEnqueued")
        )
    )

    joined = calculate_time_diff(joined, "interaction_TimeEnqueued", "csv_requestTimestamp")

    w = Window.partitionBy(
        "interaction_interactionId",
        "interaction_mqsQuoteId",
        "interaction_TimeEnqueued",
        "interaction_process_code",
        "interaction_segment"
    ).orderBy(
        F.when(F.col("csv_requestTimestamp").isNull(), 1).otherwise(0),
        F.abs(F.unix_timestamp("csv_requestTimestamp") - F.unix_timestamp("interaction_TimeEnqueued")),
        F.col("csv_requestTimestamp").asc_nulls_last()
    )

    return (
        joined.withColumn("rn", F.row_number().over(w))
        .filter("rn = 1")
        .drop("rn")
        .withColumn("reconciliation_direction", F.lit("REVERSE"))
        .withColumn("match_flag", F.when(F.col("csv_requestTimestamp").isNotNull(), "Y").otherwise("N"))
        .withColumn(
            "recon_status",
            F.when(F.col("csv_requestTimestamp").isNotNull(), "MATCHED_IN_CSV")
             .otherwise("MISSING_IN_CSV")
        )
        .withColumn(
            "recon_requestDate",
            F.coalesce(F.col("csv_requestDate"), F.to_date("interaction_TimeEnqueued"))
        )
        .withColumn("run_ts", F.current_timestamp())
    )


def write_target(final_df):
    is_first_run = final_df.filter(F.col("run_type") == "FIRST_RUN").limit(1).count() > 0

    if is_first_run or not spark.catalog.tableExists(TARGET_TABLE):
        (
            final_df.write
            .format("delta")
            .mode("overwrite")
            .partitionBy("recon_requestDate")
            .saveAsTable(TARGET_TABLE)
        )
        return

    final_df = final_df.dropDuplicates(MERGE_KEY_COLS)

    merge_condition = " AND ".join([
        f"t.{c} <=> s.{c}" for c in MERGE_KEY_COLS
    ])

    delta_target = DeltaTable.forName(spark, TARGET_TABLE)

    (
        delta_target.alias("t")
        .merge(final_df.alias("s"), merge_condition)
        .whenMatchedUpdateAll()
        .whenNotMatchedInsertAll()
        .execute()
    )


csv_df = load_csv_source()
min_ts, max_ts = get_csv_time_bounds(csv_df)

if min_ts is None or max_ts is None:
    print("No valid CSV rows found for this run. Skipping interaction reconciliation.")
else:
    interaction_df = load_interaction_source(min_ts, max_ts)

    forward_df = build_forward_reconciliation(csv_df, interaction_df)
    reverse_df = build_reverse_reconciliation(csv_df, interaction_df)

    final_df = forward_df.unionByName(reverse_df)

    write_target(final_df)

    print(f"Target table written successfully: {TARGET_TABLE}")
