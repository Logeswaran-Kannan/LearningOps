WITH csv_q AS (
    SELECT DISTINCT trim(mqsQuoteId) AS mqsQuoteId
    FROM core_bld.radar_live.reconciliation_csv_source
    WHERE mqsQuoteId IS NOT NULL
),
mqs_q AS (
    SELECT DISTINCT trim(headers['MQSQuoteId']) AS mqsQuoteId
    FROM core.mqs_athn_mtr.ehubstream
    WHERE headers['messageType'] = 'mqs-quote-request'
      AND headers['MQSQuoteId'] IS NOT NULL
)
SELECT
    count(*) AS csv_distinct_quoteids,
    sum(CASE WHEN m.mqsQuoteId IS NOT NULL THEN 1 ELSE 0 END) AS found_in_mqs,
    sum(CASE WHEN m.mqsQuoteId IS NULL THEN 1 ELSE 0 END) AS not_found_in_mqs
FROM csv_q c
LEFT JOIN mqs_q m
    ON upper(c.mqsQuoteId) = upper(m.mqsQuoteId);
