WITH csv_src AS (
    SELECT
        interactionId,
        mqsQuoteId,
        requestDate,
        requestTime,
        requestTimestamp,
        transactionType,
        transactionCode,
        product
    FROM core_bld.radar_live.reconcillation_csv_source
    WHERE mqsQuoteId IS NOT NULL
      AND interactionId IS NOT NULL
      AND requestTimestamp IS NOT NULL
),

mqs_src AS (
    SELECT
        headers['MQSQuoteId'] AS mqsQuoteId,
        headers['externalID'] AS externalID,
        enqueuedTime,
        eHubQueuedDatestamp,
        get_json_object(payload, '$.control.transactionType') AS transactionType_raw,

        CASE
            WHEN upper(get_json_object(payload, '$.control.transactionType')) LIKE 'NB%' THEN '02'
            WHEN upper(get_json_object(payload, '$.control.transactionType')) = 'RENEWAL' THEN '08'
            ELSE '30'
        END AS transactionCode
    FROM core.mqs_athena_mtr.ehubstream
    WHERE CAST(eHubQueuedDatestamp AS DATE) > '2026-01-30'
      AND headers['messageType'] = 'mqs-quote-request'
      AND headers['MQSQuoteId'] IS NOT NULL
      AND headers['externalID'] IS NOT NULL
      AND enqueuedTime IS NOT NULL
),

matched AS (
    SELECT
        c.interactionId,
        c.mqsQuoteId,
        c.requestDate,
        c.requestTime,
        c.requestTimestamp,
        c.transactionType AS csv_transactionType,
        c.transactionCode AS csv_transactionCode,
        c.product,

        m.externalID,
        m.enqueuedTime,
        m.eHubQueuedDatestamp,
        m.transactionType_raw AS mqs_transactionType,
        m.transactionCode AS mqs_transactionCode,

        /* signed difference in seconds */
        unix_timestamp(m.enqueuedTime) - unix_timestamp(c.requestTimestamp) AS diff_seconds,

        row_number() OVER (
            PARTITION BY c.interactionId, c.mqsQuoteId, c.requestTimestamp, c.transactionCode
            ORDER BY abs(unix_timestamp(m.enqueuedTime) - unix_timestamp(c.requestTimestamp))
        ) AS rn
    FROM csv_src c
    JOIN mqs_src m
      ON c.interactionId   = m.externalID
     AND c.mqsQuoteId      = m.mqsQuoteId
     AND c.transactionCode = m.transactionCode
)

SELECT
    interactionId,
    mqsQuoteId,
    requestDate,
    requestTime,
    requestTimestamp,
    csv_transactionType,
    csv_transactionCode,
    product,

    externalID,
    enqueuedTime,
    eHubQueuedDatestamp,
    mqs_transactionType,
    mqs_transactionCode,

    diff_seconds,

    /* signed differences */
    round(diff_seconds / 86400.0, 4) AS diff_days,
    round(diff_seconds / 3600.0, 4)  AS diff_hours,

    /* absolute differences */
    round(abs(diff_seconds) / 86400.0, 4) AS abs_diff_days,
    round(abs(diff_seconds) / 3600.0, 4)  AS abs_diff_hours,

    CASE
        WHEN diff_seconds > 0 THEN 'MQS after CSV'
        WHEN diff_seconds < 0 THEN 'MQS before CSV'
        ELSE 'Same timestamp'
    END AS diff_direction

FROM matched
WHERE rn = 1
ORDER BY abs(diff_seconds) DESC;
