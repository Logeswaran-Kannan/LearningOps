from pyspark.sql import functions as F
from pyspark.sql import DataFrame
from pyspark.sql.window import Window
from functools import reduce
import time
from datetime import datetime

# =========================================================
# CONFIG
# =========================================================

DIM_TABLE = "curated_idw_mtr_athn_mqs.dim_audit_rating_quote_permissions"
EHUBSTREAM_TABLE = "core.mqs_athn_mtr.ehubstream"
DLT_RAW_ENRICHMENTS_TABLE = "core.mqs_athn_mtr.dlt_raw_enrichments"
DLT_RATING_REQUEST_V2_TABLE = "core.mqs_athn_mtr.dlt_rating_request_v2"

KPI_TABLE = "core_bld.default.dvla_payload_monitor_kpi_daily"

LOOKBACK_DAYS = 180
ELIGIBILITY_DAYS = 60
EXCLUDED_JOURNEY = "Athena Motor Sale"

# =========================================================
# LOGGING
# =========================================================

JOB_START = time.perf_counter()

def log_line(message: str) -> None:
    now = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    total_elapsed = round(time.perf_counter() - JOB_START, 2)
    print(f"[{now}] {message} | total_elapsed_sec={total_elapsed}")

def log_step_start(step_name: str) -> float:
    log_line(f"START: {step_name}")
    return time.perf_counter()

def log_step_end(step_name: str, step_start: float) -> None:
    step_elapsed = round(time.perf_counter() - step_start, 2)
    total_elapsed = round(time.perf_counter() - JOB_START, 2)
    now = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    print(f"[{now}] END: {step_name} | step_elapsed_sec={step_elapsed} | total_elapsed_sec={total_elapsed}")

# =========================================================
# TARGET TABLE
# =========================================================

def create_target_table_if_not_exists() -> None:
    spark.sql(f"""
        CREATE TABLE IF NOT EXISTS {KPI_TABLE} (
            run_date DATE,
            enqueued_date DATE,
            table_name STRING,
            message_type STRING,
            eligible_quotes BIGINT,
            deleted_quotes BIGINT,
            retained_quotes BIGINT,
            partial_deletion_quotes BIGINT,
            not_found_in_target_quotes BIGINT,
            deletion_pct DOUBLE,
            created_ts TIMESTAMP
        )
        USING DELTA
        PARTITIONED BY (run_date)
    """)

def delete_today_partition() -> None:
    spark.sql(f"""
        DELETE FROM {KPI_TABLE}
        WHERE run_date = current_date()
    """)

# =========================================================
# ELIGIBLE QUOTES
# =========================================================

def get_eligible_quotes() -> DataFrame:
    base_df = (
        spark.table(DIM_TABLE)
        .select(
            F.col("MQS_QUOTE_ID").alias("mqs_quote_id"),
            F.to_date("DWH_DATA_DTS").alias("dwh_date"),
            F.col("DWH_CREATE_DTS").cast("timestamp").alias("dwh_create_dts"),
            F.col("LATEST_QUOTE_JOURNEY_DESC").alias("latest_quote_journey_desc")
        )
        .filter(F.col("mqs_quote_id").isNotNull())
        .filter(F.coalesce(F.col("latest_quote_journey_desc"), F.lit("")) != F.lit(EXCLUDED_JOURNEY))
        .filter(F.col("dwh_date").isNotNull())
        .filter(F.col("dwh_date") < F.date_sub(F.current_date(), ELIGIBILITY_DAYS))
    )

    w = Window.partitionBy("mqs_quote_id").orderBy(F.col("dwh_create_dts").desc_nulls_last())

    return (
        base_df
        .withColumn("rn", F.row_number().over(w))
        .filter(F.col("rn") == 1)
        .drop("rn")
        .select("mqs_quote_id")
    )

# =========================================================
# SOURCE TABLE PREP
# =========================================================

def get_ehubstream_base() -> DataFrame:
    base_df = (
        spark.table(EHUBSTREAM_TABLE)
        .select(
            F.col("headers")["MQSQuoteId"].alias("mqs_quote_id"),
            F.col("headers")["messageType"].alias("message_type"),
            F.col("payload"),
            F.col("enqueuedTime").cast("timestamp").alias("event_ts")
        )
        .filter(F.col("message_type").isin("mqs-quote-request", "rating-request"))
        .filter(F.to_date("event_ts") >= F.date_sub(F.current_date(), LOOKBACK_DAYS))
        .filter(F.col("mqs_quote_id").isNotNull())
    )

    payload_json = F.col("payload").cast("string")

    provider_array = F.transform(
        F.from_json(
            F.get_json_object(payload_json, "$.rawEnrichments"),
            "array<struct<provider:string>>"
        ),
        lambda x: x["provider"]
    )

    return (
        base_df
        .withColumn(
            "dvla_status",
            F.when(
                F.col("message_type") == "mqs-quote-request",
                F.when(F.array_contains(provider_array, "mylicence"), F.lit("present"))
                 .otherwise(F.lit("not_present"))
            ).when(
                F.col("message_type") == "rating-request",
                F.when(
                    F.get_json_object(
                        payload_json,
                        "$.root.ratingRequestMessage[0].myLicence[0].dln"
                    ).isNotNull(),
                    F.lit("present")
                ).otherwise(F.lit("not_present"))
            )
        )
        .withColumn("enqueued_date", F.to_date("event_ts"))
        .withColumn("table_name", F.lit("ehubstream"))
        .select("table_name", "mqs_quote_id", "message_type", "event_ts", "enqueued_date", "dvla_status")
    )

