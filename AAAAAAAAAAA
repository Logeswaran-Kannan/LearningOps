# =========================================================
# KPI BUILD
# =========================================================

def build_table_kpi(eligible_df: DataFrame, target_df: DataFrame, table_name: str) -> DataFrame:
    target_agg = (
        target_df.groupBy("table_name", "enqueued_date", "message_type", "mqs_quote_id")
        .agg(
            F.sum(F.when(F.col("dvla_status") == "present", 1).otherwise(0)).alias("present_row_count"),
            F.sum(F.when(F.col("dvla_status") == "not_present", 1).otherwise(0)).alias("not_present_row_count")
        )
    )

    classified = (
        target_agg.alias("t")
        .join(eligible_df.alias("e"), on="mqs_quote_id", how="left")
        .select(
            F.current_date().alias("run_date"),
            F.col("t.enqueued_date"),
            F.col("t.table_name"),
            F.col("t.message_type"),
            F.col("t.mqs_quote_id"),
            F.when(F.col("e.mqs_quote_id").isNotNull(), F.lit(1)).otherwise(F.lit(0)).alias("eligible_flag"),
            F.when(F.col("e.mqs_quote_id").isNull(), F.lit("NOT_ELIGIBLE"))
             .when((F.col("t.present_row_count") == 0) & (F.col("t.not_present_row_count") > 0), F.lit("DELETED"))
             .when((F.col("t.present_row_count") > 0) & (F.col("t.not_present_row_count") == 0), F.lit("RETAINED"))
             .when((F.col("t.present_row_count") > 0) & (F.col("t.not_present_row_count") > 0), F.lit("PARTIAL"))
             .otherwise(F.lit("UNKNOWN")).alias("monitor_status")
        )
    )

    return (
        classified
        .groupBy("run_date", "enqueued_date", "table_name", "message_type")
        .agg(
            F.countDistinct(F.when(F.col("eligible_flag") == 1, F.col("mqs_quote_id"))).alias("eligible_quotes"),
            F.countDistinct(F.when(F.col("monitor_status") == "DELETED", F.col("mqs_quote_id"))).alias("deleted_quotes"),
            F.countDistinct(F.when(F.col("monitor_status") == "RETAINED", F.col("mqs_quote_id"))).alias("retained_quotes"),
            F.countDistinct(F.when(F.col("monitor_status") == "PARTIAL", F.col("mqs_quote_id"))).alias("partial_deletion_quotes"),
            F.countDistinct(F.when((F.col("eligible_flag") == 1) & (F.col("monitor_status") == "UNKNOWN"), F.col("mqs_quote_id"))).alias("not_found_in_target_quotes")
        )
        .withColumn(
            "deletion_pct",
            F.round(
                F.when(
                    F.col("eligible_quotes") > 0,
                    (F.col("deleted_quotes") * F.lit(100.0)) / F.col("eligible_quotes")
                ).otherwise(F.lit(None).cast("double")),
                2
            ).cast("double")
        )
        .withColumn("created_ts", F.current_timestamp().cast("timestamp"))
    )

def write_kpi(df: DataFrame) -> None:
    (
        df.withColumn("created_ts", F.col("created_ts").cast("timestamp"))
          .withColumn("deletion_pct", F.col("deletion_pct").cast("double"))
          .write
          .mode("append")
          .saveAsTable(KPI_TABLE)
    )

# =========================================================
# MAIN
# =========================================================

def main():
    s = log_step_start("Create KPI table")
    create_target_table_if_not_exists()
    log_step_end("Create KPI table", s)

    s = log_step_start("Delete today's KPI partition")
    delete_today_partition()
    log_step_end("Delete today's KPI partition", s)

    s = log_step_start("Build eligible quotes")
    eligible_df = get_eligible_quotes()
    log_step_end("Build eligible quotes", s)

    s = log_step_start("Build ehubstream KPI")
    ehub_kpi = build_table_kpi(eligible_df, get_ehubstream_base(), "ehubstream")
    write_kpi(ehub_kpi)
    log_step_end("Build ehubstream KPI", s)

    s = log_step_start("Build dlt_raw_enrichments KPI")
    raw_kpi = build_table_kpi(eligible_df, get_dlt_raw_enrichments_base(), "dlt_raw_enrichments")
    write_kpi(raw_kpi)
    log_step_end("Build dlt_raw_enrichments KPI", s)

    s = log_step_start("Build dlt_rating_request_v2 KPI")
    rating_kpi = build_table_kpi(eligible_df, get_dlt_rating_request_v2_base(), "dlt_rating_request_v2")
    write_kpi(rating_kpi)
    log_step_end("Build dlt_rating_request_v2 KPI", s)

    log_line("JOB COMPLETED SUCCESSFULLY")

main()
