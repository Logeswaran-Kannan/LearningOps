"""
diagnose_reconciliation.py
===========================
Run this BEFORE the full reconciliation script to find exactly where rows
are being lost. It prints counts + samples at every stage, for every catalog.
"""

from pyspark.sql import SparkSession, functions as F

spark = SparkSession.builder.appName("ReconDiagnostics").getOrCreate()

SCHEMA = "ods_views"
CATALOGS = ["core", "core_tst", "core_tst_std001"]

SOURCE_SYSTEM_PREFIX = {
    "policycenter": "vw_policycenter_current_",
    "billingcenter": "vw_billingcenter_current_",
    "claimcenter": "vw_claimcenter_current_",
}
_PREFIX_ALTERNATION = "|".join(SOURCE_SYSTEM_PREFIX.values())
_NAME_PATTERN = rf"^({_PREFIX_ALTERNATION})(.+?)(_cda|_sa)?$"


def section(title):
    print("\n" + "=" * 80)
    print(title)
    print("=" * 80)


for catalog in CATALOGS:
    section(f"CATALOG: {catalog}")

    # --- Stage 0: can we even see the catalog / schema at all? ---
    try:
        schemas = spark.sql(f"SHOW SCHEMAS IN {catalog}").collect()
        schema_names = [r[0] for r in schemas]
        print(f"Schemas visible in {catalog}: {schema_names[:20]}"
              f"{' ...' if len(schema_names) > 20 else ''}")
        if SCHEMA not in schema_names and SCHEMA.lower() not in [s.lower() for s in schema_names]:
            print(f"  !! '{SCHEMA}' NOT found in schema list for {catalog}. "
                  f"Check spelling/case or permissions.")
    except Exception as e:
        print(f"  !! Could not run SHOW SCHEMAS on {catalog}: {e}")

    # --- Stage 1: raw information_schema.tables row count ---
    try:
        raw = spark.sql(f"""
            SELECT table_catalog, table_schema, table_name
            FROM {catalog}.information_schema.tables
            WHERE lower(table_schema) = lower('{SCHEMA}')
        """)
        raw_count = raw.count()
        print(f"\nStage 1 - raw information_schema.tables count (case-insensitive schema match): {raw_count}")
        if raw_count == 0:
            print("  !! ZERO rows here. This means either:")
            print("     - wrong catalog/schema name")
            print("     - you don't have SELECT/USE privileges on this catalog's information_schema")
            print("     - information_schema isn't populated for this catalog type "
                  "(e.g. it's a foreign/external catalog, not Unity Catalog managed)")
            # try SHOW TABLES as a fallback sanity check
            try:
                show_tbls = spark.sql(f"SHOW TABLES IN {catalog}.{SCHEMA}")
                st_count = show_tbls.count()
                print(f"  Fallback SHOW TABLES IN {catalog}.{SCHEMA} count: {st_count}")
                show_tbls.show(10, truncate=False)
            except Exception as e2:
                print(f"  Fallback SHOW TABLES also failed: {e2}")
            continue
        else:
            print("Sample table_name values (first 15):")
            raw.select("table_name").show(15, truncate=False)
    except Exception as e:
        print(f"  !! information_schema query failed entirely: {e}")
        continue

    # --- Stage 2: regex prefix match count ---
    enriched = (
        raw.withColumn("matched_prefix", F.regexp_extract("table_name", _NAME_PATTERN, 1))
        .withColumn("base_table_name", F.regexp_extract("table_name", _NAME_PATTERN, 2))
        .withColumn("suffix", F.regexp_extract("table_name", _NAME_PATTERN, 3))
    )
    matched_count = enriched.filter(F.col("matched_prefix") != "").count()
    print(f"\nStage 2 - rows matching source-system prefix regex: {matched_count} / {raw_count}")

    if matched_count == 0:
        print("  !! ZERO regex matches. Your naming pattern differs from what the script assumes.")
        print("     Assumed pattern: <prefix>_<base_name>[_cda|_sa]")
        print(f"     Prefixes tried: {list(SOURCE_SYSTEM_PREFIX.values())}")
        print("     Here are ALL table names in this schema so you can compare against the assumed prefixes:")
        raw.select("table_name").distinct().show(200, truncate=False)
        continue
    else:
        print("Sample matched rows (prefix / base_table_name / suffix):")
        enriched.filter(F.col("matched_prefix") != "").select(
            "table_name", "matched_prefix", "base_table_name", "suffix"
        ).show(20, truncate=False)

    # --- Stage 3: suffix distribution (to sanity-check _cda/_sa filtering) ---
    print("\nStage 3 - suffix distribution among matched rows:")
    enriched.filter(F.col("matched_prefix") != "").groupBy("suffix").count().show()

    # --- Stage 4: after catalog-specific suffix rule ---
    if catalog == "core_tst_std001":
        after_rule = enriched.filter(F.col("suffix") == "_cda")
        rule_desc = "keep only suffix == '_cda'"
    else:
        after_rule = enriched.filter(~F.col("suffix").isin("_cda", "_sa"))
        rule_desc = "exclude suffix in ('_cda','_sa')"

    after_count = after_rule.count()
    print(f"\nStage 4 - after catalog rule ({rule_desc}): {after_count}")
    if after_count == 0:
        print(f"  !! ZERO rows after applying the {catalog} suffix rule. "
              f"Look at the Stage 3 suffix distribution above -- "
              f"if everything in {catalog} has suffix '_cda' or '_sa' (or none does), "
              f"the rule may be inverted for your data, or the suffix isn't being captured "
              f"by the regex the way you expect.")
    else:
        after_rule.select("table_name", "base_table_name", "suffix").show(20, truncate=False)

section("DONE")
print("""
Common root causes for the full pipeline returning 0 rows, ranked by likelihood:

1. Schema name case mismatch (e.g. 'ODS_VIEWS' vs 'ods_views') or the schema
   living under a different catalog than expected -> Stage 1 will show 0.

2. Prefix assumption wrong -- e.g. actual names might be
   'vw_policycenter_current_p1_<name>' (extra char), or use a different
   separator, or the '_current_' segment differs per environment
   -> Stage 2 will show 0, and the full distinct table_name dump will reveal
   the real pattern.

3. The _cda/_sa filter rule inverted for your data -- e.g. core_tst_std001
   tables might not literally end in '_cda' (could be '_CDA', or a prefix
   like 'cda_' instead of a suffix) -> Stage 3/4 will show this clearly.

4. Privilege issue: you can list schemas but not read information_schema.tables
   rows (row-level ACLs / Unity Catalog permissions) -> Stage 1 exception or 0
   despite SHOW TABLES working.

Once you see which stage drops to 0, share that stage's output and I'll
adjust the regex / filter logic in the main script accordingly.
""")
