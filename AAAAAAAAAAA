def clean_value(value, max_len=80):
    if value is None:
        return ""
    s = str(value)
    s = s.replace("\n", " ").replace("\r", " ").replace("\t", " ")
    s = re.sub(r"[<>]", "", s)
    s = re.sub(r"\s+", " ", s).strip()
    return s if len(s) <= max_len else s[:max_len - 3] + "..."


def source_summary(items):
    counts = {}
    for r in items:
        src = clean_value(r.get("breach_source", "UNKNOWN"), 40)
        counts[src] = counts.get(src, 0) + 1
    return clean_value(", ".join([f"{k}: {v}" for k, v in counts.items()]), 120)


def comparison_line(items):
    if not items:
        return "Latest valid monitoring interval is within SLA."

    max_diff = max(abs(int(r.get("count_difference", 0) or 0)) for r in items)
    non_zero = sum(1 for r in items if int(r.get("count_difference", 0) or 0) != 0)

    return clean_value(
        f"Count comparison: {non_zero} impacted flow(s), max EHUB vs Bronze variance {max_diff}.",
        140
    )


def wrap_card(body):
    return {
        "type": "message",
        "attachments": [
            {
                "contentType": "application/vnd.microsoft.card.adaptive",
                "contentUrl": None,
                "content": {
                    "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
                    "type": "AdaptiveCard",
                    "version": "1.0",
                    "body": body
                }
            }
        ]
    }


