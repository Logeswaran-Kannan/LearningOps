# ---------- Per-brand breach / recovery alerts ----------
for brand in EXPECTED_BRANDS:
    print(f"\nProcessing brand: {brand}")

    rows             = get_breach_rows(brand)
    latest_interval  = get_latest_interval(brand)
    current_status   = "BREACH" if rows else "HEALTHY"
    previous_status  = read_previous_status(brand)
    payload          = None

    print(f"  Brand={brand} | Previous={previous_status} | Current={current_status}")

    if previous_status is None and current_status == "BREACH":
        print(f"  → First run breach detected for {brand}")
        payload = breach_card(rows, latest_interval, brand)

    elif previous_status == "HEALTHY" and current_status == "BREACH":
        print(f"  → New breach for {brand}")
        payload = breach_card(rows, latest_interval, brand)

    elif previous_status == "BREACH" and current_status == "HEALTHY":
        print(f"  → Recovery for {brand}")
        payload = healthy_card(latest_interval, brand)

    else:
        print(f"  → No status change for {brand} — no notification sent")

    if payload:
        send_webhook(payload)

    # Safe atomic state upsert per brand
    upsert_state(brand, current_status, latest_interval)
    print(f"  State updated: brand={brand} status={current_status} interval={latest_interval}")

