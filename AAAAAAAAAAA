SELECT
    source_system,
    table_name,
    in_core,
    in_core_tst,
    in_core_tst_std001,

    -- present in all three catalogs
    CASE WHEN in_core = 'Y' AND in_core_tst = 'Y' AND in_core_tst_std001 = 'Y'
         THEN 'Y' ELSE 'N' END AS present_in_all_three,

    -- only in production RR (core)
    CASE WHEN in_core = 'Y' AND in_core_tst = 'N' AND in_core_tst_std001 = 'N'
         THEN 'Y' ELSE 'N' END AS only_in_prod_rr,

    -- only in test RR (core_tst)
    CASE WHEN in_core = 'N' AND in_core_tst = 'Y' AND in_core_tst_std001 = 'N'
         THEN 'Y' ELSE 'N' END AS only_in_test_rr,

    -- only in CDA (core_tst_std001)
    CASE WHEN in_core = 'N' AND in_core_tst = 'N' AND in_core_tst_std001 = 'Y'
         THEN 'Y' ELSE 'N' END AS only_in_cda,

    -- present in prod RR + test RR, but missing in CDA
    CASE WHEN in_core = 'Y' AND in_core_tst = 'Y' AND in_core_tst_std001 = 'N'
         THEN 'Y' ELSE 'N' END AS in_prod_and_test_rr_missing_in_cda

FROM core.ods_recon.table_reconciliation_result
WHERE is_latest_for_day = 'Y'
ORDER BY source_system, table_name;
