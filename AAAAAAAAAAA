import json
import requests
from pyspark.sql import functions as F

WEBHOOK_URL = "YOUR_TEAMS_WEBHOOK_URL"
DASHBOARD_URL = "YOUR_DASHBOARD_URL"

STATE_TABLE = "core_bld.default.sla_alert_state"
ALERT_NAME = "radar_live_sla_monitor"

spark.sql(f"""
CREATE TABLE IF NOT EXISTS {STATE_TABLE} (
    alert_name STRING,
    current_status STRING,
    last_interval TIMESTAMP,
    last_notified_at TIMESTAMP
)
USING DELTA
""")

# =========================================================
# 1. VALIDATE INTERVALS
# =========================================================
validation_sql = """
WITH latest_mqs_interval AS (
    SELECT MAX(interval_end) AS mqs_interval
    FROM core_bld.default.monitoring_ehub_30min_metrics
    WHERE interval_end >= date_trunc('day', current_timestamp())
      AND message_type <> 'ALL'
),
interaction_expected_interval AS (
    SELECT mqs_interval - INTERVAL 30 MINUTES AS interaction_interval
    FROM latest_mqs_interval
),
ehub_check AS (
    SELECT COUNT(*) AS ehub_rows
    FROM core_bld.default.monitoring_ehub_30min_metrics
    WHERE interval_end = (SELECT mqs_interval FROM latest_mqs_interval)
      AND message_type <> 'ALL'
),
bronze_check AS (
    SELECT COUNT(*) AS bronze_rows
    FROM core_bld.default.monitoring_mqs_bronze_30min
    WHERE interval_end = (SELECT mqs_interval FROM latest_mqs_interval)
      AND message_type <> 'ALL'
),
interaction_check AS (
    SELECT COUNT(*) AS interaction_rows
    FROM core_bld.default.monitoring_mqs_interaction_status
    WHERE interval_start = (
        SELECT interaction_interval
        FROM interaction_expected_interval
    )
)
SELECT
    (SELECT mqs_interval FROM latest_mqs_interval) AS mqs_interval,
    (SELECT interaction_interval FROM interaction_expected_interval) AS interaction_interval,
    e.ehub_rows,
    b.bronze_rows,
    i.interaction_rows
FROM ehub_check e
CROSS JOIN bronze_check b
CROSS JOIN interaction_check i
"""

v = spark.sql(validation_sql).collect()[0]

mqs_interval = v["mqs_interval"]
interaction_interval = v["interaction_interval"]
ehub_rows = v["ehub_rows"]
bronze_rows = v["bronze_rows"]
interaction_rows = v["interaction_rows"]

is_valid_interval = (
    mqs_interval is not None
    and interaction_interval is not None
    and ehub_rows > 0
    and bronze_rows > 0
    and interaction_rows > 0
)

if not is_valid_interval:
    print("SKIPPED_INCOMPLETE_INTERVAL")
    print(f"MQS interval        : {mqs_interval}")
    print(f"Interaction interval: {interaction_interval}")
    print(f"EHUB rows           : {ehub_rows}")
    print(f"Bronze rows         : {bronze_rows}")
    print(f"Interaction rows    : {interaction_rows}")
    dbutils.notebook.exit("SKIPPED_INCOMPLETE_INTERVAL")


# =========================================================
# 2. BREACH QUERY
# =========================================================
breach_sql = f"""
WITH ehub_latest AS (
    SELECT
        run_date,
        interval_end,
        message_type AS message_type_link,
        message_count AS ehub_count,
        is_sla_breach AS ehub_sla
    FROM core_bld.default.monitoring_ehub_30min_metrics
    WHERE message_type <> 'ALL'
      AND interval_end = TIMESTAMP('{mqs_interval}')
),
bronze_latest AS (
    SELECT
        CASE
            WHEN message_type = 'dlt_quote_request' THEN 'mqs-quote-request'
            WHEN message_type = 'dlt_precomp_response' THEN 'precomp-response'
            WHEN message_type = 'dlt_rating_request' THEN 'rating-request'
            WHEN message_type = 'dlt_rating_response' THEN 'rating-response'
            WHEN message_type = 'dlt_cache_id' THEN 'quote-cache-id'
            WHEN message_type = 'dlt_stop_quote' THEN 'stop-quote'
            WHEN message_type = 'dlt_rating_request_dvla_removed' THEN 'dlt_rating_request_dvla_removed'
            WHEN message_type = 'dlt_raw_enrichments' THEN 'dlt_raw_enrichments'
            ELSE 'others'
        END AS message_type_link,
        interval_end,
        message_count,
        is_sla_flag
    FROM core_bld.default.monitoring_mqs_bronze_30min
    WHERE message_type <> 'ALL'
      AND interval_end = TIMESTAMP('{mqs_interval}')
),
interaction_expected AS (
    SELECT
        interval_start,
        SUM(total_count) AS total_interaction_count
    FROM core_bld.default.monitoring_mqs_interaction_status
    WHERE interval_start = TIMESTAMP('{interaction_interval}')
    GROUP BY interval_start
),
final_status AS (
    SELECT
        e.run_date,
        e.interval_end,
        e.message_type_link,
        e.ehub_count,
        e.ehub_sla,
        COALESCE(b.message_count, 0) AS bronze_count,
        COALESCE(b.is_sla_flag, 0) AS bronze_sla,
        e.ehub_count - COALESCE(b.message_count, 0) AS count_difference,
        ABS(e.ehub_count - COALESCE(b.message_count, 0)) AS abs_count_difference,
        CASE
            WHEN e.ehub_sla = 1 AND COALESCE(b.is_sla_flag, 0) = 1 THEN '⚠ EHUB & BRONZE'
            WHEN e.ehub_sla = 1 THEN '⚠ EHUB'
            WHEN COALESCE(b.is_sla_flag, 0) = 1 THEN '⚠ BRONZE'
            WHEN COALESCE(i.total_interaction_count, 0) = 0 THEN '🛠 INTERACTION'
        END AS breach_source
    FROM ehub_latest e
    LEFT JOIN bronze_latest b
        ON e.message_type_link = b.message_type_link
       AND e.interval_end = b.interval_end
    LEFT JOIN interaction_expected i
        ON 1 = 1
)
SELECT *
FROM final_status
WHERE
       ehub_sla = 1
    OR bronze_sla = 1
    OR breach_source = '🛠 INTERACTION'
ORDER BY abs_count_difference DESC, message_type_link
"""

rows = [r.asDict() for r in spark.sql(breach_sql).collect()]
current_status = "BREACH" if rows else "HEALTHY"
current_interval = mqs_interval


# =========================================================
# 3. READ PREVIOUS STATE
# =========================================================
state_rows = (
    spark.table(STATE_TABLE)
    .filter(F.col("alert_name") == ALERT_NAME)
    .collect()
)

previous_status = None
previous_interval = None

if state_rows:
    previous_status = state_rows[0]["current_status"]
    previous_interval = state_rows[0]["last_interval"]


# =========================================================
# 4. CARD HELPERS
# =========================================================
def safe_text(value, max_len=22):
    s = "" if value is None else str(value)
    return s if len(s) <= max_len else s[:max_len - 3] + "..."


def source_summary(items):
    counts = {}
    for r in items:
        src = str(r.get("breach_source", "UNKNOWN"))
        counts[src] = counts.get(src, 0) + 1
    return ", ".join([f"{k}: {v}" for k, v in counts.items()])


def comparison_line(items):
    if not items:
        return "Latest valid monitoring interval is within SLA."

    max_diff = max(abs(int(r.get("count_difference", 0))) for r in items)
    non_zero = sum(1 for r in items if int(r.get("count_difference", 0)) != 0)

    return (
        f"Count comparison shows {non_zero} impacted flow(s), "
        f"maximum EHUB vs Bronze variance: {max_diff}."
    )


def wrap_card(body):
    return {
        "type": "message",
        "attachments": [
            {
                "contentType": "application/vnd.microsoft.card.adaptive",
                "content": {
                    "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
                    "type": "AdaptiveCard",
                    "version": "1.2",
                    "body": body
                }
            }
        ]
    }


def breach_card(items):
    body = [
        {
            "type": "Container",
            "style": "attention",
            "items": [
                {
                    "type": "TextBlock",
                    "text": "⚠ SLA BREACH DETECTED",
                    "weight": "Bolder",
                    "size": "Large",
                    "wrap": True
                },
                {
                    "type": "TextBlock",
                    "text": "Radar Live production monitoring has detected a pipeline health issue requiring immediate review.",
                    "wrap": True,
                    "size": "Small",
                    "spacing": "Small"
                }
            ]
        },
        {
            "type": "FactSet",
            "spacing": "Medium",
            "facts": [
                {"title": "Environment", "value": "Production"},
                {"title": "MQS Interval", "value": str(mqs_interval)},
                {"title": "Interaction Interval", "value": str(interaction_interval)},
                {"title": "Impacted Flows", "value": str(len(items))},
                {"title": "Affected Areas", "value": source_summary(items)[:120]},
                {"title": "Severity", "value": "High"}
            ]
        },
        {
            "type": "TextBlock",
            "text": comparison_line(items),
            "wrap": True,
            "size": "Small",
            "spacing": "Small"
        },
        {
            "type": "TextBlock",
            "text": "Impact Summary",
            "weight": "Bolder",
            "spacing": "Medium"
        },
        {
            "type": "ColumnSet",
            "separator": True,
            "columns": [
                {"type": "Column", "width": 3, "items": [{"type": "TextBlock", "text": "Message Type", "weight": "Bolder", "size": "Small"}]},
                {"type": "Column", "width": 1, "items": [{"type": "TextBlock", "text": "EHUB", "weight": "Bolder", "size": "Small", "horizontalAlignment": "Center"}]},
                {"type": "Column", "width": 1, "items": [{"type": "TextBlock", "text": "Bronze", "weight": "Bolder", "size": "Small", "horizontalAlignment": "Center"}]},
                {"type": "Column", "width": 1, "items": [{"type": "TextBlock", "text": "Diff", "weight": "Bolder", "size": "Small", "horizontalAlignment": "Center"}]},
                {"type": "Column", "width": 2, "items": [{"type": "TextBlock", "text": "Source", "weight": "Bolder", "size": "Small"}]}
            ]
        }
    ]

    for r in items:
        body.append({
            "type": "ColumnSet",
            "separator": True,
            "spacing": "Small",
            "columns": [
                {"type": "Column", "width": 3, "items": [{"type": "TextBlock", "text": safe_text(r["message_type_link"]), "wrap": True, "size": "Small"}]},
                {"type": "Column", "width": 1, "items": [{"type": "TextBlock", "text": str(r["ehub_count"]), "horizontalAlignment": "Center", "size": "Small"}]},
                {"type": "Column", "width": 1, "items": [{"type": "TextBlock", "text": str(r["bronze_count"]), "horizontalAlignment": "Center", "size": "Small"}]},
                {"type": "Column", "width": 1, "items": [{"type": "TextBlock", "text": str(r["count_difference"]), "horizontalAlignment": "Center", "size": "Small"}]},
                {"type": "Column", "width": 2, "items": [{"type": "TextBlock", "text": str(r["breach_source"]), "wrap": True, "size": "Small"}]}
            ]
        })

    body.extend([
        {
            "type": "TextBlock",
            "text": f"Dashboard: {DASHBOARD_URL}",
            "wrap": True,
            "size": "Small",
            "isSubtle": True,
            "spacing": "Medium"
        },
        {
            "type": "TextBlock",
            "text": "🛠 Please review affected flows and validate upstream/downstream processing.",
            "wrap": True,
            "size": "Small"
        }
    ])

    return wrap_card(body)


def recovery_card():
    body = [
        {
            "type": "Container",
            "style": "good",
            "items": [
                {
                    "type": "TextBlock",
                    "text": "✅ RETURNED TO NORMAL",
                    "weight": "Bolder",
                    "size": "Large",
                    "wrap": True
                },
                {
                    "type": "TextBlock",
                    "text": "Radar Live monitoring confirms the service flow is now operating within SLA.",
                    "wrap": True,
                    "size": "Small",
                    "spacing": "Small"
                }
            ]
        },
        {
            "type": "FactSet",
            "spacing": "Medium",
            "facts": [
                {"title": "Environment", "value": "Production"},
                {"title": "Recovered At", "value": str(current_interval)},
                {"title": "Interaction Checked", "value": str(interaction_interval)},
                {"title": "Status", "value": "Healthy"},
                {"title": "Verification", "value": "Latest valid interval has no active breach"}
            ]
        },
        {
            "type": "TextBlock",
            "text": "EHUB, Bronze and Interaction monitoring are now within expected SLA checks for the latest valid cycle.",
            "wrap": True,
            "size": "Small",
            "spacing": "Small"
        },
        {
            "type": "TextBlock",
            "text": f"Dashboard: {DASHBOARD_URL}",
            "wrap": True,
            "size": "Small",
            "isSubtle": True,
            "spacing": "Medium"
        }
    ]

    return wrap_card(body)


# =========================================================
# 5. SEND ONLY ON STATUS CHANGE
# =========================================================
payload = None

if previous_status is None:
    if current_status == "BREACH":
        payload = breach_card(rows)

elif previous_status == "HEALTHY" and current_status == "BREACH":
    payload = breach_card(rows)

elif (
    previous_status == "BREACH"
    and current_status == "HEALTHY"
    and previous_interval is not None
    and current_interval > previous_interval
):
    payload = recovery_card()


if payload:
    response = requests.post(
        WEBHOOK_URL,
        headers={"Content-Type": "application/json"},
        data=json.dumps(payload),
        timeout=30
    )

    print("HTTP status:", response.status_code)
    print("Response text:", response.text)
    response.raise_for_status()

else:
    print(
        f"No notification sent. "
        f"Previous={previous_status}, Current={current_status}, "
        f"PreviousInterval={previous_interval}, CurrentInterval={current_interval}"
    )


# =========================================================
# 6. UPDATE STATE ONLY FOR VALID INTERVAL
# =========================================================
spark.sql(f"DELETE FROM {STATE_TABLE} WHERE alert_name = '{ALERT_NAME}'")

spark.createDataFrame(
    [(ALERT_NAME, current_status, current_interval)],
    ["alert_name", "current_status", "last_interval"]
).withColumn(
    "last_notified_at", F.current_timestamp()
).write.mode("append").saveAsTable(STATE_TABLE)

print(f"State updated: {current_status}, interval={current_interval}")
