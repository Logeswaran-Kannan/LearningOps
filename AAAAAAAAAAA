# =========================================================
# STEP 3 - AGGREGATED CLASSIFICATION
# =========================================================

def build_monitor_detail_aggregated(eligible_df: DataFrame, target_df: DataFrame, table_name: str) -> DataFrame:
    target_agg = (
        target_df.groupBy("mqs_quote_id", "message_type")
        .agg(
            F.count("*").alias("target_row_count"),
            F.sum(F.when(F.col("dvla_status") == "present", 1).otherwise(0)).alias("present_row_count"),
            F.sum(F.when(F.col("dvla_status") == "not_present", 1).otherwise(0)).alias("not_present_row_count"),
            F.max(F.col("event_ts").cast("timestamp")).alias("event_ts"),
            F.max(F.col("event_date").cast("timestamp")).alias("event_date")
        )
    )

    eligible_side = (
        eligible_df.alias("e")
        .join(target_agg.alias("t"), on="mqs_quote_id", how="left")
        .select(
            F.col("e.run_date"),
            F.lit(table_name).alias("table_name"),
            F.col("t.message_type"),
            F.col("e.mqs_quote_id"),
            F.col("e.quote_ref"),
            F.col("e.dwh_date"),
            F.col("e.dwh_create_dts").cast("timestamp").alias("dwh_create_dts"),
            F.col("e.latest_quote_journey_desc"),
            F.col("e.days_from_dwh"),
            F.col("e.eligible_flag"),
            F.col("t.target_row_count"),
            F.col("t.present_row_count"),
            F.col("t.not_present_row_count"),
            F.col("t.event_ts").cast("timestamp").alias("event_ts"),
            F.col("t.event_date").cast("timestamp").alias("event_date"),
            F.when(F.col("t.target_row_count").isNull(), F.lit("NOT_FOUND_IN_TARGET"))
             .when((F.col("t.present_row_count") == 0) & (F.col("t.not_present_row_count") > 0), F.lit("ELIGIBLE_DELETED_ALL"))
             .when((F.col("t.present_row_count") > 0) & (F.col("t.not_present_row_count") == 0), F.lit("ELIGIBLE_RETAINED_ALL"))
             .when((F.col("t.present_row_count") > 0) & (F.col("t.not_present_row_count") > 0), F.lit("ELIGIBLE_PARTIAL_DELETION"))
             .otherwise(F.lit("UNKNOWN")).alias("monitor_status"),
            F.current_timestamp().cast("timestamp").alias("checked_ts")
        )
    )

    orphan_side = (
        target_agg.alias("t")
        .join(eligible_df.alias("e"), on="mqs_quote_id", how="leftanti")
        .select(
            F.current_date().alias("run_date"),
            F.lit(table_name).alias("table_name"),
            F.col("t.message_type"),
            F.col("t.mqs_quote_id"),
            F.lit(None).cast("string").alias("quote_ref"),
            F.lit(None).cast("date").alias("dwh_date"),
            F.lit(None).cast("timestamp").alias("dwh_create_dts"),
            F.lit(None).cast("string").alias("latest_quote_journey_desc"),
            F.lit(None).cast("int").alias("days_from_dwh"),
            F.lit(0).alias("eligible_flag"),
            F.col("t.target_row_count"),
            F.col("t.present_row_count"),
            F.col("t.not_present_row_count"),
            F.col("t.event_ts").cast("timestamp").alias("event_ts"),
            F.col("t.event_date").cast("timestamp").alias("event_date"),
            F.when(F.col("t.present_row_count") > 0, F.lit("ORPHAN_PRESENT"))
             .otherwise(F.lit("ORPHAN_NOT_PRESENT")).alias("monitor_status"),
            F.current_timestamp().cast("timestamp").alias("checked_ts")
        )
    )

    return safe_union([eligible_side, orphan_side])

def write_detail_append(df: DataFrame) -> None:
    final_df = (
        df.withColumn("dwh_create_dts", F.col("dwh_create_dts").cast("timestamp"))
          .withColumn("event_ts", F.col("event_ts").cast("timestamp"))
          .withColumn("event_date", F.col("event_date").cast("timestamp"))
          .withColumn("checked_ts", F.col("checked_ts").cast("timestamp"))
    )

    (
        final_df.write
        .mode("append")
        .saveAsTable(DETAIL_TABLE)
    )

# =========================================================
# STEP 4 - SUMMARY
# =========================================================

def build_summary(detail_df: DataFrame) -> DataFrame:
    return (
        detail_df.groupBy("run_date", "table_name", "message_type")
        .agg(
            F.countDistinct(F.when(F.col("eligible_flag") == 1, F.col("mqs_quote_id"))).alias("eligible_quotes"),
            F.countDistinct(F.when(F.col("monitor_status") == "ELIGIBLE_DELETED_ALL", F.col("mqs_quote_id"))).alias("deleted_all_quotes"),
            F.countDistinct(F.when(F.col("monitor_status") == "ELIGIBLE_RETAINED_ALL", F.col("mqs_quote_id"))).alias("retained_all_quotes"),
            F.countDistinct(F.when(F.col("monitor_status") == "ELIGIBLE_PARTIAL_DELETION", F.col("mqs_quote_id"))).alias("partial_deletion_quotes"),
            F.countDistinct(F.when(F.col("monitor_status") == "NOT_FOUND_IN_TARGET", F.col("mqs_quote_id"))).alias("not_found_in_target_quotes"),
            F.countDistinct(F.when(F.col("monitor_status") == "ORPHAN_PRESENT", F.col("mqs_quote_id"))).alias("orphan_present_quotes"),
            F.countDistinct(F.when(F.col("monitor_status") == "ORPHAN_NOT_PRESENT", F.col("mqs_quote_id"))).alias("orphan_not_present_quotes"),
            F.max("days_from_dwh").alias("max_days_from_dwh"),
            F.avg("days_from_dwh").alias("avg_days_from_dwh")
        )
        .withColumn(
            "deletion_pct",
            F.round(
                F.when(
                    F.col("eligible_quotes") > 0,
                    (F.col("deleted_all_quotes") * F.lit(100.0)) / F.col("eligible_quotes")
                ),
                2
            )
        )
        .withColumn("created_ts", F.current_timestamp().cast("timestamp"))
    )

def write_summary_append(df: DataFrame) -> None:
    final_df = df.withColumn("created_ts", F.col("created_ts").cast("timestamp"))

    (
        final_df.write
        .mode("append")
        .saveAsTable(SUMMARY_TABLE)
    )

# =========================================================
# MAIN
# =========================================================

def main():
    s = log_step_start("Create target tables if not exist")
    create_target_tables_if_not_exist()
    log_step_end("Create target tables if not exist", s)

    s = log_step_start("Build eligible quotes")
    eligible_df = get_eligible_quotes()
    log_df_count(eligible_df, "eligible_df")
    write_eligible_snapshot(eligible_df)
    log_step_end("Build eligible quotes", s)

    s = log_step_start("Read today's eligible snapshot")
    eligible_today_df = read_today_eligible_snapshot()
    log_df_count(eligible_today_df, "eligible_today_df")
    log_step_end("Read today's eligible snapshot", s)

    s = log_step_start("Delete today's detail and summary partitions")
    delete_run_partition(DETAIL_TABLE)
    delete_run_partition(SUMMARY_TABLE)
    log_step_end("Delete today's detail and summary partitions", s)

    # ---------------- EHUBSTREAM ----------------
    s = log_step_start("Process ehubstream")
    ehub_df = get_ehubstream_base()
    log_df_count(ehub_df, "ehubstream_source_df")

    ehub_detail = build_monitor_detail_aggregated(eligible_today_df, ehub_df, "ehubstream")
    log_df_count(ehub_detail, "ehubstream_detail_df")

    write_detail_append(ehub_detail)
    log_step_end("Process ehubstream", s)

    # ---------------- DLT RAW ENRICHMENTS ----------------
    s = log_step_start("Process dlt_raw_enrichments")
    raw_enrichments_df = get_dlt_raw_enrichments_base()
    log_df_count(raw_enrichments_df, "dlt_raw_enrichments_source_df")

    raw_enrichments_detail = build_monitor_detail_aggregated(
        eligible_today_df,
        raw_enrichments_df,
        "dlt_raw_enrichments"
    )
    log_df_count(raw_enrichments_detail, "dlt_raw_enrichments_detail_df")

    write_detail_append(raw_enrichments_detail)
    log_step_end("Process dlt_raw_enrichments", s)

    # ---------------- DLT RATING REQUEST V2 ----------------
    s = log_step_start("Process dlt_rating_request_v2")
    rating_v2_df = get_dlt_rating_request_v2_base()
    log_df_count(rating_v2_df, "dlt_rating_request_v2_source_df")

    rating_v2_detail = build_monitor_detail_aggregated(
        eligible_today_df,
        rating_v2_df,
        "dlt_rating_request_v2"
    )
    log_df_count(rating_v2_detail, "dlt_rating_request_v2_detail_df")

    write_detail_append(rating_v2_detail)
    log_step_end("Process dlt_rating_request_v2", s)

    # ---------------- SUMMARY ----------------
    s = log_step_start("Build and write summary")
    detail_today_df = (
        spark.table(DETAIL_TABLE)
        .filter(F.col("run_date") == F.current_date())
    )
    log_df_count(detail_today_df, "detail_today_df")

    summary_df = build_summary(detail_today_df)
    log_df_count(summary_df, "summary_df")

    write_summary_append(summary_df)
    log_step_end("Build and write summary", s)

    total_elapsed = round(time.perf_counter() - JOB_START, 2)
    log_line(f"JOB COMPLETED SUCCESSFULLY | total_elapsed_sec={total_elapsed}")

main()
