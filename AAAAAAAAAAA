Dashboard SQL
All tables KPI
SELECT
    enqueued_date,
    table_name,
    deletion_type,
    message_type,
    eligible_quotes,
    deleted_quotes,
    retained_quotes,
    partial_deletion_quotes,
    deletion_pct
FROM core_bld.default.dvla_deletion_kpi_daily
ORDER BY enqueued_date DESC, table_name, message_type;
Table-wise combined KPI
SELECT
    enqueued_date,
    table_name,
    deletion_type,
    SUM(eligible_quotes) AS eligible_quotes,
    SUM(deleted_quotes) AS deleted_quotes,
    SUM(retained_quotes) AS retained_quotes,
    SUM(partial_deletion_quotes) AS partial_deletion_quotes,
    ROUND(100.0 * SUM(deleted_quotes) / NULLIF(SUM(eligible_quotes), 0), 2) AS deletion_pct
FROM core_bld.default.dvla_deletion_kpi_daily
GROUP BY enqueued_date, table_name, deletion_type
ORDER BY enqueued_date DESC, table_name;
mqs_mylicence only
SELECT
    enqueued_date,
    eligible_quotes,
    deleted_quotes,
    retained_quotes,
    deletion_pct
FROM core_bld.default.dvla_deletion_kpi_daily
WHERE table_name = 'mqs_mylicence'
ORDER BY enqueued_date DESC;
