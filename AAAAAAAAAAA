WITH base AS (
    SELECT
        POLICY_REF,
        CASE WHEN lower(TRNSCTN_DESC) LIKE '%new business%' THEN 1 ELSE 0 END AS nb_flag,
        CASE WHEN lower(TRNSCTN_DESC) LIKE '%renewal%' THEN 1 ELSE 0 END AS renewal_flag,
        CASE 
            WHEN lower(TRNSCTN_DESC) LIKE '%mid term%'
              OR lower(TRNSCTN_DESC) LIKE '%mta%'
              OR lower(TRNSCTN_DESC) LIKE '%adjustment%' 
            THEN 1 ELSE 0 
        END AS mta_flag,
        to_date(EFCTV_DTS) AS efctv_dt,
        MQS_QUOTE_ID
    FROM core.curated_idw_mtr_athn_mqs.dim_audit_rating_quote_permissions
    WHERE POLICY_REF IS NOT NULL
)

SELECT
    POLICY_REF,
    MAX(nb_flag) AS has_nb,
    MAX(renewal_flag) AS has_renewal,
    MAX(mta_flag) AS has_mta,
    COUNT(DISTINCT MQS_QUOTE_ID) AS distinct_quote_count,
    MIN(efctv_dt) AS first_efctv_dt,
    MAX(efctv_dt) AS latest_efctv_dt
FROM base
GROUP BY POLICY_REF
HAVING MAX(nb_flag) = 1
   AND (MAX(renewal_flag) = 1 OR MAX(mta_flag) = 1)
ORDER BY distinct_quote_count DESC
LIMIT 100;
