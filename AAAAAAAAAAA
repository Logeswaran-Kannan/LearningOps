# Databricks PySpark job
# DVLA Payload Deletion Monitor
# Covers:
#   1. ehubstream
#   2. dlt_raw_enrichments
#   3. dlt_rating_request_v2

from pyspark.sql import functions as F
from pyspark.sql import DataFrame
from functools import reduce

# =========================================================
# CONFIG
# =========================================================

DIM_TABLE = "curated_idw_mtr_athn_mqs.dim_audit_rating_quote_permissions"

EHUBSTREAM_TABLE = "core.mqs_athn_mtr.ehubstream"
DLT_RAW_ENRICHMENTS_TABLE = "core.mqs_athn_mtr.dlt_raw_enrichments"
DLT_RATING_REQUEST_V2_TABLE = "core.mqs_athn_mtr.dlt_rating_request_v2"

ELIGIBLE_SNAPSHOT_TABLE = "core_bld.radar_live.dvla_delete_eligible_quotes_daily"
DETAIL_TABLE = "core_bld.radar_live.dvla_payload_monitor_detail"
SUMMARY_TABLE = "core_bld.radar_live.dvla_payload_monitor_summary_daily"

LOOKBACK_DAYS = 180
ELIGIBILITY_DAYS = 60
EXCLUDED_JOURNEY = "Athena Motor Sale"

# =========================================================
# HELPERS
# =========================================================

def delete_run_partition(table_name: str) -> None:
    spark.sql(f"""
        DELETE FROM {table_name}
        WHERE run_date = current_date()
    """)

def safe_union(dfs: list[DataFrame]) -> DataFrame:
    valid_dfs = [df for df in dfs if df is not None]
    if not valid_dfs:
        raise ValueError("No DataFrames provided for union")
    return reduce(lambda x, y: x.unionByName(y, allowMissingColumns=True), valid_dfs)

# =========================================================
# STEP 1 - ELIGIBLE QUOTES
# =========================================================

def get_eligible_quotes() -> DataFrame:
    return (
        spark.table(DIM_TABLE)
        .select(
            F.col("MQS_QUOTE_ID").alias("mqs_quote_id"),
            F.col("QUOTE_REF").alias("quote_ref"),
            F.to_date("DWH_DATA_DTS").alias("dwh_date"),
            F.col("DWH_CREATE_DTS").alias("dwh_create_dts"),
            F.col("LATEST_QUOTE_JOURNEY_DESC").alias("latest_quote_journey_desc")
        )
        .filter(F.col("mqs_quote_id").isNotNull())
        .filter(F.coalesce(F.col("latest_quote_journey_desc"), F.lit("")) != F.lit(EXCLUDED_JOURNEY))
        .withColumn("days_from_dwh", F.datediff(F.current_date(), F.col("dwh_date")))
        .filter(F.col("days_from_dwh") > F.lit(ELIGIBILITY_DAYS))
        .withColumn("run_date", F.current_date())
        .withColumn("eligible_flag", F.lit(1))
        .dropDuplicates(["mqs_quote_id"])
    )

def write_eligible_snapshot(df: DataFrame) -> None:
    delete_run_partition(ELIGIBLE_SNAPSHOT_TABLE)
    (
        df.select(
            "run_date",
            "mqs_quote_id",
            "quote_ref",
            "dwh_date",
            "dwh_create_dts",
            "latest_quote_journey_desc",
            "days_from_dwh",
            "eligible_flag"
        )
        .write
        .mode("append")
        .saveAsTable(ELIGIBLE_SNAPSHOT_TABLE)
    )

# =========================================================
# STEP 2 - TABLE SPECIFIC DVLA CHECKS
# =========================================================

def get_ehubstream_base() -> DataFrame:
    base_df = (
        spark.table(EHUBSTREAM_TABLE)
        .select(
            F.col("headers")["MQSQuoteId"].alias("mqs_quote_id"),
            F.col("headers")["externalID"].alias("external_id"),
            F.col("headers")["messageType"].alias("message_type"),
            F.col("payload"),
            F.col("enqueuedTime").alias("event_ts"),
            F.col("eHubQueuedDatestamp").alias("event_date")
        )
        .filter(F.col("message_type").isin("mqs-quote-request", "rating-request"))
        .filter(F.to_date("event_date") >= F.date_sub(F.current_date(), LOOKBACK_DAYS))
        .filter(F.col("mqs_quote_id").isNotNull())
    )

    provider_array = F.transform(
        F.from_json(
            F.get_json_object("payload", "$.rawEnrichments"),
            "array<struct<provider:string>>"
        ),
        lambda x: x["provider"]
    )

    return (
        base_df
        .withColumn(
            "provider_status_quote_request",
            F.when(
                F.col("message_type") == "mqs-quote-request",
                F.when(F.array_contains(provider_array, "mylicence"), F.lit("present"))
                 .otherwise(F.lit("not_present"))
            )
        )
        .withColumn(
            "provider_status_rating_request",
            F.when(
                F.col("message_type") == "rating-request",
                F.when(
                    F.get_json_object("payload", "$.root.ratingRequestMessage[0].myLicence[0].dln").isNotNull(),
                    F.lit("present")
                ).otherwise(F.lit("not_present"))
            )
        )
        .withColumn(
            "dvla_status",
            F.when(F.col("message_type") == "mqs-quote-request", F.col("provider_status_quote_request"))
             .when(F.col("message_type") == "rating-request", F.col("provider_status_rating_request"))
        )
        .withColumn("table_name", F.lit("ehubstream"))
        .select(
            "table_name",
            "mqs_quote_id",
            "external_id",
            "message_type",
            "event_ts",
            "event_date",
            "dvla_status"
        )
    )

