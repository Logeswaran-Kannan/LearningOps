SELECT
    enqueued_date,
    table_name,
    deletion_type,
    message_type,
    total_count,
    eligible_quotes,
    deleted_quotes,
    retained_quotes,
    partial_deletion_quotes,
    orphan_count,
    dvla_present_count,
    deletion_pct,
    (eligible_quotes - deleted_quotes) AS deletion_gap,
    ROUND(
        100.0 * (retained_quotes + partial_deletion_quotes) / NULLIF(eligible_quotes, 0),
        2
    ) AS retention_failure_pct,
    ROUND(
        100.0 * orphan_count / NULLIF(total_count, 0),
        2
    ) AS orphan_pct,
    ROUND(
        100.0 * dvla_present_count / NULLIF(total_count, 0),
        2
    ) AS dvla_present_pct,
    ROUND(
        100.0 * eligible_quotes / NULLIF(total_count, 0),
        2
    ) AS eligible_share_pct
FROM core_bld.default.dvla_deletion_kpi_daily
ORDER BY enqueued_date DESC, table_name, message_type;
