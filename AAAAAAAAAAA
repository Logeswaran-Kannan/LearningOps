1. Daily forward / reverse reconciliation %
SELECT
    recon_requestDate,
    reconciliation_direction,

    COUNT(*) AS total_records,

    SUM(CASE WHEN match_flag = 'Y' THEN 1 ELSE 0 END) AS matched_records,
    SUM(CASE WHEN match_flag = 'N' THEN 1 ELSE 0 END) AS missing_records,

    ROUND(
        100.0 * SUM(CASE WHEN match_flag = 'Y' THEN 1 ELSE 0 END) / COUNT(*),
        2
    ) AS reconciliation_percentage,

    ROUND(
        100.0 * SUM(CASE WHEN match_flag = 'N' THEN 1 ELSE 0 END) / COUNT(*),
        2
    ) AS missing_percentage

FROM core_bld.radar_live.recon_interaction_detail
WHERE recon_requestDate IS NOT NULL
GROUP BY
    recon_requestDate,
    reconciliation_direction
ORDER BY
    recon_requestDate DESC,
    reconciliation_direction;
2. Single combined KPI view by date
SELECT
    recon_requestDate,

    COUNT(*) AS total_records,

    SUM(CASE WHEN reconciliation_direction = 'FORWARD' THEN 1 ELSE 0 END) AS forward_total,
    SUM(CASE WHEN reconciliation_direction = 'FORWARD' AND match_flag = 'Y' THEN 1 ELSE 0 END) AS forward_matched,
    SUM(CASE WHEN reconciliation_direction = 'FORWARD' AND match_flag = 'N' THEN 1 ELSE 0 END) AS forward_missing,

    ROUND(
        100.0 * SUM(CASE WHEN reconciliation_direction = 'FORWARD' AND match_flag = 'Y' THEN 1 ELSE 0 END)
        / NULLIF(SUM(CASE WHEN reconciliation_direction = 'FORWARD' THEN 1 ELSE 0 END), 0),
        2
    ) AS forward_recon_pct,

    SUM(CASE WHEN reconciliation_direction = 'REVERSE' THEN 1 ELSE 0 END) AS reverse_total,
    SUM(CASE WHEN reconciliation_direction = 'REVERSE' AND match_flag = 'Y' THEN 1 ELSE 0 END) AS reverse_matched,
    SUM(CASE WHEN reconciliation_direction = 'REVERSE' AND match_flag = 'N' THEN 1 ELSE 0 END) AS reverse_missing,

    ROUND(
        100.0 * SUM(CASE WHEN reconciliation_direction = 'REVERSE' AND match_flag = 'Y' THEN 1 ELSE 0 END)
        / NULLIF(SUM(CASE WHEN reconciliation_direction = 'REVERSE' THEN 1 ELSE 0 END), 0),
        2
    ) AS reverse_recon_pct

FROM core_bld.radar_live.recon_interaction_detail
WHERE recon_requestDate IS NOT NULL
GROUP BY recon_requestDate
ORDER BY recon_requestDate DESC;
3. Date + segment level KPI
SELECT
    recon_requestDate,
    csv_segment,
    reconciliation_direction,

    COUNT(*) AS total_records,
    SUM(CASE WHEN match_flag = 'Y' THEN 1 ELSE 0 END) AS matched_records,
    SUM(CASE WHEN match_flag = 'N' THEN 1 ELSE 0 END) AS missing_records,

    ROUND(
        100.0 * SUM(CASE WHEN match_flag = 'Y' THEN 1 ELSE 0 END) / COUNT(*),
        2
    ) AS recon_pct

FROM core_bld.radar_live.recon_interaction_detail
WHERE recon_requestDate IS NOT NULL
GROUP BY
    recon_requestDate,
    csv_segment,
    reconciliation_direction
ORDER BY
    recon_requestDate DESC,
    csv_segment,
    reconciliation_direction;
4. Maximum time difference by date
SELECT
    recon_requestDate,
    reconciliation_direction,

    MAX(abs_diff_hours) AS max_abs_diff_hours,
    ROUND(AVG(abs_diff_hours), 2) AS avg_abs_diff_hours,

    MAX(diff_days) AS max_diff_days,
    MIN(diff_days) AS min_diff_days

FROM core_bld.radar_live.recon_interaction_detail
WHERE recon_requestDate IS NOT NULL
  AND match_flag = 'Y'
GROUP BY
    recon_requestDate,
    reconciliation_direction
ORDER BY recon_requestDate DESC;
5. Missing records detail
SELECT
    recon_requestDate,
    reconciliation_direction,
    recon_status,
    csv_segment,

    csv_interactionId,
    csv_mqsQuoteId,
    csv_requestTimestamp,
    csv_transactionCode,

    interaction_interactionId,
    interaction_mqsQuoteId,
    interaction_TimeEnqueued,
    interaction_process_code,
    interaction_segment

FROM core_bld.radar_live.recon_interaction_detail
WHERE match_flag = 'N'
ORDER BY
    recon_requestDate DESC,
    reconciliation_direction,
    csv_requestTimestamp;

For dashboard, I would use Query 2 as main KPI, Query 3 for segment split, and Query 5 for drill-down.
