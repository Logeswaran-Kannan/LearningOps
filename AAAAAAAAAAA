WITH base AS (
    SELECT
        MQS_QUOTE_ID,
        TRNSCTN_DESC,
        RATING_REQUEST_CHANNEL_NAME,
        LATEST_QUOTE_JOURNEY_DESC,

        to_date(TRNSCTN_DT) AS trnsctn_dt,
        to_date(EFCTV_DTS) AS efctv_dt,
        DWH_CREATE_DTS,

        datediff(to_date(EFCTV_DTS), to_date(TRNSCTN_DT)) AS diff_days,

        CASE
            WHEN lower(RATING_REQUEST_CHANNEL_NAME) LIKE '%ctm%'
              OR lower(RATING_REQUEST_CHANNEL_NAME) LIKE '%compare the market%'
            THEN 'Aggs - CTM'

            WHEN lower(RATING_REQUEST_CHANNEL_NAME) LIKE '%go compare%'
            THEN 'Aggs - Go Compare'

            WHEN lower(RATING_REQUEST_CHANNEL_NAME) LIKE '%msm%'
              OR lower(RATING_REQUEST_CHANNEL_NAME) LIKE '%money supermarket%'
            THEN 'Aggs - MSM'

            WHEN lower(RATING_REQUEST_CHANNEL_NAME) LIKE '%confused%'
            THEN 'Aggs - Confused'

            ELSE 'Non Aggs'
        END AS aggregator_group,

        CASE
            WHEN lower(RATING_REQUEST_CHANNEL_NAME) LIKE '%ctm%'
              OR lower(RATING_REQUEST_CHANNEL_NAME) LIKE '%compare the market%'
              OR lower(RATING_REQUEST_CHANNEL_NAME) LIKE '%go compare%'
            THEN 15

            ELSE 24
        END AS retention_months,

        CASE
            WHEN LATEST_QUOTE_JOURNEY_DESC IS NULL
              OR lower(LATEST_QUOTE_JOURNEY_DESC) NOT LIKE '%sale%'
            THEN 1 ELSE 0
        END AS is_unconverted

    FROM core.curated_idw_mtr_athn_mqs.dim_audit_rating_quote_permissions
    WHERE MQS_QUOTE_ID IS NOT NULL
      AND DWH_CREATE_DTS < timestamp('2026-04-14 13:00:00')
),

validation AS (
    SELECT
        *,

        CASE
            WHEN lower(TRNSCTN_DESC) LIKE '%new business%'
             AND diff_days BETWEEN 0 AND 30
            THEN 'VALID'

            WHEN (
                    lower(TRNSCTN_DESC) LIKE '%mid term%'
                 OR lower(TRNSCTN_DESC) LIKE '%mta%'
                 )
             AND diff_days BETWEEN 0 AND 30
            THEN 'VALID'

            WHEN lower(TRNSCTN_DESC) LIKE '%renewal%'
             AND diff_days BETWEEN 0 AND 33
            THEN 'VALID'

            ELSE 'INVALID'
        END AS date_pattern_validation,

        add_months(trnsctn_dt, retention_months) AS delete_due_using_trnsctn_dt

    FROM base
),

impact AS (
    SELECT
        *,

        CASE
            WHEN is_unconverted = 1
             AND delete_due_using_trnsctn_dt <= current_date()
            THEN 1 ELSE 0
        END AS would_delete_using_trnsctn_dt

    FROM validation
)

SELECT
    aggregator_group,
    retention_months,
    TRNSCTN_DESC,

    COUNT(DISTINCT MQS_QUOTE_ID) AS total_quote_count,

    COUNT(DISTINCT CASE
        WHEN is_unconverted = 1
        THEN MQS_QUOTE_ID
    END) AS total_unconverted_quote_count,

    COUNT(DISTINCT CASE
        WHEN date_pattern_validation = 'VALID'
        THEN MQS_QUOTE_ID
    END) AS valid_date_pattern_quote_count,

    COUNT(DISTINCT CASE
        WHEN date_pattern_validation = 'INVALID'
        THEN MQS_QUOTE_ID
    END) AS invalid_date_pattern_quote_count,

    ROUND(
        100.0 * COUNT(DISTINCT CASE
            WHEN date_pattern_validation = 'INVALID'
            THEN MQS_QUOTE_ID
        END)
        / NULLIF(COUNT(DISTINCT MQS_QUOTE_ID), 0),
        2
    ) AS invalid_date_pattern_pct,

    COUNT(DISTINCT CASE
        WHEN would_delete_using_trnsctn_dt = 1
        THEN MQS_QUOTE_ID
    END) AS would_delete_using_transaction_date,

    ROUND(
        100.0 * COUNT(DISTINCT CASE
            WHEN would_delete_using_trnsctn_dt = 1
            THEN MQS_QUOTE_ID
        END)
        / NULLIF(COUNT(DISTINCT CASE
            WHEN is_unconverted = 1
            THEN MQS_QUOTE_ID
        END), 0),
        2
    ) AS pct_expected_to_delete_using_transaction_date

FROM impact
GROUP BY
    aggregator_group,
    retention_months,
    TRNSCTN_DESC
ORDER BY
    pct_expected_to_delete_using_transaction_date DESC,
    invalid_date_pattern_pct DESC;
