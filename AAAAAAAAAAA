SELECT
    enqueued_date,
    table_name,
    message_type,
    orphan_count,
    dvla_present_count,
    ROUND(
        100.0 * orphan_count / NULLIF(dvla_present_count, 0),
        2
    ) AS orphan_share_pct
FROM core_bld.default.dvla_deletion_kpi_daily
WHERE orphan_count > 0
ORDER BY enqueued_date DESC;
