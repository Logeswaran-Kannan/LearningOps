Dashboard SQLs
A. Headline KPI cards for latest run
WITH latest_run AS (
  SELECT MAX(run_date) AS run_date
  FROM core_bld.default.dvla_payload_monitor_summary_daily
)
SELECT
    s.run_date,
    SUM(s.eligible_quotes)               AS eligible_quotes,
    SUM(s.deleted_all_quotes)            AS deleted_all_quotes,
    SUM(s.retained_all_quotes)           AS retained_all_quotes,
    SUM(s.partial_deletion_quotes)       AS partial_deletion_quotes,
    SUM(s.not_found_in_target_quotes)    AS not_found_in_target_quotes,
    SUM(s.orphan_present_quotes)         AS orphan_present_quotes,
    ROUND(
        100.0 * SUM(s.deleted_all_quotes) / NULLIF(SUM(s.eligible_quotes), 0),
        2
    ) AS deletion_pct
FROM core_bld.default.dvla_payload_monitor_summary_daily s
JOIN latest_run l
  ON s.run_date = l.run_date
GROUP BY s.run_date;
B. Table-wise KPI comparison for latest run
WITH latest_run AS (
  SELECT MAX(run_date) AS run_date
  FROM core_bld.default.dvla_payload_monitor_summary_daily
)
SELECT
    s.run_date,
    s.table_name,
    s.message_type,
    s.eligible_quotes,
    s.deleted_all_quotes,
    s.retained_all_quotes,
    s.partial_deletion_quotes,
    s.not_found_in_target_quotes,
    s.orphan_present_quotes,
    s.orphan_not_present_quotes,
    s.deletion_pct
FROM core_bld.default.dvla_payload_monitor_summary_daily s
JOIN latest_run l
  ON s.run_date = l.run_date
ORDER BY s.table_name, s.message_type;
C. Daily trend by table
SELECT
    run_date,
    table_name,
    SUM(eligible_quotes)            AS eligible_quotes,
    SUM(deleted_all_quotes)         AS deleted_all_quotes,
    SUM(retained_all_quotes)        AS retained_all_quotes,
    SUM(partial_deletion_quotes)    AS partial_deletion_quotes,
    SUM(not_found_in_target_quotes) AS not_found_in_target_quotes,
    SUM(orphan_present_quotes)      AS orphan_present_quotes,
    ROUND(
        100.0 * SUM(deleted_all_quotes) / NULLIF(SUM(eligible_quotes), 0),
        2
    ) AS deletion_pct
FROM core_bld.default.dvla_payload_monitor_summary_daily
