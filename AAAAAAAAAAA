SELECT
    recon_requestDate,
    reconciliation_direction,
    match_flag,
    interaction_segment,
    COUNT(*) AS record_count
FROM core_bld.radar_live.recon_interaction_detail
GROUP BY
    recon_requestDate,
    reconciliation_direction,
    match_flag,
    interaction_segment
ORDER BY
    recon_requestDate,
    reconciliation_direction,
    match_flag;
