def get_breach_rows():
    query = f"""
    WITH bounds AS (
        SELECT date_trunc('day', current_timestamp()) AS day_start
    ),
    latest_mqs_interval AS (
        SELECT MAX(interval_end) AS max_interval
        FROM {EHUB_TABLE}
        WHERE interval_end >= (SELECT day_start FROM bounds)
          AND message_type <> 'ALL'
    ),
    interaction_intervals AS (
        SELECT DISTINCT interval_start
        FROM {INTERACTION_TABLE}
        WHERE interval_start >= (SELECT day_start FROM bounds)
          AND status = 'ALL'
    ),
    latest_minus_1_interaction AS (
        SELECT interval_start AS interaction_interval
        FROM (
            SELECT interval_start,
                   ROW_NUMBER() OVER (ORDER BY interval_start DESC) AS rn
            FROM interaction_intervals
        ) x WHERE rn = 1
    ),
    ehub_latest AS (
        SELECT
            run_date,
            interval_start,
            interval_end,
            message_type  AS message_type_link,
            message_count AS ehub_count,
            is_sla_breach AS ehub_sla,
            brand
        FROM {EHUB_TABLE}
        WHERE message_type <> 'ALL'
          AND brand IN ('AZ','BRITANNIA')
          AND interval_end = (SELECT max_interval FROM latest_mqs_interval)
    ),
    bronze_latest AS (
        SELECT
            CASE
                WHEN message_type = 'dlt_quote_request'                  THEN 'mqs-quote-request'
                WHEN message_type = 'dlt_precomp_response'               THEN 'precomp-response'
                WHEN message_type = 'dlt_rating_request_v2'              THEN 'rating-request'
                WHEN message_type = 'dlt_rating_response_v2'             THEN 'rating-response'
                WHEN message_type = 'dlt_cache_id'                       THEN 'quote-cache-id'
                WHEN message_type = 'dlt_stop_quote'                     THEN 'stop-quote'
                WHEN message_type = 'dlt_rating_request_dvla_removed_v2' THEN 'dlt_rating_request_dvla_removed'
                WHEN message_type = 'dlt_raw_enrichments'                THEN 'dlt_raw_enrichments'
                ELSE 'others'
            END           AS message_type_link,
            interval_end,
            interval_start,
            message_count,
            is_sla_breach AS is_sla_flag,
            brand
        FROM {BRONZE_TABLE}
        WHERE message_type <> 'ALL'
          AND brand IN ('AZ','BRITANNIA')
          AND interval_end = (SELECT max_interval FROM latest_mqs_interval)
    ),
    interaction_latest AS (
        SELECT
            interval_start,
            SUM(total_count) AS total_interaction_count
        FROM {INTERACTION_TABLE}
        WHERE status = 'ALL'
          AND interval_start = (
              SELECT interaction_interval FROM latest_minus_1_interaction
          )
        GROUP BY interval_start
    )
    SELECT
        e.run_date,
        e.interval_end,
        e.brand,
        e.message_type_link,
        e.ehub_count,
        e.ehub_sla,
        COALESCE(b.message_count, 0)               AS bronze_count,
        COALESCE(b.is_sla_flag,   0)               AS bronze_sla,
        e.ehub_count - COALESCE(b.message_count, 0) AS count_difference,
        CASE
            WHEN e.ehub_sla = 1 AND COALESCE(b.is_sla_flag, 0) = 1 THEN '△ EHUB & BRONZE'
            WHEN e.ehub_sla = 1                                      THEN '△ EHUB'
            WHEN COALESCE(b.is_sla_flag, 0) = 1                     THEN '△ BRONZE'
            WHEN COALESCE(i.total_interaction_count, 0) = 0          THEN '※ INTERACTION'
        END AS breach_source
    FROM ehub_latest e
    LEFT JOIN bronze_latest b
        ON  e.message_type_link = b.message_type_link
        AND e.interval_end      = b.interval_end
        AND e.brand             = b.brand
    LEFT JOIN interaction_latest i
        ON  e.interval_start    = i.interval_start
    WHERE
        e.ehub_sla = 1
        OR COALESCE(b.is_sla_flag, 0) = 1
        OR COALESCE(i.total_interaction_count, 0) = 0
    ORDER BY e.brand, e.message_type_link
    LIMIT 12
    """
    return [r.asDict() for r in spark.sql(query).collect()]

def get_latest_interval():
    return spark.sql(f"""
        WITH bounds AS (
            SELECT date_trunc('day', current_timestamp()) AS day_start
        )
        SELECT MAX(interval_end) AS latest_interval
        FROM {EHUB_TABLE}
        WHERE interval_end >= (SELECT day_start FROM bounds)
          AND message_type <> 'ALL'
    """).collect()[0]["latest_interval"]

def get_overnight_breach_count(brand: str) -> int:
    return int(spark.sql(f"""
        WITH bounds AS (
            SELECT date_trunc('day', current_timestamp()) AS day_start
        )
        SELECT COUNT(*) AS breach_count
        FROM {EHUB_TABLE}
        WHERE run_date >= (SELECT day_start FROM bounds)
          AND brand = '{brand}'
          AND message_type <> 'ALL'
          AND is_sla_breach = 1
    """).collect()[0]["breach_count"])

