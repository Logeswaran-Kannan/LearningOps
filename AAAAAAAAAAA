# STATE TABLE
# ==============================================================
def ensure_state_table():
    spark.sql(f"""
    CREATE TABLE IF NOT EXISTS {STATE_TABLE} (
        alert_name         STRING,
        current_status     STRING,
        last_interval      TIMESTAMP,
        last_notified_at   TIMESTAMP,
        consecutive_count  INT,
        notified_status    STRING
    )
    USING DELTA
    """)
    # Safe migration — add new columns if old table exists without them
    existing_cols = [c.lower() for c in spark.table(STATE_TABLE).columns]
    if "consecutive_count" not in existing_cols:
        spark.sql(f"ALTER TABLE {STATE_TABLE} ADD COLUMN consecutive_count INT")
    if "notified_status" not in existing_cols:
        spark.sql(f"ALTER TABLE {STATE_TABLE} ADD COLUMN notified_status STRING")

def read_previous_state():
    """Returns (current_status, notified_status, consecutive_count)"""
    state_rows = (
        spark.table(STATE_TABLE)
        .filter(F.col("alert_name") == ALERT_NAME)
        .collect()
    )
    if state_rows:
        row = state_rows[0]
        return (
            row["current_status"],
            row["notified_status"],
            int(row["consecutive_count"] or 0)
        )
    return None, None, 0

def upsert_state(current_status, current_interval,
                 consecutive_count, notified_status):
    spark.createDataFrame(
        [(ALERT_NAME, current_status,
          current_interval, consecutive_count, notified_status)],
        ["alert_name", "current_status",
         "last_interval", "consecutive_count", "notified_status"]
    ).withColumn(
        "last_notified_at", F.current_timestamp()
    ).createOrReplaceTempView("state_update")

    spark.sql(f"""
        MERGE INTO {STATE_TABLE} t
        USING state_update s
        ON t.alert_name = s.alert_name
        WHEN MATCHED THEN UPDATE SET
            t.current_status    = s.current_status,
            t.last_interval     = s.last_interval,
            t.last_notified_at  = s.last_notified_at,
            t.consecutive_count = s.consecutive_count,
            t.notified_status   = s.notified_status
        WHEN NOT MATCHED THEN INSERT (
            alert_name, current_status, last_interval,
            last_notified_at, consecutive_count, notified_status
        ) VALUES (
            s.alert_name, s.current_status, s.last_interval,
            s.last_notified_at, s.consecutive_count, s.notified_status
        )
    """)

