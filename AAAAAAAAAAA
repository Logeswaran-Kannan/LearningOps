WITH base AS (
    SELECT
        MQS_QUOTE_ID,
        POLICY_REF,
        TRNSCTN_DESC,
        RATING_REQUEST_CHANNEL_NAME,
        LATEST_QUOTE_JOURNEY_DESC,
        to_date(TRNSCTN_DT) AS trnsctn_dt,
        to_date(EFCTV_DTS) AS efctv_dt,
        to_date(DWH_DATA_DTS) AS dwh_data_dt,
        date_sub(to_date(EFCTV_DTS), 30) AS potential_earliest_trnsctn_dt,
        DWH_CREATE_DTS
    FROM core.curated_idw_mtr_athn_mqs.dim_audit_rating_quote_permissions
    WHERE DWH_CREATE_DTS < timestamp('2026-04-14 13:00:00')
      AND MQS_QUOTE_ID IS NOT NULL
)

SELECT
    TRNSCTN_DESC,

    CASE
        WHEN datediff(efctv_dt, dwh_data_dt) < -30 THEN 'EFCTV before DWH by >30 days'
        WHEN datediff(efctv_dt, dwh_data_dt) BETWEEN -30 AND 30 THEN 'EFCTV aligned with DWH +/-30'
        WHEN datediff(efctv_dt, dwh_data_dt) BETWEEN 31 AND 90 THEN 'EFCTV after DWH 31-90 days'
        WHEN datediff(efctv_dt, dwh_data_dt) BETWEEN 91 AND 180 THEN 'EFCTV after DWH 91-180 days'
        WHEN datediff(efctv_dt, dwh_data_dt) BETWEEN 181 AND 365 THEN 'EFCTV after DWH 181-365 days'
        WHEN datediff(efctv_dt, dwh_data_dt) > 365 THEN 'EFCTV after DWH >365 days'
        ELSE 'Unknown'
    END AS efctv_vs_dwh_bucket,

    COUNT(DISTINCT MQS_QUOTE_ID) AS distinct_quotes,

    MIN(efctv_dt) AS min_efctv_dt,
    MAX(efctv_dt) AS max_efctv_dt,
    MIN(dwh_data_dt) AS min_dwh_data_dt,
    MAX(dwh_data_dt) AS max_dwh_data_dt,
    MIN(potential_earliest_trnsctn_dt) AS min_potential_earliest_trnsctn_dt,
    MAX(potential_earliest_trnsctn_dt) AS max_potential_earliest_trnsctn_dt

FROM base
GROUP BY
    TRNSCTN_DESC,
    CASE
        WHEN datediff(efctv_dt, dwh_data_dt) < -30 THEN 'EFCTV before DWH by >30 days'
        WHEN datediff(efctv_dt, dwh_data_dt) BETWEEN -30 AND 30 THEN 'EFCTV aligned with DWH +/-30'
        WHEN datediff(efctv_dt, dwh_data_dt) BETWEEN 31 AND 90 THEN 'EFCTV after DWH 31-90 days'
        WHEN datediff(efctv_dt, dwh_data_dt) BETWEEN 91 AND 180 THEN 'EFCTV after DWH 91-180 days'
        WHEN datediff(efctv_dt, dwh_data_dt) BETWEEN 181 AND 365 THEN 'EFCTV after DWH 181-365 days'
        WHEN datediff(efctv_dt, dwh_data_dt) > 365 THEN 'EFCTV after DWH >365 days'
        ELSE 'Unknown'
    END
ORDER BY
    TRNSCTN_DESC,
    distinct_quotes DESC;

