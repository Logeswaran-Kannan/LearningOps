SELECT
    MQS_QUOTE_ID,
    POLICY_REF,
    QUOTE_REF,
    TRNSCTN_DESC,
    LATEST_QUOTE_JOURNEY_DESC,
    RATING_REQUEST_CHANNEL_NAME,

    to_date(TRNSCTN_DT) AS trnsctn_dt,
    to_date(EFCTV_DTS) AS efctv_dt,
    date_sub(to_date(EFCTV_DTS), 30) AS potential_earliest_trnsctn_dt,
    to_date(DWH_DATA_DTS) AS dwh_data_dt,

    datediff(to_date(EFCTV_DTS), to_date(TRNSCTN_DT)) AS efctv_vs_trnsctn_days,
    datediff(to_date(EFCTV_DTS), to_date(DWH_DATA_DTS)) AS efctv_vs_dwh_days,
    datediff(date_sub(to_date(EFCTV_DTS), 30), to_date(DWH_DATA_DTS)) AS potential_vs_dwh_days,

    DWH_CREATE_DTS,
    DWH_UPDATE_DTS

FROM core.curated_idw_mtr_athn_mqs.dim_audit_rating_quote_permissions
WHERE DWH_CREATE_DTS < timestamp('2026-04-14 13:00:00')
  AND MQS_QUOTE_ID IS NOT NULL
  AND abs(datediff(to_date(EFCTV_DTS), to_date(DWH_DATA_DTS))) > 30
ORDER BY
    abs(datediff(to_date(EFCTV_DTS), to_date(DWH_DATA_DTS))) DESC
LIMIT 200;

