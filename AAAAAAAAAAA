def is_daily_health_window() -> bool:
    now = datetime.now()
    return now.hour == DAILY_HEALTH_HOUR and now.minute < 30

def safe_text(value, max_len=22):
    s = "" if value is None else str(value)
    return s if len(s) <= max_len else s[:max_len - 3] + "..."

def summarize_sources(items):
    counts = {}
    for r in items:
        src = str(r.get("breach_source", "UNKNOWN"))
        counts[src] = counts.get(src, 0) + 1
    return ", ".join([f"{k}: {v}" for k, v in counts.items()])

def comparison_line(items):
    if not items:
        return "EHUB and Bronze counts are aligned within SLA for the latest monitored interval."
    max_diff = max([abs(int(r.get("count_difference", 0))) for r in items]) if items else 0
    non_zero = sum([1 for r in items if int(r.get("count_difference", 0)) != 0])
    if max_diff == 0:
        return "EHUB and Bronze counts are aligned for the monitored interval."
    return f"Count comparison indicates {non_zero} impacted flow(s), with a maximum EHUB vs Bronze variance of {max_diff}."

def should_send_alert(prev_status, current_status,
                      notified_status, consecutive_count):
    """
    Returns 'breach', 'recovery', or None.
    Breach  — immediate on first detection.
    Recovery — only after RECOVERY_CONFIRM_INTERVALS consecutive healthy slots.
    """
    if current_status == "BREACH":
        if notified_status != "BREACH":
            return "breach"
        return None
    if current_status == "HEALTHY":
        if notified_status == "BREACH":
            if consecutive_count >= RECOVERY_CONFIRM_INTERVALS:
                return "recovery"
            else:
                print(f"  Recovery pending — {consecutive_count}/{RECOVERY_CONFIRM_INTERVALS} intervals confirmed")
                return None
    return None

def send_webhook(payload):
    response = requests.post(
        WEBHOOK_URL,
        headers={"Content-Type": "application/json"},
        data=json.dumps(payload),
        timeout=30
    )
    print("HTTP status:", response.status_code)
    print("Response text:", response.text)
    response.raise_for_status()

def wrap_adaptive_card(body):
    return {
        "type": "message",
        "attachments": [
            {
                "contentType": "application/vnd.microsoft.card.adaptive",
                "content": {
                    "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
                    "type": "AdaptiveCard",
                    "version": "1.2",
                    "body": body
                }
            }
        ]
    }

