SELECT 'EHUB' AS table_name, interval_end AS interval_value, COUNT(*) AS row_count
FROM core_bld.default.monitoring_ehub_30min_metrics
WHERE interval_end >= date_trunc('day', current_timestamp())
  AND message_type <> 'ALL'
GROUP BY interval_end

UNION ALL

SELECT 'BRONZE' AS table_name, interval_end AS interval_value, COUNT(*) AS row_count
FROM core_bld.default.monitoring_mqs_bronze_30min
WHERE interval_end >= date_trunc('day', current_timestamp())
  AND message_type <> 'ALL'
GROUP BY interval_end

UNION ALL

SELECT 'INTERACTION' AS table_name, interval_start AS interval_value, COUNT(*) AS row_count
FROM core_bld.default.monitoring_mqs_interaction_status
WHERE interval_start >= date_trunc('day', current_timestamp())
GROUP BY interval_start

ORDER BY table_name, interval_value DESC;
