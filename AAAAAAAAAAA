SELECT
    aggregator_group,
    retention_months,

    SUM(total_quote_count) AS total_quote_count,
    SUM(total_unconverted_quote_count) AS total_unconverted_quote_count,
    SUM(invalid_date_pattern_quote_count) AS invalid_date_pattern_quote_count,
    SUM(would_delete_using_transaction_date) AS would_delete_using_transaction_date,

    ROUND(
        100.0 * SUM(would_delete_using_transaction_date)
        / NULLIF(SUM(total_unconverted_quote_count), 0),
        2
    ) AS pct_expected_to_delete_using_transaction_date

FROM (
    -- paste the first SELECT result query here, without ORDER BY
) x
GROUP BY
    aggregator_group,
    retention_months
ORDER BY
    pct_expected_to_delete_using_transaction_date DESC;
