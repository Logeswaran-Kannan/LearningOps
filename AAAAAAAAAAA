E. Latest run exception detail

This is the main drilldown grid.

WITH latest_run AS (
  SELECT MAX(run_date) AS run_date
  FROM core_bld.default.dvla_payload_monitor_detail
)
SELECT
    d.run_date,
    d.table_name,
    d.message_type,
    d.mqs_quote_id,
    d.quote_ref,
    d.days_from_dwh,
    d.target_row_count,
    d.present_row_count,
    d.not_present_row_count,
    d.monitor_status,
    d.event_ts,
    d.event_date,
    d.checked_ts
FROM core_bld.default.dvla_payload_monitor_detail d
JOIN latest_run l
  ON d.run_date = l.run_date
ORDER BY
    d.table_name,
    d.monitor_status,
    d.days_from_dwh DESC,
    d.mqs_quote_id;
F. Exception count by table and status
WITH latest_run AS (
  SELECT MAX(run_date) AS run_date
  FROM core_bld.default.dvla_payload_monitor_detail
)
SELECT
    d.run_date,
    d.table_name,
    d.message_type,
    d.monitor_status,
    COUNT(*) AS exception_count
FROM core_bld.default.dvla_payload_monitor_detail d
JOIN latest_run l
  ON d.run_date = l.run_date
GROUP BY
    d.run_date,
    d.table_name,
    d.message_type,
    d.monitor_status
ORDER BY
    d.table_name,
    d.message_type,
    d.monitor_status;

This is good for stacked bars.

G. Ageing buckets for exceptions
WITH latest_run AS (
  SELECT MAX(run_date) AS run_date
  FROM core_bld.default.dvla_payload_monitor_detail
)
SELECT
    d.table_name,
    d.message_type,
    d.monitor_status,
    CASE
        WHEN d.days_from_dwh BETWEEN 61 AND 70 THEN '61-70'
        WHEN d.days_from_dwh BETWEEN 71 AND 90 THEN '71-90'
        WHEN d.days_from_dwh BETWEEN 91 AND 120 THEN '91-120'
        WHEN d.days_from_dwh > 120 THEN '120+'
        ELSE 'UNKNOWN'
    END AS ageing_bucket,
    COUNT(*) AS quote_count
FROM core_bld.default.dvla_payload_monitor_detail d
JOIN latest_run l
  ON d.run_date = l.run_date
GROUP BY
    d.table_name,
    d.message_type,
    d.monitor_status,
    CASE
        WHEN d.days_from_dwh BETWEEN 61 AND 70 THEN '61-70'
        WHEN d.days_from_dwh BETWEEN 71 AND 90 THEN '71-90'
        WHEN d.days_from_dwh BETWEEN 91 AND 120 THEN '91-120'
        WHEN d.days_from_dwh > 120 THEN '120+'
        ELSE 'UNKNOWN'
    END
ORDER BY
    d.table_name,
    d.message_type,
    d.monitor_status,
    ageing_bucket;
H. Worst affected quotes
WITH latest_run AS (
  SELECT MAX(run_date) AS run_date
  FROM core_bld.default.dvla_payload_monitor_detail
)
SELECT
    d.run_date,
    d.table_name,
    d.message_type,
    d.mqs_quote_id,
    d.quote_ref,
    d.days_from_dwh,
    d.target_row_count,
    d.present_row_count,
    d.not_present_row_count,
    d.monitor_status
FROM core_bld.default.dvla_payload_monitor_detail d
JOIN latest_run l
  ON d.run_date = l.run_date
WHERE d.monitor_status IN (
    'ELIGIBLE_RETAINED_ALL',
    'ELIGIBLE_PARTIAL_DELETION',
    'ORPHAN_PRESENT'
)
ORDER BY
    d.days_from_dwh DESC,
    d.present_row_count DESC,
    d.target_row_count DESC
LIMIT 100;
