# Databricks PySpark job
# DVLA Payload Deletion Monitor
# Covers:
#   1. ehubstream
#   2. dlt_raw_enrichments
#   3. dlt_rating_request_v2

from pyspark.sql import functions as F
from pyspark.sql import DataFrame
from functools import reduce
import time
from datetime import datetime

# =========================================================
# CONFIG
# =========================================================

DIM_TABLE = "curated_idw_mtr_athn_mqs.dim_audit_rating_quote_permissions"
EHUBSTREAM_TABLE = "core.mqs_athn_mtr.ehubstream"
DLT_RAW_ENRICHMENTS_TABLE = "core.mqs_athn_mtr.dlt_raw_enrichments"
DLT_RATING_REQUEST_V2_TABLE = "core.mqs_athn_mtr.dlt_rating_request_v2"

ELIGIBLE_SNAPSHOT_TABLE = "core_bld.default.dvla_delete_eligible_quotes_daily"
DETAIL_TABLE = "core_bld.default.dvla_payload_monitor_detail"
SUMMARY_TABLE = "core_bld.default.dvla_payload_monitor_summary_daily"

LOOKBACK_DAYS = 180
ELIGIBILITY_DAYS = 60
EXCLUDED_JOURNEY = "Athena Motor Sale"

# Set to True only if you want row counts in logs.
# Note: count() triggers Spark jobs, so it adds runtime.
ENABLE_COUNTS_IN_LOG = True

# =========================================================
# TIMING / LOGGING
# =========================================================

JOB_START = time.perf_counter()

def log_line(message: str) -> None:
    now = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    total_elapsed = round(time.perf_counter() - JOB_START, 2)
    print(f"[{now}] {message} | total_elapsed_sec={total_elapsed}")

def log_step_start(step_name: str) -> float:
    log_line(f"START: {step_name}")
    return time.perf_counter()

def log_step_end(step_name: str, step_start: float) -> None:
    step_elapsed = round(time.perf_counter() - step_start, 2)
    total_elapsed = round(time.perf_counter() - JOB_START, 2)
    now = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    print(f"[{now}] END: {step_name} | step_elapsed_sec={step_elapsed} | total_elapsed_sec={total_elapsed}")

def log_df_count(df: DataFrame, label: str) -> None:
    if ENABLE_COUNTS_IN_LOG:
        cnt = df.count()
        log_line(f"{label} row_count={cnt}")

# =========================================================
# HELPERS
# =========================================================

def safe_union(dfs: list[DataFrame]) -> DataFrame:
    valid_dfs = [df for df in dfs if df is not None]
    if not valid_dfs:
        raise ValueError("No DataFrames provided for union")
    return reduce(lambda x, y: x.unionByName(y, allowMissingColumns=True), valid_dfs)

def delete_run_partition(table_name: str) -> None:
    spark.sql(f"""
        DELETE FROM {table_name}
        WHERE run_date = current_date()
    """)

# =========================================================
# TARGET TABLE CREATION
# =========================================================

def create_target_tables_if_not_exist() -> None:
    spark.sql(f"""
        CREATE TABLE IF NOT EXISTS {ELIGIBLE_SNAPSHOT_TABLE} (
            run_date DATE,
            mqs_quote_id STRING,
            quote_ref STRING,
            dwh_date DATE,
            dwh_create_dts TIMESTAMP,
            latest_quote_journey_desc STRING,
            days_from_dwh INT,
            eligible_flag INT
        )
        USING DELTA
        PARTITIONED BY (run_date)
    """)

    spark.sql(f"""
        CREATE TABLE IF NOT EXISTS {DETAIL_TABLE} (
            run_date DATE,
            table_name STRING,
            message_type STRING,
            mqs_quote_id STRING,
            quote_ref STRING,
            dwh_date DATE,
            dwh_create_dts TIMESTAMP,
            latest_quote_journey_desc STRING,
            days_from_dwh INT,
            eligible_flag INT,
            target_row_count BIGINT,
            present_row_count BIGINT,
            not_present_row_count BIGINT,
            event_ts TIMESTAMP,
            event_date TIMESTAMP,
            monitor_status STRING,
            checked_ts TIMESTAMP
        )
        USING DELTA
        PARTITIONED BY (run_date)
    """)

    spark.sql(f"""
        CREATE TABLE IF NOT EXISTS {SUMMARY_TABLE} (
            run_date DATE,
            table_name STRING,
            message_type STRING,
            eligible_quotes BIGINT,
            deleted_all_quotes BIGINT,
            retained_all_quotes BIGINT,
            partial_deletion_quotes BIGINT,
            not_found_in_target_quotes BIGINT,
            orphan_present_quotes BIGINT,
            orphan_not_present_quotes BIGINT,
            max_days_from_dwh INT,
            avg_days_from_dwh DOUBLE,
            deletion_pct DECIMAL(10,2),
            created_ts TIMESTAMP
        )
        USING DELTA
        PARTITIONED BY (run_date)
    """)

# =========================================================
# STEP 1 - ELIGIBLE QUOTES
# =========================================================

def get_eligible_quotes() -> DataFrame:
    return (
        spark.table(DIM_TABLE)
        .select(
            F.col("MQS_QUOTE_ID").alias("mqs_quote_id"),
            F.col("QUOTE_REF").alias("quote_ref"),
            F.to_date("DWH_DATA_DTS").alias("dwh_date"),
            F.col("DWH_CREATE_DTS").cast("timestamp").alias("dwh_create_dts"),
            F.col("LATEST_QUOTE_JOURNEY_DESC").alias("latest_quote_journey_desc")
        )
        .filter(F.col("mqs_quote_id").isNotNull())
        .filter(F.coalesce(F.col("latest_quote_journey_desc"), F.lit("")) != F.lit(EXCLUDED_JOURNEY))
        .withColumn("days_from_dwh", F.datediff(F.current_date(), F.col("dwh_date")))
        .filter(F.col("days_from_dwh") > F.lit(ELIGIBILITY_DAYS))
        .withColumn("run_date", F.current_date())
        .withColumn("eligible_flag", F.lit(1))
        .dropDuplicates(["mqs_quote_id"])
    )

def write_eligible_snapshot(df: DataFrame) -> None:
    delete_run_partition(ELIGIBLE_SNAPSHOT_TABLE)

    final_df = df.withColumn("dwh_create_dts", F.col("dwh_create_dts").cast("timestamp"))

    (
        final_df.select(
            "run_date",
            "mqs_quote_id",
            "quote_ref",
            "dwh_date",
            "dwh_create_dts",
            "latest_quote_journey_desc",
            "days_from_dwh",
            "eligible_flag"
        )
        .write
        .mode("append")
        .saveAsTable(ELIGIBLE_SNAPSHOT_TABLE)
    )

def read_today_eligible_snapshot() -> DataFrame:
    return (
        spark.table(ELIGIBLE_SNAPSHOT_TABLE)
        .filter(F.col("run_date") == F.current_date())
    )

# =========================================================
# STEP 2 - TABLE SPECIFIC DVLA CHECKS
# =========================================================

def get_ehubstream_base() -> DataFrame:
    base_df = (
        spark.table(EHUBSTREAM_TABLE)
        .select(
            F.col("headers")["MQSQuoteId"].alias("mqs_quote_id"),
            F.col("headers")["messageType"].alias("message_type"),
            F.col("payload"),
            F.col("enqueuedTime").cast("timestamp").alias("event_ts"),
            F.col("eHubQueuedDatestamp").cast("timestamp").alias("event_date")
        )
        .filter(F.col("message_type").isin("mqs-quote-request", "rating-request"))
        .filter(F.to_date("event_date") >= F.date_sub(F.current_date(), LOOKBACK_DAYS))
        .filter(F.col("mqs_quote_id").isNotNull())
    )

    payload_json = F.col("payload").cast("string")

    provider_array = F.transform(
        F.from_json(
            F.get_json_object(payload_json, "$.rawEnrichments"),
            "array<struct<provider:string>>"
        ),
        lambda x: x["provider"]
    )

    final_df = (
        base_df
        .withColumn(
            "dvla_status",
            F.when(
                F.col("message_type") == "mqs-quote-request",
                F.when(F.array_contains(provider_array, "mylicence"), F.lit("present"))
                 .otherwise(F.lit("not_present"))
            ).when(
                F.col("message_type") == "rating-request",
                F.when(
                    F.get_json_object(
                        payload_json,
                        "$.root.ratingRequestMessage[0].myLicence[0].dln"
                    ).isNotNull(),
                    F.lit("present")
                ).otherwise(F.lit("not_present"))
            )
        )
        .withColumn("table_name", F.lit("ehubstream"))
        .select(
            "table_name",
            "mqs_quote_id",
            "message_type",
            "event_ts",
            "event_date",
            "dvla_status"
        )
    )

    return final_df

