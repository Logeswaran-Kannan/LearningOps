SELECT
    MQS_QUOTE_ID,
    POLICY_REF,
    QUOTE_REF,
    aggregator_group,
    TRNSCTN_DESC,
    LATEST_QUOTE_JOURNEY_DESC,

    trnsctn_dt,
    efctv_dt,
    dwh_data_dt,

    diff_days,
    validation_status,

    DWH_CREATE_DTS

FROM validation
WHERE validation_status <> 'VALID'
ORDER BY
    abs(diff_days) DESC
LIMIT 500;
