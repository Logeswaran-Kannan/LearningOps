WITH base AS (
    SELECT
        POLICY_REF,
        MQS_QUOTE_ID,
        QUOTE_REF,
        TRNSCTN_DESC,
        LATEST_QUOTE_JOURNEY_DESC,
        to_date(TRNSCTN_DT) AS trnsctn_dt,
        to_date(EFCTV_DTS) AS efctv_dt,
        DWH_CREATE_DTS,

        CASE
            WHEN lower(TRNSCTN_DESC) LIKE '%new business%' THEN 1 ELSE 0
        END AS nb_flag,

        CASE
            WHEN lower(TRNSCTN_DESC) LIKE '%renewal%' THEN 1 ELSE 0
        END AS renewal_flag,

        CASE
            WHEN lower(TRNSCTN_DESC) LIKE '%mid term%'
              OR lower(TRNSCTN_DESC) LIKE '%mta%'
              OR lower(TRNSCTN_DESC) LIKE '%adjustment%' THEN 1 ELSE 0
        END AS mta_flag

    FROM core.curated_idw_mtr_athn_mqs.dim_audit_rating_quote_permissions
    WHERE POLICY_REF IS NOT NULL
),

policy_flags AS (
    SELECT
        POLICY_REF,
        MAX(nb_flag) AS has_nb,
        MAX(renewal_flag) AS has_renewal,
        MAX(mta_flag) AS has_mta,
        COUNT(DISTINCT MQS_QUOTE_ID) AS distinct_quote_count,
        COUNT(*) AS record_count,
        MIN(efctv_dt) AS min_efctv_dt,
        MAX(efctv_dt) AS max_efctv_dt
    FROM base
    GROUP BY POLICY_REF
),

eligible_policies AS (
    SELECT *
    FROM policy_flags
    WHERE has_nb = 1
      AND (has_renewal = 1 OR has_mta = 1)   -- exclude only NB policies
)

SELECT
    b.POLICY_REF,

    p.has_nb,
    p.has_renewal,
    p.has_mta,

    b.MQS_QUOTE_ID,
    b.QUOTE_REF,
    b.TRNSCTN_DESC,
    b.LATEST_QUOTE_JOURNEY_DESC,
    b.trnsctn_dt,
    b.efctv_dt,

    datediff(
        b.efctv_dt,
        lag(b.efctv_dt) OVER (
            PARTITION BY b.POLICY_REF
            ORDER BY b.efctv_dt, b.DWH_CREATE_DTS
        )
    ) AS efctv_days_from_previous,

    b.DWH_CREATE_DTS

FROM base b
JOIN eligible_policies p
    ON b.POLICY_REF = p.POLICY_REF
ORDER BY
    b.POLICY_REF,
    b.efctv_dt,
    b.DWH_CREATE_DTS
LIMIT 500;



