# =========================================================
# STEP 3 - CLASSIFICATION
# =========================================================

def build_monitor_detail(eligible_df: DataFrame, target_df: DataFrame, table_name: str) -> DataFrame:
    eligible_side = (
        eligible_df.alias("e")
        .join(target_df.alias("t"), on="mqs_quote_id", how="left")
        .select(
            F.col("e.run_date"),
            F.lit(table_name).alias("table_name"),
            F.col("t.message_type"),
            F.col("e.mqs_quote_id"),
            F.col("e.quote_ref"),
            F.col("e.dwh_date"),
            F.col("e.dwh_create_dts"),
            F.col("e.latest_quote_journey_desc"),
            F.col("e.days_from_dwh"),
            F.col("e.eligible_flag"),
            F.col("t.external_id"),
            F.col("t.event_ts"),
            F.col("t.event_date"),
            F.col("t.dvla_status"),
            F.when(F.col("t.mqs_quote_id").isNull(), F.lit("NOT_FOUND_IN_TARGET"))
             .when(F.col("t.dvla_status") == "present", F.lit("ELIGIBLE_RETAINED"))
             .when(F.col("t.dvla_status") == "not_present", F.lit("ELIGIBLE_DELETED"))
             .otherwise(F.lit("UNKNOWN")).alias("monitor_status"),
            F.current_timestamp().alias("checked_ts")
        )
    )

    orphan_side = (
        target_df.alias("t")
        .join(eligible_df.alias("e"), on="mqs_quote_id", how="leftanti")
        .select(
            F.current_date().alias("run_date"),
            F.lit(table_name).alias("table_name"),
            F.col("t.message_type"),
            F.col("t.mqs_quote_id"),
            F.lit(None).cast("string").alias("quote_ref"),
            F.lit(None).cast("date").alias("dwh_date"),
            F.lit(None).cast("timestamp").alias("dwh_create_dts"),
            F.lit(None).cast("string").alias("latest_quote_journey_desc"),
            F.lit(None).cast("int").alias("days_from_dwh"),
            F.lit(0).alias("eligible_flag"),
            F.col("t.external_id"),
            F.col("t.event_ts"),
            F.col("t.event_date"),
            F.col("t.dvla_status"),
            F.when(F.col("t.dvla_status") == "present", F.lit("ORPHAN_PRESENT"))
             .when(F.col("t.dvla_status") == "not_present", F.lit("ORPHAN_NOT_PRESENT"))
             .otherwise(F.lit("UNKNOWN")).alias("monitor_status"),
            F.current_timestamp().alias("checked_ts")
        )
    )

    final_df = safe_union([eligible_side, orphan_side])

    return final_df.dropDuplicates([
        "run_date",
        "table_name",
        "mqs_quote_id",
        "message_type",
        "monitor_status"
    ])

def write_detail(df: DataFrame) -> None:
    delete_run_partition(DETAIL_TABLE)
    (
        df.write
        .mode("append")
        .saveAsTable(DETAIL_TABLE)
    )

# =========================================================
# STEP 4 - SUMMARY
# =========================================================

def build_summary(detail_df: DataFrame) -> DataFrame:
    return (
        detail_df.groupBy("run_date", "table_name", "message_type")
        .agg(
            F.countDistinct(F.when(F.col("eligible_flag") == 1, F.col("mqs_quote_id"))).alias("eligible_quotes"),
            F.countDistinct(F.when(F.col("monitor_status") == "ELIGIBLE_DELETED", F.col("mqs_quote_id"))).alias("deleted_quotes"),
            F.countDistinct(F.when(F.col("monitor_status") == "ELIGIBLE_RETAINED", F.col("mqs_quote_id"))).alias("retained_quotes"),
            F.countDistinct(F.when(F.col("monitor_status") == "NOT_FOUND_IN_TARGET", F.col("mqs_quote_id"))).alias("not_found_in_target_quotes"),
            F.countDistinct(F.when(F.col("monitor_status") == "ORPHAN_PRESENT", F.col("mqs_quote_id"))).alias("orphan_present_quotes"),
            F.countDistinct(F.when(F.col("monitor_status") == "ORPHAN_NOT_PRESENT", F.col("mqs_quote_id"))).alias("orphan_not_present_quotes"),
            F.max("days_from_dwh").alias("max_days_from_dwh"),
            F.avg("days_from_dwh").alias("avg_days_from_dwh")
        )
        .withColumn(
            "deletion_pct",
            F.round(
                F.when(
                    F.col("eligible_quotes") > 0,
                    (F.col("deleted_quotes") * F.lit(100.0)) / F.col("eligible_quotes")
                ),
                2
            )
        )
        .withColumn("created_ts", F.current_timestamp())
    )

def write_summary(df: DataFrame) -> None:
    delete_run_partition(SUMMARY_TABLE)
    (
        df.write
        .mode("append")
        .saveAsTable(SUMMARY_TABLE)
    )

# =========================================================
# MAIN
# =========================================================

def main():
    eligible_df = get_eligible_quotes()
    write_eligible_snapshot(eligible_df)

    ehub_df = get_ehubstream_base()
    raw_enrichments_df = get_dlt_raw_enrichments_base()
    rating_v2_df = get_dlt_rating_request_v2_base()

    ehub_detail = build_monitor_detail(eligible_df, ehub_df, "ehubstream")
    raw_enrichments_detail = build_monitor_detail(eligible_df, raw_enrichments_df, "dlt_raw_enrichments")
    rating_v2_detail = build_monitor_detail(eligible_df, rating_v2_df, "dlt_rating_request_v2")

    detail_df = safe_union([
        ehub_detail,
        raw_enrichments_detail,
        rating_v2_detail
    ])

    write_detail(detail_df)

    summary_df = build_summary(detail_df)
    write_summary(summary_df)

    print("DVLA payload deletion monitor completed successfully")
