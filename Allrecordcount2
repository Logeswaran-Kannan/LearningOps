SELECT
  tl.target_table_catalog,
  tl.target_table_schema,
  tl.target_table_name,
  tl.source_table_catalog,
  tl.source_table_schema,
  tl.source_table_name,
  tl.source_type,
  MAX(tl.event_time) AS last_seen
FROM system.access.table_lineage tl
JOIN target_entities te
  ON lower(tl.target_table_schema) = lower(te.dest_schema)
 AND lower(tl.target_table_name)   = lower(te.dest_entity)
WHERE tl.event_date >= DATE_SUB(current_date(), 90)   -- widen if needed
GROUP BY ALL
ORDER BY tl.target_table_name, tl.source_table_name;
