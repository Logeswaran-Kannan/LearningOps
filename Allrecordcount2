from pyspark.sql import functions as F

INPUT_TABLE = "core_tst.testing_sb.target_entities"
DEST_CATALOG = "core"
EVENT_LOOKBACK_DAYS = 400

OUTPUT_ODS_LIST = "core_tst.testing_sb.ods_upstream_tables"

targets_df = (
    spark.table(INPUT_TABLE)
    .select(
        F.lower(F.col("dest_schema")).alias("dest_schema"),
        F.lower(F.col("dest_entity")).alias("dest_entity")
    )
    .where(F.col("dest_schema").isNotNull())
    .where(F.col("dest_entity").isNotNull())
    .distinct()
    .withColumn(
        "destination_table",
        F.concat_ws(".", F.lit(DEST_CATALOG), F.col("dest_schema"), F.col("dest_entity"))
    )
)

table_lineage_df = (
    spark.table("system.access.table_lineage")
    .select(
        F.lower(F.col("source_table_full_name")).alias("ods_table"),
        F.lower(F.col("target_table_full_name")).alias("destination_table"),
        F.col("event_date")
    )
    .where(F.col("source_table_full_name").isNotNull())
    .where(F.col("target_table_full_name").isNotNull())
    .where(F.lower(F.col("source_table_full_name")).contains(".ods_views."))
)

table_lineage_df = table_lineage_df.where(
    F.col("event_date") >= F.date_sub(F.current_date(), EVENT_LOOKBACK_DAYS)
)

ods_upstream_tables = (
    table_lineage_df
    .join(targets_df.select("destination_table"), "destination_table", "inner")
    .select("ods_table")
    .distinct()
    .orderBy("ods_table")
)

display(ods_upstream_tables)

ods_upstream_tables.write.mode("overwrite").saveAsTable(OUTPUT_ODS_LIST)

print(f"Saved upstream ods_views table list to {OUTPUT_ODS_LIST}")
print(f"ODS upstream table count: {ods_upstream_tables.count()}")
