WITH target_users AS (
  SELECT lower(email) AS email
  FROM VALUES
    ('user1@company.com'),
    ('user2@company.com'),
    ('user3@company.com')
  AS t(email)
),

created_tables AS (
  SELECT
    event_time AS created_time,
    lower(user_identity.email) AS created_by,
    request_params.full_name AS full_table_name
  FROM system.access.audit
  WHERE action_name IN ('createTable', 'createTableV2')
    AND lower(user_identity.email) IN (SELECT email FROM target_users)
    AND request_params.full_name IS NOT NULL
),

table_list AS (
  SELECT
    created_by,
    full_table_name,
    split(full_table_name, '\\.')[0] AS catalog_name,
    split(full_table_name, '\\.')[1] AS schema_name,
    split(full_table_name, '\\.')[2] AS table_name,
    min(created_time) AS created_time
  FROM created_tables
  GROUP BY created_by, full_table_name
),

last_access AS (
  SELECT
    lower(source_table_full_name) AS full_table_name,
    max(event_time) AS last_accessed_time
  FROM system.access.table_lineage
  WHERE source_table_full_name IS NOT NULL
  GROUP BY lower(source_table_full_name)
)

SELECT
  t.created_by,
  t.catalog_name,
  t.schema_name,
  t.table_name,
  t.full_table_name,
  t.created_time,
  l.last_accessed_time,

  CASE
    WHEN l.last_accessed_time IS NULL THEN 'Never accessed / no lineage found'
    WHEN l.last_accessed_time < current_timestamp() - INTERVAL 90 DAYS THEN 'Not used > 90 days'
    WHEN l.last_accessed_time < current_timestamp() - INTERVAL 60 DAYS THEN 'Not used > 60 days'
    ELSE 'Recently used'
  END AS cleanup_readiness_status

FROM table_list t
LEFT JOIN last_access l
  ON lower(t.full_table_name) = l.full_table_name
ORDER BY
  t.created_by,
  t.catalog_name,
  t.schema_name,
  l.last_accessed_time ASC NULLS FIRST;
