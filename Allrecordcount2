# COMMAND ----------
# MAGIC %md ## 1. Configuration

# COMMAND ----------
@dataclass
class DDLReconConfig:
    # -- Three sources ------------------------------------------------------------
    prod_catalog: str = "core"              # Read Replica PROD -- production truth
    tst_catalog: str = "core_tst"           # Read Replica TST
    cda_catalog: str = "core_tst_std001"    # CDA
    prod_schema: str = "ods_views"
    tst_schema: str = "ods_views"
    cda_schema: str = "ods_views"
    cda_table_suffix: str = "_cda"

    # -- Table name filter (naming pattern) ----------------------------------------
    # Domain -> table-name prefix. PROD and TST use the bare name; CDA is the
    # same bare name + cda_table_suffix. Add domains here to extend coverage --
    # no other code changes needed.
    domain_prefixes: Dict[str, str] = field(default_factory=lambda: {
        "policycenter": "vw_policycenter_current_p",
        "billingcenter": "vw_billingcenter_current_b",
        "claimcenter": "vw_claimcenter_current_c",
    })

    # Columns known to exist only in CDA by design (CDC metadata) -- never
    # reported as drift.
    cda_only_expected_columns: List[str] = field(default_factory=lambda: ["gwcbi___operation"])

    # Loosen cosmetic type differences (e.g. varchar(n) vs string) that Unity
    # Catalog metadata may report differently without being a real conflict.
    normalize_types: bool = True

    # -- Output ---------------------------------------------------------------------
    output_catalog: str = "core_tst_std001"
    output_schema: str = "testing_sb"
    output_table: str = "gw_ddl_schema_drift_summary"
    write_results: bool = True
    results_mode: str = "append"   # append preserves daily history for trending

    # -- Resilience -------------------------------------------------------------------
    fail_run_if_error_rate_above: Optional[float] = None

    def prod_schema_fqn(self) -> str:
        return f"{self.prod_catalog}.{self.prod_schema}"

    def tst_schema_fqn(self) -> str:
        return f"{self.tst_catalog}.{self.tst_schema}"

    def cda_schema_fqn(self) -> str:
        return f"{self.cda_catalog}.{self.cda_schema}"

    def output_table_fqn(self) -> str:
        return f"{self.output_catalog}.{self.output_schema}.{self.output_table}"


