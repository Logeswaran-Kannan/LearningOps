DO $$
DECLARE
    r RECORD;
BEGIN
    DROP TABLE IF EXISTS temp_large_column_values;

    CREATE TEMP TABLE temp_large_column_values (
        table_name   TEXT,
        column_name  TEXT,
        row_ctid     TEXT,
        size_mb      NUMERIC(20,2)
    );

    FOR r IN
        SELECT table_name, column_name
        FROM information_schema.columns
        WHERE table_schema = 'public'
          AND data_type IN (
              'text',
              'character varying',
              'character',
              'json',
              'jsonb',
              'xml',
              'bytea'
          )
    LOOP
        EXECUTE format(
            'INSERT INTO temp_large_column_values
             SELECT %L,
                    %L,
                    ctid::text,
                    ROUND(pg_column_size(%I)::numeric / 1024 / 1024, 2)
             FROM public.%I
             WHERE pg_column_size(%I) > 1048576',
            r.table_name,
            r.column_name,
            r.column_name,
            r.table_name,
            r.column_name
        );
    END LOOP;
END $$;

SELECT *
FROM temp_large_column_values
ORDER BY size_mb DESC;
