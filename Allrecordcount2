SELECT
    event_time,
    source_table_full_name,
    target_table_full_name,
    entity_type,
    entity_id,
    entity_run_id,
    entity_metadata
FROM system.access.table_lineage
WHERE lower(source_table_full_name) =
      lower('core_tst.ods_views.vw_billingcenter_current_bc_account')
ORDER BY event_time DESC;
