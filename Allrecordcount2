import requests

jira_base_url = "https://your-jira-url"
jira_token = dbutils.secrets.get(scope="your_scope", key="jira_pat")

url = f"{jira_base_url}/rest/api/2/myself"

headers = {
    "Authorization": f"Bearer {jira_token}",
    "Accept": "application/json"
}

try:
    response = requests.get(url, headers=headers, timeout=30)

    print("Status Code:", response.status_code)
    print("Response:")
    print(response.text[:1000])

except requests.exceptions.Timeout:
    print("Connection timed out. Databricks cannot reach Jira within 30 seconds.")

except requests.exceptions.ConnectionError as e:
    print("Connection error. Possible firewall / DNS / network issue.")
    print(str(e))

except Exception as e:
    print("Unexpected error:")
    print(str(e))
