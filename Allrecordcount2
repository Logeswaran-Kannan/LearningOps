from datetime import datetime
from pyspark.sql.types import StructType, StructField, StringType, IntegerType

bucket = dbutils.secrets.get(
    scope="Azure-secret-key-vault",
    key="gw-cda-s3-bucket-name"
)

base_path = f"s3a://{bucket}/prod/bc/1756398239893/"

rows = []

table_folders = [t for t in dbutils.fs.ls(base_path) if t.isDir()]

for table in table_folders:
    table_name = table.name.rstrip("/")
    table_path = table.path

    batch_dates = []
    subfolder_count = 0
    timestamp_folder_count = 0
    status = "SUCCESS"
    error_message = ""

    try:
        subfolders = [s for s in dbutils.fs.ls(table_path) if s.isDir()]
        subfolder_count = len(subfolders)

        for sub in subfolders:
            try:
                timestamp_folders = [x for x in dbutils.fs.ls(sub.path) if x.isDir()]
                timestamp_folder_count += len(timestamp_folders)

                for ts_folder in timestamp_folders:
                    ts_name = ts_folder.name.rstrip("/")

                    try:
                        ts = int(ts_name)
                        dt = datetime.fromtimestamp(ts / 1000)
                        batch_dates.append(dt)
                    except:
                        pass

            except Exception as e:
                status = "PARTIAL_SUCCESS"
                error_message = str(e)

        if batch_dates:
            min_dt = min(batch_dates)
            max_dt = max(batch_dates)

            rows.append((
                table_name,
                table_path,
                subfolder_count,
                timestamp_folder_count,
                min_dt.strftime("%Y-%m-%d %H:%M:%S"),
                max_dt.strftime("%Y-%m-%d %H:%M:%S"),
                min_dt.strftime("%b-%Y"),
                max_dt.strftime("%b-%Y"),
                status,
                error_message
            ))
        else:
            rows.append((
                table_name,
                table_path,
                subfolder_count,
                timestamp_folder_count,
                "",
                "",
                "",
                "",
                "NO_TIMESTAMP_FOUND",
                error_message
            ))

    except Exception as e:
        rows.append((
            table_name,
            table_path,
            subfolder_count,
            timestamp_folder_count,
            "",
            "",
            "",
            "",
            "FAILED",
            str(e)
        ))

schema = StructType([
    StructField("table_name", StringType(), True),
    StructField("table_path", StringType(), True),
    StructField("subfolder_count", IntegerType(), True),
    StructField("timestamp_folder_count", IntegerType(), True),
    StructField("min_batch_date", StringType(), True),
    StructField("max_batch_date", StringType(), True),
    StructField("min_month_year", StringType(), True),
    StructField("max_month_year", StringType(), True),
    StructField("status", StringType(), True),
    StructField("error_message", StringType(), True)
])

summary_df = spark.createDataFrame(rows, schema)

display(summary_df.orderBy("table_name"))
