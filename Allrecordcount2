from datetime import datetime

bucket = dbutils.secrets.get(
    scope="Azure-secret-key-vault",
    key="gw-cda-s3-bucket-name"
)

path = f"s3a://{bucket}/prod/bc/"

for f in dbutils.fs.ls(path):
    try:
        # Remove trailing slash if present
        ts = int(f.name.rstrip("/"))

        # Convert milliseconds to datetime
        dt = datetime.fromtimestamp(ts / 1000)

        print(f"{f.name:<20} --> {dt.strftime('%B %Y')} ({dt.strftime('%Y-%m-%d %H:%M:%S')})")

    except ValueError:
        # Skip non-timestamp folders
        pass
