from pyspark.sql import functions as F
from pyspark.sql.types import StructType, ArrayType
from pyspark.sql import DataFrame

source_table = "core_tst.your_schema.source_table"
target_table = "core_tst.your_schema.target_deflatten_table"
payload_col = "payload"

df = spark.table(source_table)

# Add traceable source row id before exploding arrays
df = df.withColumn("source_row_id", F.monotonically_increasing_id())

# Infer JSON schema from payload
payload_schema = spark.read.json(
    df.select(payload_col)
      .where(F.col(payload_col).isNotNull())
      .rdd
      .map(lambda r: r[payload_col])
).schema

# Parse payload string into struct
df_parsed = df.withColumn(
    "payload_json",
    F.from_json(F.col(payload_col), payload_schema)
)

def flatten_df(df: DataFrame, sep: str = "_") -> DataFrame:
    while True:
        complex_cols = []

        for field in df.schema.fields:
            if isinstance(field.dataType, StructType):
                complex_cols.append((field.name, "struct"))
            elif isinstance(field.dataType, ArrayType):
                complex_cols.append((field.name, "array"))

        if not complex_cols:
            break

        col_name, col_type = complex_cols[0]

        if col_type == "struct":
            nested_cols = [
                F.col(f"`{col_name}`.`{nested.name}`")
                 .alias(f"{col_name}{sep}{nested.name}")
                for nested in df.schema[col_name].dataType.fields
            ]

            df = df.select("*", *nested_cols).drop(col_name)

        elif col_type == "array":
            df = df.withColumn(
                col_name,
                F.explode_outer(F.col(col_name))
            )

    return df

# Flatten payload_json, keep original payload and source_row_id
df_flattened = flatten_df(df_parsed)

# Write target deflattened table
(
    df_flattened
    .write
    .format("delta")
    .mode("overwrite")
    .option("overwriteSchema", "true")
    .saveAsTable(target_table)
)
