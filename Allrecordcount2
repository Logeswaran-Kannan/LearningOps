from pyspark.sql import functions as F
from pyspark.sql.types import StructType, ArrayType
from pyspark.sql import DataFrame

SOURCE_TABLE = "core_tst.mqs_athn_mtr.ehubstream"
TARGET_TABLE = "core_tst.mqs_athn_mtr.precomp_request_flattened"

# Read source data
df = (
    spark.table(SOURCE_TABLE)
    .filter(
        F.col("headers")
         .getField("messageType")
         .cast("string") == "precomp-request"
    )
)

# Traceable source row id
df = df.withColumn("source_row_id", F.monotonically_increasing_id())

# Infer payload schema
payload_schema = spark.read.json(
    df.select("payload")
      .where(F.col("payload").isNotNull())
      .rdd
      .map(lambda r: r["payload"])
).schema

# Parse JSON payload
df = df.withColumn(
    "payload_json",
    F.from_json(F.col("payload"), payload_schema)
)

def flatten_df(df: DataFrame, sep="_"):

    while True:

        complex_cols = []

        for field in df.schema.fields:

            if isinstance(field.dataType, StructType):
                complex_cols.append((field.name, "struct"))

            elif isinstance(field.dataType, ArrayType):
                complex_cols.append((field.name, "array"))

        if not complex_cols:
            break

        col_name, col_type = complex_cols[0]

        if col_type == "struct":

            expanded = [
                F.col(f"`{col_name}`.`{f.name}`")
                 .alias(f"{col_name}{sep}{f.name}")
                for f in df.schema[col_name].dataType.fields
            ]

            df = df.select("*", *expanded).drop(col_name)

        elif col_type == "array":

            df = df.withColumn(
                col_name,
                F.explode_outer(F.col(col_name))
            )

    return df

# Flatten entire dataframe
df_flat = flatten_df(df)

# Optional cleanup
df_flat = df_flat.drop("payload_json")

# Save flattened output
(
    df_flat.write
    .format("delta")
    .mode("overwrite")
    .option("overwriteSchema", "true")
    .saveAsTable(TARGET_TABLE)
)

print(f"Flattened table created: {TARGET_TABLE}")





# Count how many flattened rows each source message produced
display(
    spark.table(TARGET_TABLE)
         .groupBy("source_row_id")
         .count()
         .orderBy(F.desc("count"))
)
