DO $$
DECLARE
    r RECORD;
    sql_text TEXT;
BEGIN
    DROP TABLE IF EXISTS temp_large_columns;

    CREATE TEMP TABLE temp_large_columns (
        schema_name TEXT,
        table_name  TEXT,
        column_name TEXT,
        row_id      TEXT,
        data_size_mb NUMERIC
    );

    FOR r IN
        SELECT table_schema, table_name, column_name
        FROM information_schema.columns
        WHERE table_schema NOT IN ('pg_catalog', 'information_schema')
          AND data_type NOT IN ('bytea') -- remove this line if you also want bytea columns
    LOOP
        sql_text := format(
            'INSERT INTO temp_large_columns
             SELECT %L, %L, %L,
                    ctid::text,
                    ROUND(pg_column_size(%I)::numeric / 1024 / 1024, 2)
             FROM %I.%I
             WHERE pg_column_size(%I) > 1048576',
            r.table_schema,
            r.table_name,
            r.column_name,
            r.column_name,
            r.table_schema,
            r.table_name,
            r.column_name
        );

        EXECUTE sql_text;
    END LOOP;
END $$;

SELECT *
FROM temp_large_columns
ORDER BY data_size_mb DESC;
